@page "/access-denied"
@using Microsoft.AspNetCore.Authorization

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex flex-column align-center justify-center" Style="min-height:60vh;">
    <MudIcon Icon="@Icons.Material.Filled.Lock" Color="Color.Error" Style="font-size:64px;" Class="mb-4" />
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-2" Style="font-family:'DM Serif Display',serif;">Access Denied</MudText>
    <MudText Typo="Typo.body1" Align="Align.Center" Class="mb-6" Style="color:var(--mud-palette-text-secondary);">
        You don't have permission to view this page.
    </MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Href="/" StartIcon="@Icons.Material.Filled.Home">
        Back to Dashboard
    </MudButton>
</MudContainer>
