    // ── Grading rule upsert ──────────────────────────────
    private async Task SetGradingRuleAsync(int classGroupTypeId, int gradeId, int? scaleId)
    {
        var key = (classGroupTypeId, gradeId);
        _gradingRuleScaleIds[key] = scaleId;

        var existing = await Db.TermGradeGradingRules
            .FirstOrDefaultAsync(r =>
                r.TermInstanceId   == _selectedTermId &&
                r.ClassGroupTypeId == classGroupTypeId &&
                r.GradeId          == gradeId);

        if (scaleId == null)
        {
            if (existing != null) { Db.TermGradeGradingRules.Remove(existing); await Db.SaveChangesAsync(); }
            return;
        }

        if (existing != null)
        {
            existing.GradingScaleId = scaleId.Value;
        }
        else
        {
            Db.TermGradeGradingRules.Add(new TermGradeGradingRule
            {
                TermInstanceId   = _selectedTermId!.Value,
                ClassGroupTypeId = classGroupTypeId,
                GradeId          = gradeId,
                GradingScaleId   = scaleId.Value
            });
        }
        await Db.SaveChangesAsync();
        Snackbar.Add("Grading scale saved.", Severity.Success);
    }

    // ── Subject config actions ──────────────────────────────
    private async Task SetModifierTemplateAsync(int cgiId, int classTemplateId, int? templateId)
    {
        var key = (cgiId, classTemplateId);
        if (!_subjectConfigs.TryGetValue(key, out var cfg))
        {
            cfg = new ClassGroupSubjectConfig
            {
                ClassGroupInstanceId      = cgiId,
                CurriculumClassTemplateId = classTemplateId,
                ActiveStrandIdsJson       = "[]",
                UpdatedAt                 = DateTimeOffset.UtcNow
            };
            Db.ClassGroupSubjectConfigs.Add(cfg);
            await Db.SaveChangesAsync();
            _subjectConfigs[key] = cfg;
        }

        cfg.SubjectModifierTemplateId = templateId;
        cfg.UpdatedAt = DateTimeOffset.UtcNow;
        await Db.SaveChangesAsync();
        Snackbar.Add("Modifier template saved.", Severity.Success);
    }

    private async Task ToggleStrandAsync(int cgiId, int classTemplateId, int strandId, bool active)
    {
        var toggleKey = (cgiId, classTemplateId, strandId);
        if (active) _activeStrands.Add(toggleKey);
        else        _activeStrands.Remove(toggleKey);

        var cfgKey = (cgiId, classTemplateId);
        if (!_subjectConfigs.TryGetValue(cfgKey, out var cfg))
        {
            cfg = new ClassGroupSubjectConfig
            {
                ClassGroupInstanceId      = cgiId,
                CurriculumClassTemplateId = classTemplateId,
                ActiveStrandIdsJson       = "[]",
                UpdatedAt                 = DateTimeOffset.UtcNow
            };
            Db.ClassGroupSubjectConfigs.Add(cfg);
            await Db.SaveChangesAsync();
            _subjectConfigs[cfgKey] = cfg;
        }

        // Rebuild active strand IDs from the HashSet for this cgi+template
        var activeIds = _activeStrands
            .Where(k => k.CgiId == cgiId && k.ClassTemplateId == classTemplateId)
            .Select(k => k.StrandId)
            .ToList();

        cfg.ActiveStrandIdsJson = System.Text.Json.JsonSerializer.Serialize(activeIds);
        cfg.UpdatedAt = DateTimeOffset.UtcNow;
        await Db.SaveChangesAsync();
    }

    // ── Helpers ───────────────────────────────────────────
    private static string GetInitials(string? first, string? last)
    {
        var f = string.IsNullOrWhiteSpace(first) ? "?" : first[0].ToString().ToUpper();
        var l = string.IsNullOrWhiteSpace(last)  ? ""  : last[0].ToString().ToUpper();
        return f + l;
    }
