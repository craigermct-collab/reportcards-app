@page "/class-setup"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@inject SchoolDbContext Db
@inject ISnackbar Snackbar

<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">Class Setup</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@(_showAddForm ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
               OnClick="@(() => _showAddForm = !_showAddForm)"
               Disabled="@(_selectedTermId == null)">
        @(_showAddForm ? "Cancel" : "New Class Group")
    </MudButton>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Set up class groups, assign teachers, and enroll students per term.
</MudText>

<!-- ── Year + Term Selector ───────────────────────────── -->
@if (_isLoading)
{
    <MudCard Class="mb-6" Elevation="1">
        <MudCardContent Class="d-flex justify-center pa-6">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </MudCardContent>
    </MudCard>
}
else
{
    <MudCard Class="mb-6" Elevation="1">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?"
                               Value="_selectedYearId"
                               ValueChanged="@(async (int? v) => { _selectedYearId = v; _selectedTermId = null; _classGroupInstances = new(); _enrollmentsByGroup = new(); })"
                               Label="School Year"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var y in _schoolYears)
                        {
                            <MudSelectItem T="int?" Value="@((int?)y.Id)">
                                @y.Name @(y.IsActive ? "★" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?"
                               Value="_selectedTermId"
                               ValueChanged="@(async (int? v) => { _selectedTermId = v; await LoadClassGroupsAsync(); })"
                               Label="Term"
                               Variant="Variant.Outlined"
                               Disabled="@(_selectedYearId == null)"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var t in TermsForYear)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>
}

@if (_selectedTermId != null)
{
    <!-- ── Add Class Group Instance ─────────────────────── -->
    <MudCollapse Expanded="_showAddForm">
    <MudCard Class="mb-6" Elevation="1">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">Add Class Group</MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?" @bind-Value="_newClassGroupTypeId"
                               Label="Class Group Type"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var cgt in _classGroupTypes)
                        {
                            <MudSelectItem T="int?" Value="@((int?)cgt.Id)">@cgt.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_newDisplayName"
                                  Label="Display Name"
                                  Placeholder="e.g. Kindergarten AM"
                                  Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="4" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddClassGroupInstanceAsync"
                               Disabled="@(!CanAddGroup)"
                               FullWidth="true">
                        Add Class Group
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>
    </MudCollapse>

    <!-- ── Class Group Instances List ───────────────────── -->
    @if (_classGroupInstances.Count == 0)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            No class groups set up for this term yet.
        </MudAlert>
    }
    else
    {
        @foreach (var cgi in _classGroupInstances)
        {
            var enrollments = _enrollmentsByGroup.GetValueOrDefault(cgi.Id) ?? new();
            var enrolledStudentIds = enrollments.Select(e => e.StudentId).ToHashSet();
            var available = _activeStudents.Where(s => !enrolledStudentIds.Contains(s.Id))
                                           .OrderBy(s => s.LastName).ThenBy(s => s.FirstName).ToList();
            var grades = GradesForGroup(cgi.ClassGroupTypeId);

            <MudCard Class="mb-4" Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <div class="d-flex align-center gap-3">
                            <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
                            <div>
                                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                    @cgi.DisplayName
                                </MudText>
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                    @cgi.ClassGroupType?.Name
                                </MudText>
                            </div>
                        </div>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudTooltip Text="Delete class group">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="@(() => DeleteClassGroupAsync(cgi))" />
                        </MudTooltip>
                    </CardHeaderActions>
                </MudCardHeader>

                <MudCardContent>

                    <!-- ── Teachers ───────────────────────────────── -->
                    <MudText Typo="Typo.overline" Class="mb-2"
                             Style="color:var(--mud-palette-text-secondary);">Teachers</MudText>

                    @if (cgi.TeacherAssignments.Count > 0)
                    {
                        <MudTable Items="cgi.TeacherAssignments" Dense="true" Hover="true"
                                  Elevation="0" Class="mb-3"
                                  Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                            <HeaderContent>
                                <MudTh>Teacher</MudTh>
                                <MudTh>Grade (optional)</MudTh>
                                <MudTh>Role (optional)</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>@context.Teacher?.DisplayName</MudTd>
                                <MudTd>@(context.Grade?.Name ?? "—")</MudTd>
                                <MudTd>@(context.Role ?? "—")</MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                   Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => DeleteAssignmentAsync(context))" />
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mb-3"
                                 Style="color:var(--mud-palette-text-secondary);">
                            No teachers assigned yet.
                        </MudText>
                    }

                    <!-- Add teacher assignment -->
                    <MudGrid Class="mb-5">
                        <MudItem xs="12" sm="3">
                            <MudSelect T="int?" @bind-Value="_newTeacherIds[cgi.Id]"
                                       Label="Teacher"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       AnchorOrigin="Origin.BottomCenter">
                                @foreach (var t in _activeTeachers)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="int?" @bind-Value="_newAssignmentGradeIds[cgi.Id]"
                                       Label="Grade (optional)"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true"
                                       AnchorOrigin="Origin.BottomCenter">
                                @foreach (var g in grades)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField @bind-Value="_newAssignmentRoles[cgi.Id]"
                                          Label="Role (optional)"
                                          Placeholder="e.g. Lead Teacher"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="3" Class="d-flex align-end">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.PersonAdd"
                                       OnClick="@(() => AddAssignmentAsync(cgi))"
                                       Disabled="@(!CanAddAssignment(cgi.Id))"
                                       FullWidth="true">
                                Assign Teacher
                            </MudButton>
                        </MudItem>
                    </MudGrid>

                    <MudDivider Class="mb-4" />

                    <!-- ── Students ───────────────────────────────── -->
                    <MudText Typo="Typo.overline" Class="mb-2"
                             Style="color:var(--mud-palette-text-secondary);">
                        Students
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                 Variant="Variant.Filled" Class="ml-1">
                            @enrollments.Count
                        </MudChip>
                    </MudText>

                    @if (enrollments.Count > 0)
                    {
                        <MudTable Items="enrollments" Dense="true" Hover="true"
                                  Elevation="0" Class="mb-3"
                                  Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                            <HeaderContent>
                                <MudTh>Student</MudTh>
                                <MudTh>Grade</MudTh>
                                <MudTh>Enrolled</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <div class="d-flex align-center gap-2">
                                        <MudAvatar Style="background:#1B4F72; color:white; width:26px; height:26px; font-size:10px; font-weight:700;">
                                            @GetInitials(context.Student?.FirstName, context.Student?.LastName)
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                                            @context.Student?.LastName, @context.Student?.FirstName
                                        </MudText>
                                    </div>
                                </MudTd>
                                <MudTd>@context.Grade?.Name</MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.caption">
                                        @context.EnrolledOn.ToString("MMM d, yyyy")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudTooltip Text="Reseed learning items">
                                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                       Color="Color.Info" Size="Size.Small"
                                                       OnClick="@(() => ReseedAsync(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Unenroll student">
                                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                                       Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => UnenrollAsync(context, cgi.Id))" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mb-3"
                                 Style="color:var(--mud-palette-text-secondary);">
                            No students enrolled yet.
                        </MudText>
                    }

                    <!-- Add student enrollment -->
                    @if (available.Count > 0 || grades.Count > 0)
                    {
                        <MudGrid>
                            <MudItem xs="12" sm="5">
                                <MudSelect T="int?" @bind-Value="_newEnrollStudentIds[cgi.Id]"
                                           Label="Student"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           AnchorOrigin="Origin.BottomCenter">
                                    @foreach (var s in available)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)s.Id)">
                                            @s.LastName, @s.FirstName
                                        </MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="4">
                                <MudSelect T="int?" @bind-Value="_newEnrollGradeIds[cgi.Id]"
                                           Label="Grade"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           AnchorOrigin="Origin.BottomCenter">
                                    @foreach (var g in grades)
                                    {
                                        <MudSelectItem T="int?" Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                                    }
                                </MudSelect>
                            </MudItem>
                            <MudItem xs="12" sm="3" Class="d-flex align-end">
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.HowToReg"
                                           OnClick="@(() => EnrollStudentAsync(cgi))"
                                           Disabled="@(!CanEnroll(cgi.Id))"
                                           FullWidth="true">
                                    Enroll
                                </MudButton>
                            </MudItem>
                        </MudGrid>
                        @if (available.Count == 0)
                        {
                            <MudText Typo="Typo.caption" Class="mt-1"
                                     Style="color:var(--mud-palette-text-secondary);">
                                All active students are already enrolled in this class group.
                            </MudText>
                        }
                    }

                    <MudDivider Class="mt-5 mb-4" />

                    <!-- ── Grading Scales ───────────────────────── -->
                    <MudText Typo="Typo.overline" Class="mb-3"
                             Style="color:var(--mud-palette-text-secondary);">Default Grading Scale per Grade</MudText>

                    @if (_gradingScales.Count == 0)
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true">
                            No grading scales defined yet. Add scales on the Grading Scales page first.
                        </MudAlert>
                    }
                    else if (grades.Count == 0)
                    {
                        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
                            No grades configured for this class group type.
                        </MudText>
                    }
                    else
                    {
                        <MudGrid>
                            @foreach (var grade in grades)
                            {
                                var ruleKey = (cgi.ClassGroupTypeId, grade.Id);
                                var currentScaleId = _gradingRuleScaleIds.GetValueOrDefault(ruleKey);
                                <MudItem xs="12" sm="6" md="4">
                                    <MudSelect T="int?"
                                               Value="@currentScaleId"
                                               ValueChanged="@(async (int? v) => await SetGradingRuleAsync(cgi.ClassGroupTypeId, grade.Id, v))"
                                               Label="@grade.Name"
                                               Variant="Variant.Outlined"
                                               Margin="Margin.Dense"
                                               Clearable="true"
                                               AnchorOrigin="Origin.BottomCenter"
                                               HelperText="@(currentScaleId == null ? "Not set — will use first scale as fallback" : null)">
                                        @foreach (var scale in _gradingScales)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)scale.Id)">
                                                @scale.Name
                                                @if (scale.ValueType == GradingValueType.OptionList)
                                                {
                                                    <span style="opacity:0.6;"> · @scale.Options.Count options</span>
                                                }
                                                else
                                                {
                                                    <span style="opacity:0.6;"> · Numeric</span>
                                                }
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </MudItem>
                            }
                        </MudGrid>
                    }

                    @if (_subjectGroups.Count > 0)
                    {
                        <MudDivider Class="mt-5 mb-4" />

                        <MudText Typo="Typo.overline" Class="mb-3"
                                 Style="color:var(--mud-palette-text-secondary);">Subject Configuration</MudText>

                        @foreach (var sg in _subjectGroups)
                        {
                            var cfgKey = (cgi.Id, sg.Id);
                            var cfg = _subjectConfigs.GetValueOrDefault(cfgKey);
                            var currentTemplateId = cfg?.SubjectModifierTemplateId;
                            var strands = _strandsByGroup.GetValueOrDefault(sg.Id) ?? new();

                            <MudCard Elevation="0" Class="mb-3"
                                     Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                                <MudCardContent Class="pa-3">
                                    <div class="d-flex align-center justify-space-between mb-2">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight:700;">
                                            @sg.Name
                                        </MudText>
                                    </div>

                                    <MudGrid>
                                        <MudItem xs="12" sm="5">
                                            <MudSelect T="int?"
                                                       Value="@currentTemplateId"
                                                       ValueChanged="@(async (int? v) => await SetModifierTemplateAsync(cgi.Id, sg.Id, v))"
                                                       Label="Modifier Template"
                                                       Variant="Variant.Outlined"
                                                       Margin="Margin.Dense"
                                                       Clearable="true"
                                                       AnchorOrigin="Origin.BottomCenter"
                                                       HelperText="Checkboxes shown beside this subject's mark">
                                                @foreach (var tmpl in _modifierTemplates)
                                                {
                                                    <MudSelectItem T="int?" Value="@((int?)tmpl.Id)">
                                                        @tmpl.Name
                                                    </MudSelectItem>
                                                }
                                            </MudSelect>
                                        </MudItem>
                                    </MudGrid>

                                    @if (strands.Count > 0)
                                    {
                                        <MudText Typo="Typo.caption" Class="mt-3 mb-1 d-block"
                                                 Style="color:var(--mud-palette-text-secondary);">Active Strands</MudText>
                                        <div class="d-flex flex-wrap gap-2">
                                            @foreach (var strand in strands)
                                            {
                                                var isActive = _activeStrands.Contains((cgi.Id, sg.Id, strand.Id));
                                                var strandStyle = isActive
                                                    ? "cursor:pointer; font-weight:700;"
                                                    : "cursor:pointer; font-weight:400;";
                                                <MudChip T="string"
                                                         Variant="@(isActive ? Variant.Filled : Variant.Outlined)"
                                                         Color="@(isActive ? Color.Primary : Color.Default)"
                                                         Size="Size.Small"
                                                         Style="@strandStyle"
                                                         OnClick="@(async () => await ToggleStrandAsync(cgi.Id, sg.Id, strand.Id, !isActive))">
                                                    @strand.Name
                                                </MudChip>
                                            }
                                        </div>
                                        <MudText Typo="Typo.caption" Class="mt-1"
                                                 Style="color:var(--mud-palette-text-secondary); font-style:italic;">
                                            Click a strand to toggle it on/off. Filled = active on report card.
                                        </MudText>
                                    }
                                </MudCardContent>
                            </MudCard>
                        }
                    }

                </MudCardContent>
            </MudCard>
        }
    }
}

@code {
    // ── Data ──────────────────────────────────────────────
    private bool _isLoading = true;
    private List<SchoolYear>          _schoolYears        = new();
    private List<ClassGroupType>      _classGroupTypes    = new();
    private List<Teacher>             _activeTeachers     = new();
    private List<Student>             _activeStudents     = new();
    private List<ClassGroupInstance>  _classGroupInstances = new();

    // enrollments keyed by ClassGroupInstance.Id
    private Dictionary<int, List<Enrollment>> _enrollmentsByGroup = new();

    // ── Selection state ───────────────────────────────────
    private int? _selectedYearId;
    private int? _selectedTermId;

    // ── Add group form ────────────────────────────────────
    private bool   _showAddForm;
    private int?   _newClassGroupTypeId;
    private string _newDisplayName = "";

    // ── Per-group teacher assignment state ─────────────────
    private Dictionary<int, int?>   _newTeacherIds         = new();
    private Dictionary<int, int?>   _newAssignmentGradeIds = new();
    private Dictionary<int, string> _newAssignmentRoles    = new();

    // ── Per-group enrollment state ─────────────────────────
    private Dictionary<int, int?> _newEnrollStudentIds = new();
    private Dictionary<int, int?> _newEnrollGradeIds   = new();

    // ── Grading rules: keyed by (ClassGroupTypeId, GradeId) ──
    // Value is the selected GradingScaleId (null = not set)
    private Dictionary<(int ClassGroupTypeId, int GradeId), int?> _gradingRuleScaleIds = new();
    private List<GradingScale> _gradingScales = new();

    // ── Subject modifier / strand config ──────────────────────
    private List<SubjectModifierTemplate>  _modifierTemplates  = new();
    // Curriculum class templates available for the selected year (deduplicated by name)
    private List<CurriculumClassTemplate>  _subjectGroups      = new();
    // Strands keyed by CurriculumClassTemplateId
    private Dictionary<int, List<CurriculumSubStrand>> _strandsByGroup = new();
    // Config keyed by (ClassGroupInstanceId, CurriculumClassTemplateId)
    private Dictionary<(int CgiId, int ClassTemplateId), ClassGroupSubjectConfig> _subjectConfigs = new();
    // UI strand toggle state keyed by (ClassGroupInstanceId, CurriculumClassTemplateId, StrandId)
    private HashSet<(int CgiId, int ClassTemplateId, int StrandId)> _activeStrands = new();

    // ── Computed ──────────────────────────────────────────
    private bool CanAddGroup =>
        _selectedTermId != null &&
        _newClassGroupTypeId != null &&
        !string.IsNullOrWhiteSpace(_newDisplayName);

    private bool CanAddAssignment(int cgiId) =>
        _newTeacherIds.TryGetValue(cgiId, out var t) && t != null;

    private bool CanEnroll(int cgiId) =>
        _newEnrollStudentIds.TryGetValue(cgiId, out var s) && s != null &&
        _newEnrollGradeIds.TryGetValue(cgiId, out var g) && g != null;

    private List<TermInstance> TermsForYear =>
        _schoolYears.FirstOrDefault(y => y.Id == _selectedYearId)?.TermInstances
            .OrderBy(t => t.SortOrder).ToList() ?? new();

    private List<Grade> GradesForGroup(int classGroupTypeId) =>
        _classGroupTypes.FirstOrDefault(c => c.Id == classGroupTypeId)?.Grades
            .OrderBy(g => g.SortOrder).ToList() ?? new();

    // ── Lifecycle ─────────────────────────────────────────
    protected override async Task OnInitializedAsync()
    {
        _schoolYears = await Db.SchoolYears
            .Include(y => y.TermInstances)
            .OrderByDescending(y => y.Name)
            .ToListAsync();

        _classGroupTypes = await Db.ClassGroupTypes
            .Include(c => c.Grades)
            .OrderBy(c => c.SortOrder)
            .ToListAsync();

        _activeTeachers = await Db.Teachers
            .Where(t => t.IsActive)
            .OrderBy(t => t.DisplayName)
            .ToListAsync();

        _activeStudents = await Db.Students
            .Where(s => s.IsActive)
            .OrderBy(s => s.LastName).ThenBy(s => s.FirstName)
            .ToListAsync();

        _gradingScales = await Db.GradingScales
            .Include(s => s.Options)
            .OrderBy(s => s.Name)
            .ToListAsync();

        var activeYear = _schoolYears.FirstOrDefault(y => y.IsActive);
        if (activeYear != null)
        {
            _selectedYearId = activeYear.Id;
            _selectedTermId = activeYear.TermInstances.OrderBy(t => t.SortOrder).FirstOrDefault()?.Id;
        }

        await LoadClassGroupsAsync();
        _isLoading = false;
    }

    private async Task LoadClassGroupsAsync()
    {
        if (_selectedTermId == null)
        {
            _classGroupInstances = new();
            _enrollmentsByGroup  = new();
            return;
        }

        _classGroupInstances = await Db.ClassGroupInstances
            .Where(c => c.TermInstanceId == _selectedTermId)
            .Include(c => c.ClassGroupType)
                .ThenInclude(ct => ct.Grades.OrderBy(g => g.SortOrder))
            .Include(c => c.TeacherAssignments)
                .ThenInclude(a => a.Teacher)
            .Include(c => c.TeacherAssignments)
                .ThenInclude(a => a.Grade)
            .OrderBy(c => c.ClassGroupType!.SortOrder)
            .ThenBy(c => c.DisplayName)
            .ToListAsync();

        // Load enrollments for all groups in one query
        var cgiIds = _classGroupInstances.Select(c => c.Id).ToList();
        var allEnrollments = await Db.Enrollments
            .Where(e => cgiIds.Contains(e.ClassGroupInstanceId))
            .Include(e => e.Student)
            .Include(e => e.Grade)
            .OrderBy(e => e.Student!.LastName).ThenBy(e => e.Student!.FirstName)
            .ToListAsync();
        _enrollmentsByGroup = allEnrollments.GroupBy(e => e.ClassGroupInstanceId)
            .ToDictionary(g => g.Key, g => g.ToList());

        // Init per-group form state
        foreach (var cgi in _classGroupInstances)
        {
            _newTeacherIds.TryAdd(cgi.Id, null);
            _newAssignmentGradeIds.TryAdd(cgi.Id, null);
            _newAssignmentRoles.TryAdd(cgi.Id, "");
            _newEnrollStudentIds.TryAdd(cgi.Id, null);
            _newEnrollGradeIds.TryAdd(cgi.Id, null);
        }

        // Load existing grading rules for this term
        var existingRules = await Db.TermGradeGradingRules
            .Where(r => r.TermInstanceId == _selectedTermId)
            .ToListAsync();
        _gradingRuleScaleIds = existingRules
            .ToDictionary(
                r => (r.ClassGroupTypeId, r.GradeId),
                r => (int?)r.GradingScaleId);

        await LoadSubjectConfigAsync();
    }

    private async Task LoadSubjectConfigAsync()
    {
        if (_selectedTermId == null) return;

        // Load modifier templates
        _modifierTemplates = await Db.SubjectModifierTemplates
            .OrderBy(t => t.IsSystem ? 0 : 1).ThenBy(t => t.Name)
            .ToListAsync();

        // Find the school year for the selected term
        var schoolYearId = await Db.TermInstances
            .Where(t => t.Id == _selectedTermId)
            .Select(t => t.SchoolYearId)
            .FirstOrDefaultAsync();

        // Load curriculum class templates (subject groups) for this year
        // Get distinct IDs first, then load with full includes
        var subjectGroupIds = await Db.YearClassOfferings
            .Where(o => o.YearCurriculum!.SchoolYearId == schoolYearId && o.IsEnabled)
            .Select(o => o.CurriculumClassTemplateId)
            .Distinct()
            .ToListAsync();

        _subjectGroups = await Db.CurriculumClassTemplates
            .Where(ct => subjectGroupIds.Contains(ct.Id))
            .Include(ct => ct.SubjectTemplates)
                .ThenInclude(st => st.SubStrands)
            .OrderBy(ct => ct.SortOrder)
            .ToListAsync();

        // Build strands lookup (flatten all substrands across subjects within each group)
        _strandsByGroup = _subjectGroups.ToDictionary(
            sg => sg.Id,
            sg => sg.SubjectTemplates
                     .SelectMany(st => st.SubStrands)
                     .OrderBy(s => s.SortOrder)
                     .ToList());

        // Load existing configs for all class group instances in this term
        var cgiIds = _classGroupInstances.Select(c => c.Id).ToList();
        var configs = await Db.ClassGroupSubjectConfigs
            .Where(c => cgiIds.Contains(c.ClassGroupInstanceId))
            .ToListAsync();

        _subjectConfigs = configs.ToDictionary(
            c => (c.ClassGroupInstanceId, c.CurriculumClassTemplateId));

        // Build active strand toggles from saved JSON
        _activeStrands = new HashSet<(int, int, int)>();
        foreach (var cfg in configs)
        {
            var ids = System.Text.Json.JsonSerializer
                .Deserialize<List<int>>(cfg.ActiveStrandIdsJson) ?? new();
            foreach (var sid in ids)
                _activeStrands.Add((cfg.ClassGroupInstanceId, cfg.CurriculumClassTemplateId, sid));
        }
    }

    // ── Teacher actions ───────────────────────────────────
    private async Task AddAssignmentAsync(ClassGroupInstance cgi)
    {
        if (!CanAddAssignment(cgi.Id)) return;

        Db.TeacherAssignments.Add(new TeacherAssignment
        {
            ClassGroupInstanceId = cgi.Id,
            TeacherId            = _newTeacherIds[cgi.Id]!.Value,
            GradeId              = _newAssignmentGradeIds.GetValueOrDefault(cgi.Id),
            Role                 = string.IsNullOrWhiteSpace(_newAssignmentRoles.GetValueOrDefault(cgi.Id))
                                   ? null : _newAssignmentRoles[cgi.Id].Trim()
        });

        await Db.SaveChangesAsync();
        _newTeacherIds[cgi.Id]         = null;
        _newAssignmentGradeIds[cgi.Id] = null;
        _newAssignmentRoles[cgi.Id]    = "";
        Snackbar.Add("Teacher assigned.", Severity.Success);
        await LoadClassGroupsAsync();
    }

    private async Task DeleteAssignmentAsync(TeacherAssignment assignment)
    {
        Db.TeacherAssignments.Remove(assignment);
        await Db.SaveChangesAsync();
        Snackbar.Add("Assignment removed.", Severity.Info);
        await LoadClassGroupsAsync();
