@page "/report-card-mapping"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@using ReportCards.Web.Services
@inject SchoolDbContext Db
@inject PdfFieldReaderService PdfReader
@inject PdfRenderService PdfRenderer
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<PageTitle>Report Card Field Mapping</PageTitle>

<div class="d-flex align-center gap-3 mb-1">
    <MudIcon Icon="@Icons.Material.Filled.AccountTree"
             Style="background:#1B4F72; color:white; padding:8px; border-radius:10px; font-size:24px;" />
    <div>
        <MudText Typo="Typo.h5" Style="font-family:'DM Serif Display',serif; line-height:1.1;">Report Card Field Mapping</MudText>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
            Drag a DB field onto a highlighted PDF field to map it. Auto-Map All handles the full set instantly.
        </MudText>
    </div>
</div>

<MudDivider Class="my-4" />

@if (_loading)
{
    <div class="d-flex justify-center pa-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else
{
    <!-- Template selector + actions -->
    <MudCard Elevation="1" Class="mb-4">
        <MudCardContent Class="py-3">
            <MudGrid Spacing="3" AlignItems="AlignItems.Center">
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?" Label="Report Card Template" Value="_selectedTemplateId"
                               ValueChanged="OnTemplateChanged"
                               Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomLeft"
                               Clearable="true">
                        @foreach (var t in _templates)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.Id)">
                                @t.Name
                                <MudChip T="string" Size="Size.Small" Class="ml-2"
                                         Color="@(t.TemplateType == ReportCardTemplateType.ElementaryProgressReport ? Color.Info : Color.Secondary)"
                                         Variant="Variant.Filled" Style="font-size:10px; height:18px;">
                                    @(t.TemplateType == ReportCardTemplateType.ElementaryProgressReport ? "Progress" : "RC1")
                                </MudChip>
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                @if (_selectedTemplate != null)
                {
                    <MudItem xs="12" sm="8">
                        <div class="d-flex align-center gap-2 flex-wrap">
                            <MudChip T="string" Icon="@Icons.Material.Filled.Link"
                                     Color="@(_mappings.Any() ? Color.Success : Color.Warning)"
                                     Variant="Variant.Filled" Size="Size.Small">
                                @_mappings.Count mapped
                            </MudChip>
                            <MudButton Variant="Variant.Outlined" Color="Color.Error" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.DeleteSweep"
                                       OnClick="ClearAllMappingsAsync"
                                       Disabled="@(!_mappings.Any())">
                                Clear All
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.AutoFixHigh"
                                       OnClick="AutoMapAll">
                                Auto-Map All
                            </MudButton>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="SaveMappingsAsync"
                                       Disabled="@(!_dirty)">
                                Save Mappings
                            </MudButton>
                            <!-- Page tabs -->
                            @if (_pageImages.Any())
                            {
                                <MudDivider Vertical="true" Style="height:24px;" />
                                @for (int p = 1; p <= _pageImages.Count; p++)
                                {
                                    var pageNum = p;
                                    <MudButton Variant="@(_currentPage == pageNum ? Variant.Filled : Variant.Outlined)"
                                               Color="Color.Primary" Size="Size.Small"
                                               OnClick="@(() => SwitchPage(pageNum))">
                                        Page @pageNum
                                    </MudButton>
                                }
                            }
                        </div>
                    </MudItem>
                }
            </MudGrid>
        </MudCardContent>
    </MudCard>

    @if (_selectedTemplate != null)
    {
        <div style="display:flex; gap:12px; align-items:flex-start;">

            <!-- LEFT: DB Source fields panel -->
            <div style="width:220px; flex-shrink:0;">
                <MudText Typo="Typo.overline" Style="color:#1B4F72; font-size:11px; font-weight:700; display:block; margin-bottom:8px;">
                    📊 DB Source Fields
                </MudText>
                <div style="max-height:calc(100vh - 220px); overflow-y:auto;">
                    @foreach (var group in _sourceGroups)
                    {
                        <div class="mb-2">
                            <MudText Typo="Typo.overline"
                                     Style="color:var(--mud-palette-text-secondary); font-size:9px; letter-spacing:0.08em; display:block; margin-bottom:3px; padding-left:4px;">
                                @group.Label
                            </MudText>
                            @foreach (var src in group.Fields)
                            {
                                var isMapped = _mappings.Any(m => m.ReportDestinationKey == src.Key);
                                var mappedTo = _mappings.FirstOrDefault(m => m.ReportDestinationKey == src.Key)?.PdfFieldName;
                                <div class="src-chip @(isMapped ? "src-mapped" : "") @(_dragSourceKey == src.Key ? "src-dragging" : "")"
                                     draggable="true"
                                     @ondragstart="@(() => { _dragSourceKey = src.Key; })"
                                     @ondragend="@(() => { _dragSourceKey = null; })"
                                     title="@src.Key">
                                    <div style="display:flex; align-items:center; gap:4px;">
                                        <div style="width:7px; height:7px; border-radius:50%; flex-shrink:0; background:@(isMapped ? "#2E7D32" : "#1B4F72");"></div>
                                        <span style="font-size:11px; font-weight:@(isMapped ? "600" : "400"); white-space:nowrap; overflow:hidden; text-overflow:ellipsis; flex:1;">@src.Label</span>
                                        @if (isMapped)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Style="color:#2E7D32; font-size:12px; flex-shrink:0;" />
                                        }
                                    </div>
                                    @if (isMapped && mappedTo != null)
                                    {
                                        <div style="font-size:9px; color:var(--mud-palette-text-secondary); margin-left:11px; font-family:monospace; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                                            → @mappedTo
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>

            <!-- RIGHT: PDF overlay panel -->
            <div style="flex:1; min-width:0;">
                @if (_pageImages.Any() && _currentPage <= _pageImages.Count)
                {
                    var pageImage = _pageImages[_currentPage - 1];
                    var fieldsOnPage = _fieldRects.Where(f => f.Page == _currentPage).ToList();
                    const double PdfW = 612.0;
                    const double PdfH = 792.0;

                    <div style="position:relative; display:inline-block; max-width:100%;"
                         ondragover="event.preventDefault()">

                        <!-- Rendered PDF page image -->
                        <img src="@pageImage"
                             style="display:block; max-width:100%; width:100%; border:1px solid var(--mud-palette-divider); border-radius:4px;"
                             id="pdf-page-img" />

                        <!-- Field overlay drop zones — positioned using PDF coordinates scaled to image size -->
                        @if (_imgWidth > 0)
                        {
                            var scaleX = _imgWidth  / PdfW;
                            var scaleY = _imgHeight / PdfH;

                            @foreach (var f in fieldsOnPage)
                            {
                                var (left, top, right, bottom) = f.ToScreen(PdfH);
                                var cssLeft   = left   * scaleX;
                                var cssTop    = top    * scaleY;
                                var cssWidth  = (right - left) * scaleX;
                                var cssHeight = (bottom - top) * scaleY;

                                var isMapped  = _mappings.Any(m => m.PdfFieldName == f.Name);
                                var isTarget  = _dragTargetPdf == f.Name;
                                var srcKey    = _mappings.FirstOrDefault(m => m.PdfFieldName == f.Name)?.ReportDestinationKey;

                                var borderColor = isTarget ? "#E67E22" : isMapped ? "#2E7D32" : "rgba(27,79,114,0.5)";
                                var bgColor     = isTarget ? "rgba(230,126,34,0.25)"
                                                : isMapped ? "rgba(46,125,50,0.15)"
                                                : f.FieldType == "Checkbox" ? "rgba(123,79,191,0.08)"
                                                : "rgba(27,79,114,0.06)";
                                var fieldTitle  = isMapped ? $"{f.Name} <- {srcKey}" : $"{f.Name} (unmapped)";

                                <div class="pdf-field-zone"
                                     style="position:absolute;
                                            left:@(cssLeft.ToString("F1"))px;
                                            top:@(cssTop.ToString("F1"))px;
                                            width:@(cssWidth.ToString("F1"))px;
                                            height:@(cssHeight.ToString("F1"))px;
                                            border: @(isTarget ? "2px" : "1.5px") solid @borderColor;
                                            background: @bgColor;
                                            border-radius: 2px;
                                            cursor: pointer;
                                            box-sizing: border-box;"
                                     title="@fieldTitle"
                                     ondragover="event.preventDefault()"
                                     @ondragenter="@(() => _dragTargetPdf = f.Name)"
                                     @ondragleave="@(() => { if (_dragTargetPdf == f.Name) _dragTargetPdf = null; })"
                                     @ondrop="@(async (DragEventArgs e) => await HandleDropAsync(f.Name))"
                                     @onclick="@(() => ClickPdfField(f.Name))">
                                    @if (isMapped && cssHeight > 14)
                                    {
                                        <span style="font-size:@(Math.Min(cssHeight * 0.55, 9).ToString("F0"))px;
                                                     color:#2E7D32; font-weight:600;
                                                     white-space:nowrap; overflow:hidden;
                                                     display:block; padding:1px 2px;
                                                     font-family:monospace; line-height:1;">
                                            @srcKey?.Split('.').LastOrDefault()
                                        </span>
                                    }
                                </div>
                            }
                        }
                    </div>

                    <!-- Legend -->
                    <div class="d-flex gap-3 mt-2 flex-wrap">
                        <div class="d-flex align-center gap-1">
                            <div style="width:12px; height:8px; border:1.5px solid rgba(27,79,114,0.5); background:rgba(27,79,114,0.06); border-radius:1px;"></div>
                            <MudText Typo="Typo.caption">Unmapped</MudText>
                        </div>
                        <div class="d-flex align-center gap-1">
                            <div style="width:12px; height:8px; border:1.5px solid #2E7D32; background:rgba(46,125,50,0.15); border-radius:1px;"></div>
                            <MudText Typo="Typo.caption">Mapped</MudText>
                        </div>
                        <div class="d-flex align-center gap-1">
                            <div style="width:12px; height:8px; border:2px solid #E67E22; background:rgba(230,126,34,0.25); border-radius:1px;"></div>
                            <MudText Typo="Typo.caption">Drag target</MudText>
                        </div>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                            Click a mapped field to remove the mapping. Drag a DB field (left) onto a PDF field to map it.
                        </MudText>
                    </div>
                }
                else if (_selectedTemplate != null && !_pageImages.Any())
                {
                    var renderErr = PdfRenderer.GetLastError(_selectedTemplate.FileName);
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                        Could not render PDF pages for <strong>@_selectedTemplate.FileName</strong>.
                        @if (renderErr != null)
                        {
                            <div style="font-family:monospace; font-size:11px; margin-top:4px;">@renderErr</div>
                        }
                    </MudAlert>
                }
            </div>
        </div>
    }
    else
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Select a report card template above to begin mapping.
        </MudAlert>
    }
}

<style>
    .src-chip {
        padding: 5px 8px;
        margin-bottom: 4px;
        border-radius: 6px;
        border: 1px solid var(--mud-palette-divider);
        background: var(--mud-palette-surface);
        cursor: grab;
        transition: border-color 0.1s, background 0.1s;
        user-select: none;
    }
    .src-chip:hover {
        border-color: #1B4F72;
        background: rgba(27,79,114,0.04);
    }
    .src-mapped {
        border-color: #2E7D32;
        background: rgba(46,125,50,0.04);
    }
    .src-dragging {
        opacity: 0.5;
        cursor: grabbing;
    }
    .pdf-field-zone {
        transition: border-color 0.1s, background 0.1s;
    }
    .pdf-field-zone:hover {
        filter: brightness(0.92);
    }
</style>

@code {
    private record SourceGroup(string Label, List<SourceField> Fields);
    private record SourceField(string Key, string Label);
    private record MappingEntry(string ReportDestinationKey, string PdfFieldName);

    private bool _loading = true;
    private bool _dirty   = false;
    private int  _currentPage = 1;
    private double _imgWidth  = 0;
    private double _imgHeight = 0;

    private List<ReportCardTemplate>           _templates        = new();
    private ReportCardTemplate?                _selectedTemplate = null;
    private int?                               _selectedTemplateId = null;
    private List<PdfFieldInfo>                 _pdfFields        = new();
    private List<MappingEntry>                 _mappings         = new();
    private List<SourceGroup>                  _sourceGroups     = new();
    private List<string>                       _pageImages       = new();
    private List<PdfFieldCoordinates.FieldRect> _fieldRects      = new();

    private string? _dragSourceKey = null;
    private string? _dragTargetPdf = null;

    protected override async Task OnInitializedAsync()
    {
        _templates = await Db.ReportCardTemplates.OrderBy(t => t.Name).ToListAsync();
        BuildSourceGroups();
        _loading = false;
    }

    private async Task OnTemplateChanged(int? id)
    {
        _selectedTemplateId = id;
        _selectedTemplate   = _templates.FirstOrDefault(t => t.Id == id);
        _pdfFields          = new();
        _mappings           = new();
        _pageImages         = new();
        _fieldRects         = new();
        _currentPage        = 1;
        _imgWidth           = 0;
        _imgHeight          = 0;
        _dirty              = false;
        _needsImageMeasure  = true;

        if (_selectedTemplate == null) return;

        BuildSourceGroups(_selectedTemplate);

        // Load PDF field list
        _pdfFields = PdfReader.GetFields(_selectedTemplate.FileName);

        // Render PDF pages to images
        _pageImages = PdfRenderer.GetPageImages(_selectedTemplate.FileName, dpi: 120);

        // Load field coordinate overlay data
        _fieldRects = PdfFieldCoordinates.GetForFile(_selectedTemplate.FileName);

        // Load saved mappings
        var saved = await Db.ReportTemplateFieldMaps
            .Where(m => m.ReportCardTemplateId == id)
            .ToListAsync();
        _mappings = saved.Select(m => new MappingEntry(m.ReportDestinationKey, m.PdfFieldName)).ToList();
    }

    private bool _needsImageMeasure = false;

    private void SwitchPage(int pageNum)
    {
        _currentPage      = pageNum;
        _needsImageMeasure = true;
        // Don't reset _imgWidth — keep overlay visible during transition
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if ((firstRender || _needsImageMeasure) && _pageImages.Any())
        {
            _needsImageMeasure = false;
            try
            {
                // Use async version that waits for img.onload if not yet rendered
                var dims = await JS.InvokeAsync<double[]>("getImageDimensionsAsync", "pdf-page-img");
                if (dims?.Length == 2 && dims[0] > 0)
                {
                    _imgWidth  = dims[0];
                    _imgHeight = dims[1];
                    StateHasChanged();
                }
                else
                {
                    // Fallback: retry once after a short delay
                    await Task.Delay(300);
                    dims = await JS.InvokeAsync<double[]>("getImageDimensionsAsync", "pdf-page-img");
                    if (dims?.Length == 2 && dims[0] > 0)
                    {
                        _imgWidth  = dims[0];
                        _imgHeight = dims[1];
                        StateHasChanged();
                    }
                }
            }
            catch { }
        }
    }

    private Task HandleDropAsync(string pdfFieldName)
    {
        DropOnPdfField(pdfFieldName);
        return Task.CompletedTask;
    }

    private void DropOnPdfField(string pdfFieldName)
    {
        if (_dragSourceKey == null) return;
        _mappings.RemoveAll(m => m.ReportDestinationKey == _dragSourceKey || m.PdfFieldName == pdfFieldName);
        _mappings.Add(new MappingEntry(_dragSourceKey, pdfFieldName));
        _dirty = true;
        _dragSourceKey = null;
        _dragTargetPdf = null;
        StateHasChanged();
    }

    private void ClickPdfField(string pdfFieldName)
    {
        // If already mapped — remove the mapping (click to unmap)
        var existing = _mappings.FirstOrDefault(m => m.PdfFieldName == pdfFieldName);
        if (existing != null)
        {
            _mappings.Remove(existing);
            _dirty = true;
            Snackbar.Add($"Removed mapping for {pdfFieldName}", Severity.Info);
            StateHasChanged();
        }
    }

    private void AutoMapAll()
    {
        if (_selectedTemplate == null) return;
        var pdfFieldNames = _pdfFields.Select(f => f.Name).ToHashSet();
        _mappings.Clear();

        var maps = IsKindergartenTemplate(_selectedTemplate)
            ? ReportCardFieldMapSeeder.KindergartenCommunicationOfLearningMaps()
            : ReportCardFieldMapSeeder.ElementaryReportCardMaps();

        int matched = 0, skipped = 0;
        foreach (var (destKey, pdfField) in maps)
        {
            if (pdfFieldNames.Contains(pdfField))
            {
                _mappings.Add(new MappingEntry(destKey, pdfField));
                matched++;
            }
            else skipped++;
        }

        _dirty = true;
        var msg = skipped > 0
            ? $"{matched} mappings auto-populated ({skipped} PDF fields not found — check field names). Click Save Mappings."
            : $"{matched} mappings auto-populated. Click Save Mappings.";
        Snackbar.Add(msg, skipped > 0 ? Severity.Warning : Severity.Success);
        StateHasChanged();
    }

    private static bool IsKindergartenTemplate(ReportCardTemplate t) =>
        t.FileName.StartsWith("Kindergarten", StringComparison.OrdinalIgnoreCase) ||
        t.FileName.StartsWith("kindergarten", StringComparison.OrdinalIgnoreCase);

    private async Task SaveMappingsAsync()
    {
        if (_selectedTemplate == null) return;
        try
        {
            var existing = await Db.ReportTemplateFieldMaps
                .Where(m => m.ReportCardTemplateId == _selectedTemplate.Id)
                .ToListAsync();
            Db.ReportTemplateFieldMaps.RemoveRange(existing);

            foreach (var m in _mappings)
            {
                Db.ReportTemplateFieldMaps.Add(new ReportTemplateFieldMap
                {
                    ReportCardTemplateId = _selectedTemplate.Id,
                    ReportDestinationKey = m.ReportDestinationKey,
                    PdfFieldName         = m.PdfFieldName,
                });
            }

            await Db.SaveChangesAsync();
            _dirty = false;
            Snackbar.Add($"{_mappings.Count} mappings saved.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ClearAllMappingsAsync()
    {
        if (_selectedTemplate == null) return;
        var existing = await Db.ReportTemplateFieldMaps
            .Where(m => m.ReportCardTemplateId == _selectedTemplate.Id)
            .ToListAsync();
        Db.ReportTemplateFieldMaps.RemoveRange(existing);
        await Db.SaveChangesAsync();
        _mappings.Clear();
        _dirty = false;
        Snackbar.Add("All mappings cleared.", Severity.Info);
    }

    private void BuildSourceGroups(ReportCardTemplate? template = null)
    {
        if (template != null && IsKindergartenTemplate(template))
        {
            _sourceGroups = new List<SourceGroup>
            {
                new("Student Info", new()
                {
                    new(ReportDestinationKeys.StudentName,    "Student Name"),
                    new(ReportDestinationKeys.StudentOen,     "OEN"),
                    new(ReportDestinationKeys.TeacherName,    "Teacher"),
                    new(ReportDestinationKeys.SchoolName,     "School Name"),
                    new(ReportDestinationKeys.SchoolBoard,    "School Board"),
                    new(ReportDestinationKeys.SchoolAddress,  "Address"),
                    new(ReportDestinationKeys.SchoolPhone,    "Phone"),
                    new(ReportDestinationKeys.Principal,      "Principal"),
                    new(ReportDestinationKeys.TermDate,       "Date"),
                }),
                new("Attendance", new()
                {
                    new(ReportDestinationKeys.DaysAbsent,      "Days Absent"),
                    new(ReportDestinationKeys.TotalDaysAbsent, "Total Days Absent"),
                    new(ReportDestinationKeys.TimesLate,       "Times Late"),
                    new(ReportDestinationKeys.TotalTimesLate,  "Total Times Late"),
                }),
                new("Placement", new()
                {
                    new(ReportDestinationKeys.KindergartenYear2,      "Kindergarten Year 2"),
                    new(ReportDestinationKeys.KindergartenGrade1,     "Grade 1"),
                    new(ReportDestinationKeys.KindergartenReportYear1,"Report Year 1"),
                    new(ReportDestinationKeys.KindergartenReportYear2,"Report Year 2"),
                }),
                new("Belonging & Contributing", new()
                {
                    new(ReportDestinationKeys.KindergartenBelongingESL,   "ESL"),
                    new(ReportDestinationKeys.KindergartenBelongingIEP,   "IEP"),
                    new(ReportDestinationKeys.KindergartenBelongingNotes, "Notes / Comments"),
                }),
                new("Self-Regulation & Well-Being", new()
                {
                    new(ReportDestinationKeys.KindergartenSelfRegESL,   "ESL"),
                    new(ReportDestinationKeys.KindergartenSelfRegIEP,   "IEP"),
                    new(ReportDestinationKeys.KindergartenSelfRegNotes, "Notes / Comments"),
                }),
                new("Demonstrating Literacy & Math", new()
                {
                    new(ReportDestinationKeys.KindergartenLiteracyESL,   "ESL"),
                    new(ReportDestinationKeys.KindergartenLiteracyIEP,   "IEP"),
                    new(ReportDestinationKeys.KindergartenLiteracyNotes, "Notes / Comments"),
                }),
                new("Problem Solving & Innovating", new()
                {
                    new(ReportDestinationKeys.KindergartenProblemESL,   "ESL"),
                    new(ReportDestinationKeys.KindergartenProblemIEP,   "IEP"),
                    new(ReportDestinationKeys.KindergartenProblemNotes, "Notes / Comments"),
                }),
            };
            return;
        }

        _sourceGroups = new List<SourceGroup>
        {
            new("Student Info", new()
            {
                new(ReportDestinationKeys.StudentName,  "Student Name"),
                new(ReportDestinationKeys.StudentOen,   "OEN"),
                new(ReportDestinationKeys.StudentGrade, "Grade"),
                new(ReportDestinationKeys.TeacherName,  "Teacher"),
                new(ReportDestinationKeys.SchoolName,   "School Name"),
                new(ReportDestinationKeys.SchoolBoard,  "School Board"),
                new(ReportDestinationKeys.SchoolAddress,"Address"),
                new(ReportDestinationKeys.SchoolPhone,  "Phone"),
                new(ReportDestinationKeys.Principal,    "Principal"),
                new(ReportDestinationKeys.TermDate,     "Term Date"),
            }),
            new("Attendance", new()
            {
                new(ReportDestinationKeys.DaysAbsent,       "Days Absent"),
                new(ReportDestinationKeys.TotalDaysAbsent,  "Total Days Absent"),
                new(ReportDestinationKeys.TimesLate,        "Times Late"),
                new(ReportDestinationKeys.TotalTimesLate,   "Total Times Late"),
            }),
            new("Learning Skills", new()
            {
                new(ReportDestinationKeys.Responsibility  + ".term1", "Responsibility T1"),
                new(ReportDestinationKeys.Responsibility  + ".term2", "Responsibility T2"),
                new(ReportDestinationKeys.Organization    + ".term1", "Organization T1"),
                new(ReportDestinationKeys.Organization    + ".term2", "Organization T2"),
                new(ReportDestinationKeys.IndependentWork + ".term1", "Independent Work T1"),
                new(ReportDestinationKeys.IndependentWork + ".term2", "Independent Work T2"),
                new(ReportDestinationKeys.Collaboration   + ".term1", "Collaboration T1"),
                new(ReportDestinationKeys.Collaboration   + ".term2", "Collaboration T2"),
                new(ReportDestinationKeys.Initiative      + ".term1", "Initiative T1"),
                new(ReportDestinationKeys.Initiative      + ".term2", "Initiative T2"),
                new(ReportDestinationKeys.SelfRegulation  + ".term1", "Self-Regulation T1"),
                new(ReportDestinationKeys.SelfRegulation  + ".term2", "Self-Regulation T2"),
            }),
            new("Subjects", new()
            {
                new(ReportDestinationKeys.Language       + ".term1", "Language T1"),
                new(ReportDestinationKeys.Language       + ".term2", "Language T2"),
                new(ReportDestinationKeys.LanguageNotes,             "Language Notes"),
                new(ReportDestinationKeys.French         + ".term1", "French T1"),
                new(ReportDestinationKeys.French         + ".term2", "French T2"),
                new(ReportDestinationKeys.NativeLanguage + ".term1", "Native Lang T1"),
                new(ReportDestinationKeys.NativeLanguage + ".term2", "Native Lang T2"),
                new(ReportDestinationKeys.Mathematics    + ".term1", "Math T1"),
                new(ReportDestinationKeys.Mathematics    + ".term2", "Math T2"),
                new(ReportDestinationKeys.MathematicsNotes,          "Math Notes"),
                new(ReportDestinationKeys.ScienceAndTech + ".term1", "Sci & Tech T1"),
                new(ReportDestinationKeys.ScienceAndTech + ".term2", "Sci & Tech T2"),
                new(ReportDestinationKeys.ScienceAndTechNotes,       "Sci & Tech Notes"),
                new(ReportDestinationKeys.SocialStudies  + ".term1", "Social Studies T1"),
