@page "/enrollments"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@inject SchoolDbContext Db
@inject ISnackbar Snackbar
<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">Enrollments</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@(_showAddForm ? Icons.Material.Filled.Close : Icons.Material.Filled.PersonAdd)"
               OnClick="@(() => _showAddForm = !_showAddForm)"
               Disabled="@(_selectedClassGroupId == null)">
        @(_showAddForm ? "Cancel" : "Enroll Student")
    </MudButton>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Enroll students into class groups per term.
</MudText>

<!-- Year / Term / Class Group Selector -->
@if (_isLoading)
{
    <MudCard Class="mb-6" Elevation="1">
        <MudCardContent Class="d-flex justify-center pa-6">
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
        </MudCardContent>
    </MudCard>
}
else
{
    <MudCard Class="mb-6" Elevation="1">
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?"
                               Value="_selectedYearId"
                               ValueChanged="@(async (int? v) => { _selectedYearId = v; _selectedTermId = null; _selectedClassGroupId = null; _enrollments = new(); })"
                               Label="School Year" Variant="Variant.Outlined"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var y in _schoolYears)
                        {
                            <MudSelectItem T="int?" Value="@((int?)y.Id)">
                                @y.Name @(y.IsActive ? "★" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?"
                               Value="_selectedTermId"
                               ValueChanged="@(async (int? v) => { _selectedTermId = v; _selectedClassGroupId = null; _enrollments = new(); })"
                               Label="Term" Variant="Variant.Outlined"
                               Disabled="@(_selectedYearId == null)"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var t in TermsForYear)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.Id)">@t.Name</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudSelect T="int?"
                               Value="_selectedClassGroupId"
                               ValueChanged="@(async (int? v) => { _selectedClassGroupId = v; await LoadEnrollmentsAsync(); })"
                               Label="Class Group" Variant="Variant.Outlined"
                               Disabled="@(_selectedTermId == null)"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var cgi in ClassGroupsForTerm)
                        {
                            <MudSelectItem T="int?" Value="@((int?)cgi.Id)">
                                @cgi.DisplayName (@cgi.ClassGroupType?.Name)
                            </MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>
}

@if (_selectedClassGroupId != null)
{
    <MudGrid>
        <!-- Left: Enroll a student -->
        <MudItem xs="12" md="5">
        <MudCollapse Expanded="_showAddForm">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">Enroll Student</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent>
                    <MudSelect T="int?" @bind-Value="_newStudentId"
                               Label="Student" Variant="Variant.Outlined" Class="mb-3"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var s in AvailableStudents)
                        {
                            <MudSelectItem T="int?" Value="@((int?)s.Id)">
                                @s.LastName, @s.FirstName
                            </MudSelectItem>
                        }
                    </MudSelect>
                    <MudSelect T="int?" @bind-Value="_newGradeId"
                               Label="Grade" Variant="Variant.Outlined" Class="mb-4"
                               AnchorOrigin="Origin.BottomCenter">
                        @foreach (var g in GradesForSelectedGroup)
                        {
                            <MudSelectItem T="int?" Value="@((int?)g.Id)">@g.Name</MudSelectItem>
                        }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.PersonAdd"
                               OnClick="EnrollStudentAsync"
                               Disabled="@(!CanEnroll)" FullWidth="true">
                        Enroll
                    </MudButton>
                    @if (AvailableStudents.Count == 0)
                    {
                        <MudText Typo="Typo.caption" Class="mt-2"
                                 Style="color:var(--mud-palette-text-secondary);">
                            All active students are already enrolled in this class group.
                        </MudText>
                    }
                </MudCardContent>
            </MudCard>
        </MudCollapse>
        </MudItem>

        <!-- Right: Current enrollments -->
        <MudItem xs="12" md="7">
            <MudCard Elevation="1">
                <MudCardHeader>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">
                            Enrolled Students
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary"
                                     Variant="Variant.Filled" Class="ml-2">
                                @_enrollments.Count
                            </MudChip>
                        </MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pa-0">
                    @if (_enrollments.Count == 0)
                    {
                        <div class="pa-4">
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                                No students enrolled yet.
                            </MudAlert>
                        </div>
                    }
                    else
                    {
                        <MudTable Items="_enrollments" Hover="true" Dense="false" Elevation="0">
                            <HeaderContent>
                                <MudTh>Student</MudTh>
                                <MudTh>Grade</MudTh>
                                <MudTh>Enrolled</MudTh>
                                <MudTh></MudTh>
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd>
                                    <div class="d-flex align-center gap-2">
                                        <MudAvatar Style="background:#1B4F72; color:white; width:30px; height:30px; font-size:11px; font-weight:700;">
                                            @GetInitials(context.Student?.FirstName, context.Student?.LastName)
                                        </MudAvatar>
                                        <MudText Typo="Typo.body2" Style="font-weight:600;">
                                            @context.Student?.LastName, @context.Student?.FirstName
                                        </MudText>
                                    </div>
                                </MudTd>
                                <MudTd>@context.Grade?.Name</MudTd>
                                <MudTd>
                                    <MudText Typo="Typo.caption">
                                        @context.EnrolledOn.ToString("MMM d, yyyy")
                                    </MudText>
                                </MudTd>
                                <MudTd Style="text-align:right;">
                                    <MudTooltip Text="Reseed learning items">
                                        <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                                       Color="Color.Info" Size="Size.Small"
                                                       OnClick="@(() => ReseedAsync(context))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Unenroll student">
                                        <MudIconButton Icon="@Icons.Material.Filled.PersonRemove"
                                                       Color="Color.Error" Size="Size.Small"
                                                       OnClick="@(() => UnenrollAsync(context))" />
                                    </MudTooltip>
                                </MudTd>
                            </RowTemplate>
                        </MudTable>
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Attendance Panel -->
    <MudCard Class="mt-6" Elevation="1">
        <MudCardContent>
            <AttendancePanel
                ClassGroupInstanceId="@_selectedClassGroupId!.Value"
                TermInstanceId="@_selectedTermId!.Value"
                SchoolYearId="@(_schoolYears.FirstOrDefault(y => y.Id == _selectedYearId)?.Id ?? 0)" />
        </MudCardContent>
    </MudCard>
}

@code {
    private bool _isLoading = true;
    private List<SchoolYear> _schoolYears = new();
    private List<ClassGroupInstance> _allClassGroups = new();
    private List<Student> _activeStudents = new();
    private List<Enrollment> _enrollments = new();

    private int? _selectedYearId;
    private int? _selectedTermId;
    private int? _selectedClassGroupId;
    private int? _newStudentId;
    private int? _newGradeId;
    private bool  _showAddForm;

    private bool CanEnroll => _newStudentId != null && _newGradeId != null;

    private List<TermInstance> TermsForYear =>
        _schoolYears.FirstOrDefault(y => y.Id == _selectedYearId)?.TermInstances
            .OrderBy(t => t.SortOrder).ToList() ?? new();

    private List<ClassGroupInstance> ClassGroupsForTerm =>
        _allClassGroups.Where(c => c.TermInstanceId == _selectedTermId)
            .OrderBy(c => c.ClassGroupType?.SortOrder).ThenBy(c => c.DisplayName)
            .ToList();

    private ClassGroupInstance? SelectedGroup =>
        _allClassGroups.FirstOrDefault(c => c.Id == _selectedClassGroupId);

    private List<Grade> GradesForSelectedGroup =>
        SelectedGroup?.ClassGroupType?.Grades.OrderBy(g => g.SortOrder).ToList() ?? new();

    private List<Student> AvailableStudents
    {
        get
        {
            var enrolledIds = _enrollments.Select(e => e.StudentId).ToHashSet();
            return _activeStudents.Where(s => !enrolledIds.Contains(s.Id))
                .OrderBy(s => s.LastName).ThenBy(s => s.FirstName).ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _schoolYears = await Db.SchoolYears
            .Include(y => y.TermInstances)
            .OrderByDescending(y => y.Name)
            .ToListAsync();

        _allClassGroups = await Db.ClassGroupInstances
            .Include(c => c.ClassGroupType)
                .ThenInclude(ct => ct.Grades.OrderBy(g => g.SortOrder))
            .ToListAsync();

        _activeStudents = await Db.Students
            .Where(s => s.IsActive)
            .ToListAsync();

        var activeYear = _schoolYears.FirstOrDefault(y => y.IsActive);
        if (activeYear != null)
        {
            _selectedYearId = activeYear.Id;
            _selectedTermId = activeYear.TermInstances.OrderBy(t => t.SortOrder).FirstOrDefault()?.Id;
            // Auto-select first class group for the active term so students show immediately
            _selectedClassGroupId = _allClassGroups
                .Where(c => c.TermInstanceId == _selectedTermId)
                .OrderBy(c => c.ClassGroupType?.SortOrder)
                .ThenBy(c => c.DisplayName)
                .FirstOrDefault()?.Id;
        }

        await LoadEnrollmentsAsync();
        _isLoading = false;
    }

    private async Task LoadEnrollmentsAsync()
    {
        if (_selectedClassGroupId == null) { _enrollments = new(); return; }

        _enrollments = await Db.Enrollments
            .Where(e => e.ClassGroupInstanceId == _selectedClassGroupId)
            .Include(e => e.Student)
            .Include(e => e.Grade)
            .OrderBy(e => e.Student!.LastName).ThenBy(e => e.Student!.FirstName)
            .ToListAsync();
    }

    private async Task EnrollStudentAsync()
    {
        if (!CanEnroll) return;

        var exists = await Db.Enrollments.AnyAsync(e =>
            e.StudentId == _newStudentId &&
            e.ClassGroupInstanceId == _selectedClassGroupId);

        if (exists) { Snackbar.Add("Student is already enrolled in this class group.", Severity.Warning); return; }

        var enrollment = new Enrollment
        {
            StudentId            = _newStudentId!.Value,
            TermInstanceId       = _selectedTermId!.Value,
            ClassGroupInstanceId = _selectedClassGroupId!.Value,
            GradeId              = _newGradeId!.Value
        };
        Db.Enrollments.Add(enrollment);
        await Db.SaveChangesAsync();

        var seeded = await SeedLearningItemsAsync(enrollment);
        _newStudentId = null; _newGradeId = null; _showAddForm = false;
        Snackbar.Add($"Student enrolled with {seeded} learning item(s) seeded.", Severity.Success);
        await LoadEnrollmentsAsync();
    }

    private async Task ReseedAsync(Enrollment enrollment)
    {
        // Remove existing items that have no assessments yet (safe to reseed)
        var existing = await Db.StudentLearningItems
            .Where(li => li.EnrollmentId == enrollment.Id)
            .ToListAsync();

        var withAssessments = await Db.Assessments
            .Where(a => existing.Select(li => li.Id).Contains(a.StudentLearningItemId))
            .Select(a => a.StudentLearningItemId)
            .Distinct()
            .ToListAsync();

        var removable = existing.Where(li => !withAssessments.Contains(li.Id)).ToList();
        Db.StudentLearningItems.RemoveRange(removable);
        await Db.SaveChangesAsync();

        var seeded = await SeedLearningItemsAsync(enrollment);
        Snackbar.Add($"Reseeded: {seeded} learning item(s) added.", Severity.Success);
        StateHasChanged();
    }

    private async Task<int> SeedLearningItemsAsync(Enrollment enrollment)
    {
        // Find the YearCurriculum for this school year
        var yearCurriculum = await Db.YearCurriculums
            .FirstOrDefaultAsync(yc => yc.SchoolYearId ==
                Db.TermInstances
                    .Where(t => t.Id == enrollment.TermInstanceId)
                    .Select(t => t.SchoolYearId)
                    .FirstOrDefault());

        if (yearCurriculum == null) return 0;

        // Load class group type for fallback grading rule lookup
        var classGroupInstance = await Db.ClassGroupInstances
            .FirstOrDefaultAsync(c => c.Id == enrollment.ClassGroupInstanceId);

        // Load enabled class offerings for this grade
        var classOfferings = await Db.YearClassOfferings
            .Include(o => o.CurriculumClassTemplate)
            .Include(o => o.SubjectOfferings)
                .ThenInclude(so => so.CurriculumSubjectTemplate)
            .Where(o => o.YearCurriculumId == yearCurriculum.Id
                     && o.GradeId          == enrollment.GradeId
                     && o.IsEnabled)
            .ToListAsync();

        // Load fallback grading rules for this term+grade+classgroup
        var gradingRules = await Db.TermGradeGradingRules
            .Where(r => r.TermInstanceId    == enrollment.TermInstanceId
                     && r.GradeId           == enrollment.GradeId
                     && r.ClassGroupTypeId  == classGroupInstance!.ClassGroupTypeId)
            .ToListAsync();
        var fallbackScaleId = gradingRules.FirstOrDefault()?.GradingScaleId;

        // Track already-seeded items to avoid duplicates
        var existingClassOfferingIds   = await Db.StudentLearningItems
            .Where(li => li.EnrollmentId == enrollment.Id && li.YearClassOfferingId != null)
            .Select(li => li.YearClassOfferingId!.Value).ToListAsync();
        var existingSubjectOfferingIds = await Db.StudentLearningItems
            .Where(li => li.EnrollmentId == enrollment.Id && li.YearSubjectOfferingId != null)
            .Select(li => li.YearSubjectOfferingId!.Value).ToListAsync();

        int count = 0;
        foreach (var classOffering in classOfferings)
        {
            var template = classOffering.CurriculumClassTemplate;
            if (template == null) continue;

            if (!template.GradedAtStrandLevel)
            {
                // One item for the whole subject
                if (!existingClassOfferingIds.Contains(classOffering.Id))
                {
                    Db.StudentLearningItems.Add(new StudentLearningItem
                    {
                        EnrollmentId       = enrollment.Id,
                        DisplayName        = template.Name,
                        ItemType           = LearningItemType.Class,
                        YearClassOfferingId = classOffering.Id,
                        GradingScaleId     = classOffering.GradingScaleId ?? fallbackScaleId
                            ?? await GetDefaultScaleIdAsync()
                    });
                    count++;
                }
            }
            else
            {
                // One item per enabled strand
                foreach (var subjectOffering in classOffering.SubjectOfferings.Where(so => so.IsEnabled))
                {
                    if (existingSubjectOfferingIds.Contains(subjectOffering.Id)) continue;
                    var strandTemplate = subjectOffering.CurriculumSubjectTemplate;
                    if (strandTemplate == null) continue;

                    Db.StudentLearningItems.Add(new StudentLearningItem
                    {
                        EnrollmentId          = enrollment.Id,
                        DisplayName           = strandTemplate.Name,
                        ItemType              = LearningItemType.Subject,
                        YearClassOfferingId   = classOffering.Id,
                        YearSubjectOfferingId = subjectOffering.Id,
                        GradingScaleId        = subjectOffering.GradingScaleId
                            ?? classOffering.GradingScaleId
                            ?? fallbackScaleId
                            ?? await GetDefaultScaleIdAsync()
                    });
                    count++;
                }
            }
        }

        await Db.SaveChangesAsync();
        return count;
    }

    private async Task<int> GetDefaultScaleIdAsync()
    {
        // Last resort: grab any grading scale from the DB
        return await Db.GradingScales.Select(g => g.Id).FirstOrDefaultAsync();
    }

    private async Task UnenrollAsync(Enrollment enrollment)
    {
        Db.Enrollments.Remove(enrollment);
        await Db.SaveChangesAsync();
        Snackbar.Add($"{enrollment.Student?.FirstName} {enrollment.Student?.LastName} unenrolled.", Severity.Info);
        await LoadEnrollmentsAsync();
    }

    private static string GetInitials(string? first, string? last)
    {
        var f = string.IsNullOrWhiteSpace(first) ? "?" : first[0].ToString().ToUpper();
        var l = string.IsNullOrWhiteSpace(last) ? "" : last[0].ToString().ToUpper();
        return f + l;
    }
}
