@page "/grading-scales"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@inject SchoolDbContext Db
@inject ISnackbar Snackbar

<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">Grading Scales</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@(_showAddForm ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
               OnClick="@(() => _showAddForm = !_showAddForm)">
        @(_showAddForm ? "Cancel" : "New Scale")
    </MudButton>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    View and manage grading scales and their options.
</MudText>

<MudCollapse Expanded="_showAddForm">
<MudCard Class="mb-6" Elevation="1">
    <MudCardHeader>
        <CardHeaderContent>
            <MudText Typo="Typo.h6">Add Grading Scale</MudText>
        </CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_newName"
                              Label="Scale Name"
                              Placeholder="e.g. Kindergarten 3-Level"
                              Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="GradingValueType" @bind-Value="_newValueType"
                           Label="Type" Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomCenter">
                    <MudSelectItem T="GradingValueType" Value="GradingValueType.OptionList">Option List</MudSelectItem>
                    <MudSelectItem T="GradingValueType" Value="GradingValueType.Numeric">Numeric</MudSelectItem>
                </MudSelect>
            </MudItem>
            @if (_newValueType == GradingValueType.Numeric)
            {
                <MudItem xs="6" sm="1">
                    <MudNumericField @bind-Value="_newMin" Label="Min" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudNumericField @bind-Value="_newMax" Label="Max" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudNumericField @bind-Value="_newStep" Label="Step" Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="6" sm="1">
                    <MudTextField @bind-Value="_newSuffix" Label="Suffix" Placeholder="%" Variant="Variant.Outlined" />
                </MudItem>
            }
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddScaleAsync"
                           Disabled="@(string.IsNullOrWhiteSpace(_newName))"
                           FullWidth="true">
                    Add Scale
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudCardContent>
</MudCard>
</MudCollapse>

<!-- ── Scales List ─────────────────────────────────────── -->
@if (_scales.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No grading scales yet.</MudAlert>
}
else
{
    @foreach (var scale in _scales)
    {
        <MudCard Class="mb-4" Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.Scale" Color="Color.Primary" />
                        <div>
                            <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                @scale.Name
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                @if (scale.ValueType == GradingValueType.Numeric)
                                {
                                    @($"Numeric  {scale.MinValue} – {scale.MaxValue}, step {scale.Step}{scale.DisplaySuffix}")
                                }
                                else
                                {
                                    @($"Option List  ·  {scale.Options.Count} option(s)")
                                }
                            </MudText>
                        </div>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="@(scale.ValueType == GradingValueType.OptionList ? Color.Secondary : Color.Tertiary)">
                            @scale.ValueType.ToString()
                        </MudChip>
                    </div>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudTooltip Text="Delete scale">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error" Size="Size.Small"
                                       OnClick="@(() => DeleteScaleAsync(scale))" />
                    </MudTooltip>
                </CardHeaderActions>
            </MudCardHeader>

            @if (scale.ValueType == GradingValueType.OptionList)
            {
                <MudCardContent>
                    <!-- Options list -->
                    @if (scale.Options.Count > 0)
                    {
                        <div class="d-flex flex-wrap gap-2 mb-4">
                            @foreach (var opt in scale.Options.OrderBy(o => o.SortOrder))
                            {
                                <MudChip T="string"
                                         Variant="Variant.Filled"
                                         Color="Color.Default"
                                         OnClose="@(() => DeleteOptionAsync(opt))"
                                         Style="font-weight:600;">
                                    @if (!string.IsNullOrWhiteSpace(opt.Code))
                                    {
                                        <span style="opacity:0.6; margin-right:4px;">@opt.Code</span>
                                    }
                                    @opt.Label
                                </MudChip>
                            }
                        </div>
                    }
                    else
                    {
                        <MudText Typo="Typo.body2" Class="mb-3"
                                 Style="color:var(--mud-palette-text-secondary);">
                            No options yet.
                        </MudText>
                    }

                    <!-- Add option -->
                    <MudGrid>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_newOptionLabels[scale.Id]"
                                          Label="Label"
                                          Placeholder="e.g. At Class Level"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudTextField @bind-Value="_newOptionCodes[scale.Id]"
                                          Label="Code (optional)"
                                          Placeholder="e.g. CL"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                        </MudItem>
                        <MudItem xs="12" sm="3" Class="d-flex align-end">
                            <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       OnClick="@(() => AddOptionAsync(scale))"
                                       Disabled="@(!CanAddOption(scale.Id))"
                                       FullWidth="true">
                                Add Option
                            </MudButton>
                        </MudItem>
                    </MudGrid>
                </MudCardContent>
            }
        </MudCard>
    }
}

<!-- ═══════════════════════════════════════════════════════════ -->
<!-- SUBJECT MODIFIER TEMPLATES                                   -->
<!-- ═══════════════════════════════════════════════════════════ -->

<MudDivider Class="my-8" />

<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">Subject Modifier Templates</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Secondary" Size="Size.Small"
               StartIcon="@(_showAddModifierForm ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
               OnClick="@(() => _showAddModifierForm = !_showAddModifierForm)">
        @(_showAddModifierForm ? "Cancel" : "New Template")
    </MudButton>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Define sets of boolean options (e.g. ESL/ELD, IEP, French) that appear beside subject marks during grade entry.
    Assign a template to a class group during class setup.
</MudText>

<MudCollapse Expanded="_showAddModifierForm">
<MudCard Class="mb-6" Elevation="1">
    <MudCardHeader>
        <CardHeaderContent><MudText Typo="Typo.h6">New Modifier Template</MudText></CardHeaderContent>
    </MudCardHeader>
    <MudCardContent>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_newModifierName"
                              Label="Template Name"
                              Placeholder='e.g. "Standard (3 options)"'
                              Variant="Variant.Outlined" />
            </MudItem>
        </MudGrid>

        <!-- Option builder -->
        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Options</MudText>
        <div class="d-flex flex-wrap gap-2 mb-3">
            @foreach (var opt in _newModifierOptions)
            {
                <MudChip T="string" Variant="Variant.Filled" Color="Color.Secondary"
                         OnClose="@(() => _newModifierOptions.Remove(opt))">
                    @opt
                </MudChip>
            }
            @if (_newModifierOptions.Count == 0)
            {
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">No options yet — add some below.</MudText>
            }
        </div>
        <MudGrid>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_newModifierOptionInput"
                              Label="Option label"
                              Placeholder='e.g. "ESL/ELD"'
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              OnKeyUp="@HandleModifierOptionKeyUp" />
            </MudItem>
            <MudItem xs="12" sm="2" Class="d-flex align-end">
                <MudButton Variant="Variant.Outlined" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="AddModifierOption"
                           Disabled="@(string.IsNullOrWhiteSpace(_newModifierOptionInput))"
                           FullWidth="true">
                    Add Option
                </MudButton>
            </MudItem>
        </MudGrid>

        <MudButton Class="mt-4" Variant="Variant.Filled" Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveModifierTemplateAsync"
                   Disabled="@(string.IsNullOrWhiteSpace(_newModifierName) || _newModifierOptions.Count == 0)">
            Save Template
        </MudButton>
    </MudCardContent>
</MudCard>
</MudCollapse>

<!-- Modifier templates list -->
@if (_modifierTemplates.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No modifier templates yet.</MudAlert>
}
else
{
    @foreach (var tmpl in _modifierTemplates)
    {
        var options = System.Text.Json.JsonSerializer.Deserialize<List<string>>(tmpl.OptionsJson) ?? new();
        <MudCard Class="mb-4" Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" />
                        <div>
                            <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                @tmpl.Name
                            </MudText>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                @options.Count option(s)
                                @if (tmpl.IsSystem) { <span> · System template</span> }
                            </MudText>
                        </div>
                        @if (tmpl.IsSystem)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Warning">System</MudChip>
                        }
                    </div>
                </CardHeaderContent>
                <CardHeaderActions>
                    @if (!tmpl.IsSystem)
                    {
                        <MudTooltip Text="Delete template">
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error" Size="Size.Small"
                                           OnClick="@(() => DeleteModifierTemplateAsync(tmpl))" />
                        </MudTooltip>
                    }
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var opt in options)
                    {
                        <MudChip T="string" Variant="Variant.Outlined" Color="Color.Secondary"
                                 Size="Size.Small" Style="font-weight:600;">
                            @opt
                        </MudChip>
                    }
                </div>
            </MudCardContent>
        </MudCard>
    }
}

@code {
    private List<GradingScale> _scales = new();
    private bool _showAddForm;

    // New scale form
    private string _newName = "";
    private GradingValueType _newValueType = GradingValueType.OptionList;
    private decimal? _newMin;
    private decimal? _newMax;
    private decimal? _newStep;
    private string _newSuffix = "";

    // Per-scale option form
    private Dictionary<int, string> _newOptionLabels = new();
    private Dictionary<int, string> _newOptionCodes = new();

    private bool CanAddOption(int scaleId) =>
        _newOptionLabels.TryGetValue(scaleId, out var l) && !string.IsNullOrWhiteSpace(l);

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
        await LoadModifierTemplatesAsync();
    }

    private async Task LoadAsync()
    {
        _scales = await Db.GradingScales
            .Include(s => s.Options)
            .OrderBy(s => s.Name)
            .ToListAsync();

        foreach (var s in _scales)
        {
            _newOptionLabels.TryAdd(s.Id, "");
            _newOptionCodes.TryAdd(s.Id, "");
        }
    }

    private async Task AddScaleAsync()
    {
        if (string.IsNullOrWhiteSpace(_newName)) return;

        var scale = new GradingScale
        {
            Name = _newName.Trim(),
            ValueType = _newValueType
        };

        if (_newValueType == GradingValueType.Numeric)
        {
            scale.MinValue = _newMin;
            scale.MaxValue = _newMax;
            scale.Step = _newStep;
            scale.DisplaySuffix = string.IsNullOrWhiteSpace(_newSuffix) ? null : _newSuffix.Trim();
        }

        Db.GradingScales.Add(scale);
        await Db.SaveChangesAsync();

        _newName = ""; _showAddForm = false;
        _newMin = null; _newMax = null; _newStep = null; _newSuffix = "";
        Snackbar.Add("Grading scale added.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteScaleAsync(GradingScale scale)
    {
        Db.GradingScales.Remove(scale);
        await Db.SaveChangesAsync();
        Snackbar.Add($"'{scale.Name}' deleted.", Severity.Info);
        await LoadAsync();
    }

    private async Task AddOptionAsync(GradingScale scale)
    {
        if (!CanAddOption(scale.Id)) return;

        var label = _newOptionLabels[scale.Id].Trim();
        var code = _newOptionCodes.GetValueOrDefault(scale.Id, "").Trim();
        var sortOrder = scale.Options.Count + 1;

        Db.GradingScaleOptions.Add(new GradingScaleOption
        {
            GradingScaleId = scale.Id,
            Label = label,
            Code = string.IsNullOrWhiteSpace(code) ? null : code,
            SortOrder = sortOrder
        });

        await Db.SaveChangesAsync();
        _newOptionLabels[scale.Id] = "";
        _newOptionCodes[scale.Id] = "";
        Snackbar.Add($"Option '{label}' added.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteOptionAsync(GradingScaleOption option)
    {
        Db.GradingScaleOptions.Remove(option);
        await Db.SaveChangesAsync();
        Snackbar.Add($"Option '{option.Label}' deleted.", Severity.Info);
        await LoadAsync();
    }

    // ───────────────────────────────────────────────────────────────────
    // SUBJECT MODIFIER TEMPLATES
    // ───────────────────────────────────────────────────────────────────

    private List<SubjectModifierTemplate> _modifierTemplates = new();
    private bool _showAddModifierForm;
    private string _newModifierName = "";
    private string _newModifierOptionInput = "";
    private List<string> _newModifierOptions = new();

    private async Task LoadModifierTemplatesAsync()
    {
        _modifierTemplates = await Db.SubjectModifierTemplates
            .OrderBy(t => t.IsSystem ? 0 : 1)
            .ThenBy(t => t.Name)
            .ToListAsync();
    }

    private void AddModifierOption()
    {
        var opt = _newModifierOptionInput.Trim();
        if (string.IsNullOrWhiteSpace(opt)) return;
        if (!_newModifierOptions.Contains(opt))
            _newModifierOptions.Add(opt);
        _newModifierOptionInput = "";
    }

    private void HandleModifierOptionKeyUp(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter") AddModifierOption();
    }

    private async Task SaveModifierTemplateAsync()
    {
        if (string.IsNullOrWhiteSpace(_newModifierName) || _newModifierOptions.Count == 0) return;

        var json = System.Text.Json.JsonSerializer.Serialize(_newModifierOptions);
        Db.SubjectModifierTemplates.Add(new SubjectModifierTemplate
        {
            Name        = _newModifierName.Trim(),
            OptionsJson = json,
            IsSystem    = false,
            CreatedAt   = DateTimeOffset.UtcNow
        });
        await Db.SaveChangesAsync();

        _newModifierName = "";
        _newModifierOptions = new();
        _newModifierOptionInput = "";
        _showAddModifierForm = false;
        Snackbar.Add("Modifier template saved.", Severity.Success);
        await LoadModifierTemplatesAsync();
    }

    private async Task DeleteModifierTemplateAsync(SubjectModifierTemplate tmpl)
    {
        if (tmpl.IsSystem)
        {
            Snackbar.Add("System templates cannot be deleted.", Severity.Warning);
            return;
        }
        Db.SubjectModifierTemplates.Remove(tmpl);
        await Db.SaveChangesAsync();
        Snackbar.Add($"'{tmpl.Name}' deleted.", Severity.Info);
        await LoadModifierTemplatesAsync();
    }
}
