@page "/curriculum"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@inject SchoolDbContext Db
@inject IDbContextFactory<SchoolDbContext> DbFactory
@inject ISnackbar Snackbar
@inject IJSRuntime JS

<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">Curriculum Templates</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add"
               OnClick="OpenAddTemplate">
        New Template
    </MudButton>
    <MudTooltip Text="Download blank JSON format to use with Claude or ChatGPT">
        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Code"
                   OnClick="DownloadBlankSchemaAsync">
            JSON Format
        </MudButton>
    </MudTooltip>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Define curriculum templates with grades, subjects, strands, and sub-strands. Templates are assigned to school years.
</MudText>

@if (_templates.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No curriculum templates yet. Create one to get started.
    </MudAlert>
}
else
{
    <MudGrid>
        <!-- LEFT: Tree -->
        <MudItem xs="12" md="4" lg="3">
            @foreach (var tmpl in _templates)
            {
                <MudCard Class="mb-3" Elevation="1"
                         Style="@(_selectedTemplateId == tmpl.Id ? "border:2px solid var(--mud-palette-primary);" : "")">
                    <MudCardHeader Style="cursor:pointer; padding-bottom:4px;"
                                   @onclick="@(() => SelectTemplate(tmpl))">
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks"
                                         Color="@(_selectedTemplateId == tmpl.Id ? Color.Primary : Color.Default)"
                                         Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1" Style="font-weight:600;">@tmpl.Name</MudText>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(tmpl.Description))
                            {
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                    @tmpl.Description
                                </MudText>
                            }
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <div @onclick:stopPropagation="true" class="d-flex">
                                <MudTooltip Text="Re-import Excel (replaces all curriculum data)">
                                    <MudIconButton Icon="@Icons.Material.Filled.UploadFile" Size="Size.Small"
                                                   Color="Color.Warning"
                                                   OnClick="@(() => OpenReimportDialog(tmpl))" />
                                </MudTooltip>
                                <MudTooltip Text="Export as JSON">
                                    <MudIconButton Icon="@Icons.Material.Filled.Download" Size="Size.Small"
                                                   Color="Color.Primary"
                                                   OnClick="@(() => ExportTemplateAsync(tmpl))" />
                                </MudTooltip>
                                <MudTooltip Text="Delete template">
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                   Color="Color.Error"
                                                   OnClick="@(() => ConfirmDeleteTemplate(tmpl))" />
                                </MudTooltip>
                            </div>
                        </CardHeaderActions>
                    </MudCardHeader>

                    @if (_selectedTemplateId == tmpl.Id)
                    {
                        <MudCardContent Style="padding-top:0; padding-bottom:8px;">
                            @foreach (var grade in tmpl.GradeTemplates.OrderBy(g => g.SortOrder))
                            {
                                <div class="d-flex align-center"
                                     style="padding:2px 0 2px 8px; cursor:pointer; border-radius:4px; @(_selectedGradeId == grade.Id ? "background:var(--mud-palette-action-default-hover);" : "")"
                                     @onclick="@(() => SelectGrade(grade))">
                                    <MudIcon Icon="@Icons.Material.Filled.ExpandMore"
                                             Size="Size.Small"
                                             Style="color:var(--mud-palette-text-secondary); font-size:16px;" />
                                    <MudText Typo="Typo.body2" Style="flex:1; padding-left:4px;">
                                        @grade.Grade?.Name
                                    </MudText>
                                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                        @grade.ClassTemplates.Count subj.
                                    </MudText>
                                </div>

                                @if (_selectedGradeId == grade.Id)
                                {
                                    @foreach (var subj in grade.ClassTemplates.OrderBy(s => s.SortOrder))
                                    {
                                        <div class="d-flex align-center"
                                             style="padding:2px 0 2px 24px; cursor:pointer; border-radius:4px; @(_selectedSubjectId == subj.Id ? "background:var(--mud-palette-action-default-hover);" : "")"
                                             @onclick="@(() => SelectSubject(subj))">
                                            <MudIcon Icon="@Icons.Material.Filled.Subject"
                                                     Size="Size.Small"
                                                     Style="color:var(--mud-palette-primary); font-size:14px;" />
                                            <MudText Typo="Typo.body2" Style="flex:1; padding-left:4px;">
                                                @subj.Name
                                            </MudText>
                                            @if (subj.GradedAtStrandLevel)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.AccountTree"
                                                         Size="Size.Small"
                                                         Title="Graded per strand"
                                                         Style="color:var(--mud-palette-info); font-size:14px;" />
                                            }
                                        </div>

                                        @if (_selectedSubjectId == subj.Id)
                                        {
                                            @foreach (var strand in subj.SubjectTemplates.OrderBy(s => s.SortOrder))
                                            {
                                                <div class="d-flex align-center"
                                                     style="padding:2px 0 2px 40px; cursor:pointer; border-radius:4px; @(_selectedStrandId == strand.Id ? "background:var(--mud-palette-action-default-hover);" : "")"
                                                     @onclick="@(() => SelectStrand(strand))">
                                                    <MudIcon Icon="@Icons.Material.Filled.LinearScale"
                                                             Size="Size.Small"
                                                             Style="color:var(--mud-palette-secondary); font-size:13px;" />
                                                    <MudText Typo="Typo.body2" Style="flex:1; padding-left:4px; font-size:0.8rem;">
                                                        @strand.Name
                                                    </MudText>
                                                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                                        @strand.SubStrands.Count sub
                                                    </MudText>
                                                </div>
                                            }
                                        }
                                    }
                                }
                            }

                            <MudButton Variant="Variant.Text" Color="Color.Primary" Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Add"
                                       Class="mt-2"
                                       OnClick="@(() => OpenAddGrade(tmpl))">
                                Add Grade
                            </MudButton>
                        </MudCardContent>
                    }
                </MudCard>
            }
        </MudItem>

        <!-- RIGHT: Detail Panel -->
        <MudItem xs="12" md="8" lg="9">
            @if (_selectedStrandId != null && SelectedStrand != null)
            {
                <MudCard Elevation="1" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.LinearScale" Color="Color.Secondary" />
                                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                    @SelectedStrand.Name
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Secondary" Variant="Variant.Outlined">Strand</MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                @BreadcrumbText
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Delete strand">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => ConfirmDeleteStrand(SelectedStrand))" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (SelectedStrand.SubStrands.Count > 0)
                        {
                            <MudTable Items="SelectedStrand.SubStrands.OrderBy(s => s.SortOrder)"
                                      Dense="true" Hover="true" Elevation="0" Class="mb-4"
                                      Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                                <HeaderContent>
                                    <MudTh Style="width:60px;">Order</MudTh>
                                    <MudTh>Name</MudTh>
                                    <MudTh>Code</MudTh>
                                    <MudTh>Guidance Text</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.SortOrder</MudTd>
                                    <MudTd><strong>@context.Name</strong></MudTd>
                                    <MudTd>@(context.Code ?? "—")</MudTd>
                                    <MudTd>
                                        @if (!string.IsNullOrWhiteSpace(context.Description))
                                        {
                                            <MudText Typo="Typo.caption"
                                                     Style="display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden;">
                                                @context.Description
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">—</MudText>
                                        }
                                    </MudTd>
                                    <MudTd Style="text-align:right;">
                                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                                       Color="Color.Default"
                                                       OnClick="@(() => OpenEditSubStrand(context))" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => DeleteSubStrandAsync(context))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                No sub-strands yet. Add one below to provide teacher guidance text.
                            </MudAlert>
                        }
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddSubStrand">
                            Add Sub-Strand
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
            else if (_selectedSubjectId != null && SelectedSubject != null)
            {
                <MudCard Elevation="1" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Subject" Color="Color.Primary" />
                                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                    @SelectedSubject.Name
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined">Subject</MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                @BreadcrumbText
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Delete subject">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => ConfirmDeleteSubject(SelectedSubject))" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        <div class="d-flex align-center gap-3 mb-4 pa-3"
                             style="border:1px solid var(--mud-palette-divider); border-radius:8px; background:var(--mud-palette-background-grey);">
                            <MudIcon Icon="@Icons.Material.Filled.Grading" Color="Color.Primary" />
                            <div style="flex:1;">
                                <MudText Typo="Typo.body2" Style="font-weight:600;">Grading Mode</MudText>
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                    @(SelectedSubject.GradedAtStrandLevel
                                        ? "Teachers assign a grade to each strand individually"
                                        : "Teachers assign a single grade for the whole subject")
                                </MudText>
                            </div>
                            <MudSwitch T="bool"
                                       Value="SelectedSubject.GradedAtStrandLevel"
                                       ValueChanged="@((v) => ToggleGradingModeAsync(SelectedSubject, v))"
                                       Label="@(SelectedSubject.GradedAtStrandLevel ? "Per Strand" : "Whole Subject")"
                                       Color="Color.Primary" />
                        </div>

                        <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary);" Class="mb-2">Strands</MudText>

                        @if (SelectedSubject.SubjectTemplates.Count > 0)
                        {
                            <MudTable Items="SelectedSubject.SubjectTemplates.OrderBy(s => s.SortOrder)"
                                      Dense="true" Hover="true" Elevation="0" Class="mb-4"
                                      Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                                <HeaderContent>
                                    <MudTh Style="width:60px;">Order</MudTh>
                                    <MudTh>Strand Name</MudTh>
                                    <MudTh>Code</MudTh>
                                    <MudTh Style="width:80px;">Sub-Strands</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.SortOrder</MudTd>
                                    <MudTd>
                                        <span style="cursor:pointer; color:var(--mud-palette-primary);"
                                              @onclick="@(() => SelectStrand(context))">
                                            @context.Name
                                        </span>
                                    </MudTd>
                                    <MudTd>@(context.Code ?? "—")</MudTd>
                                    <MudTd>@context.SubStrands.Count</MudTd>
                                    <MudTd Style="text-align:right;">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => ConfirmDeleteStrand(context))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                No strands defined yet.
                            </MudAlert>
                        }

                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddStrand">
                            Add Strand
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
            else if (_selectedGradeId != null && SelectedGrade != null)
            {
                <MudCard Elevation="1" Class="mb-4">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.Class" Color="Color.Primary" />
                                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                    @SelectedGrade.Grade?.Name
                                </MudText>
                                <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Grade</MudChip>
                            </div>
                            <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                @BreadcrumbText
                            </MudText>
                        </CardHeaderContent>
                        <CardHeaderActions>
                            <MudTooltip Text="Delete grade from template">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => ConfirmDeleteGrade(SelectedGrade))" />
                            </MudTooltip>
                        </CardHeaderActions>
                    </MudCardHeader>
                    <MudCardContent>
                        @if (SelectedGrade.ClassTemplates.Count > 0)
                        {
                            <MudTable Items="SelectedGrade.ClassTemplates.OrderBy(s => s.SortOrder)"
                                      Dense="true" Hover="true" Elevation="0" Class="mb-4"
                                      Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                                <HeaderContent>
                                    <MudTh Style="width:60px;">Order</MudTh>
                                    <MudTh>Subject Name</MudTh>
                                    <MudTh>Code</MudTh>
                                    <MudTh>Grading Mode</MudTh>
                                    <MudTh Style="width:80px;">Strands</MudTh>
                                    <MudTh></MudTh>
                                </HeaderContent>
                                <RowTemplate>
                                    <MudTd>@context.SortOrder</MudTd>
                                    <MudTd>
                                        <span style="cursor:pointer; color:var(--mud-palette-primary);"
                                              @onclick="@(() => SelectSubject(context))">
                                            @context.Name
                                        </span>
                                    </MudTd>
                                    <MudTd>@(context.Code ?? "—")</MudTd>
                                    <MudTd>
                                        @if (context.GradedAtStrandLevel)
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Info" Variant="Variant.Filled">Per Strand</MudChip>
                                        }
                                        else
                                        {
                                            <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined">Whole Subject</MudChip>
                                        }
                                    </MudTd>
                                    <MudTd>@context.SubjectTemplates.Count</MudTd>
                                    <MudTd Style="text-align:right;">
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                                       Color="Color.Error"
                                                       OnClick="@(() => ConfirmDeleteSubject(context))" />
                                    </MudTd>
                                </RowTemplate>
                            </MudTable>
                        }
                        else
                        {
                            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
                                No subjects defined for this grade yet.
                            </MudAlert>
                        }

                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="OpenAddSubject">
                            Add Subject
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            }
            else if (_selectedTemplateId != null && SelectedTemplate != null)
            {
                <MudCard Elevation="1">
                    <MudCardHeader>
                        <CardHeaderContent>
                            <div class="d-flex align-center gap-2">
                                <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Color="Color.Primary" />
                                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                                    @SelectedTemplate.Name
                                </MudText>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>
                    <MudCardContent>
                        <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
                            Select a grade in the tree to view and edit its subjects and strands.
                        </MudText>
                        <MudText Typo="Typo.body2">
                            <strong>@SelectedTemplate.GradeTemplates.Count</strong> grade(s),
                            <strong>@SelectedTemplate.GradeTemplates.Sum(g => g.ClassTemplates.Count)</strong> subject(s),
                            <strong>@SelectedTemplate.GradeTemplates.SelectMany(g => g.ClassTemplates).Sum(s => s.SubjectTemplates.Count)</strong> strand(s).
                        </MudText>
                    </MudCardContent>
                </MudCard>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Select a curriculum template from the left panel to view its contents.
                </MudAlert>
            }
        </MudItem>
    </MudGrid>
}

<!-- New Template Dialog -->
<MudDialog @bind-Visible="_addTemplateOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true })">
    <TitleContent><MudText Typo="Typo.h6">New Curriculum Template</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="_newTemplateName" Label="Template Name"
                      Placeholder="e.g. Ontario Curriculum 2027"
                      Variant="Variant.Outlined" Class="mb-3" />
        <MudTextField @bind-Value="_newTemplateDesc" Label="Description (optional)"
                      Placeholder="e.g. Based on Ontario Ministry curriculum"
                      Variant="Variant.Outlined" Lines="2" Class="mb-4" />

        <MudDivider Class="mb-3" />

        <MudTabs @bind-ActivePanelIndex="_templateCreateMode" Elevation="0" Rounded="false" PanelClass="pt-3">

            <MudTabPanel Text="Start Blank" Icon="@Icons.Material.Filled.NoteAdd">
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
                    Create an empty template and add grades, subjects, and strands manually.
                </MudText>
            </MudTabPanel>

            <MudTabPanel Text="Copy Existing" Icon="@Icons.Material.Filled.ContentCopy">
                @if (_templates.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No existing templates to copy from yet.</MudAlert>
                }
                else
                {
                    <MudSelect T="int?" @bind-Value="_copyFromTemplateId" Label="Copy from"
                               Variant="Variant.Outlined" AnchorOrigin="Origin.BottomCenter"
                               HelperText="All grades, subjects, strands, and sub-strands will be duplicated into the new template.">
                        @foreach (var t in _templates)
                        {
                            <MudSelectItem T="int?" Value="@((int?)t.Id)">
                                @t.Name@(!string.IsNullOrWhiteSpace(t.Description) ? $" — {t.Description}" : "")
                            </MudSelectItem>
                        }
                    </MudSelect>
                }
            </MudTabPanel>

            <MudTabPanel Text="Import Excel" Icon="@Icons.Material.Filled.TableChart">
                <MudText Typo="Typo.body2" Class="mb-3" Style="color:var(--mud-palette-text-secondary);">
                    Upload the <strong>Ontario_Full_Curriculum.xlsx</strong> (or any file in the same 10-column format). Each unique combination of Grade + Subject Group becomes a subject. Strands become sub-strands.
                </MudText>
                <MudText Typo="Typo.caption" Class="mb-3" Style="color:var(--mud-palette-text-secondary);">
                    Expected columns: Subject Group · Subject · Grade · Strand Code · Strand · Overall Code · Overall Expectation · Specific Code · Sub-topic · Specific Expectation
                </MudText>

                <InputFile id="xlsxFileInput" OnChange="HandleXlsxFileSelected" accept=".xlsx" style="display:none;" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile"
                           HtmlTag="label" for="xlsxFileInput">
                    Choose Excel File
                </MudButton>
                @if (!string.IsNullOrWhiteSpace(_xlsxFileName))
                {
                    <MudText Typo="Typo.caption" Class="ml-3" Style="color:var(--mud-palette-text-secondary);">@_xlsxFileName</MudText>
                }
                @if (_xlsxParsing)
                {
                    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
                    <MudText Typo="Typo.caption" Class="mt-1">Reading file...</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(_xlsxParseError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">@_xlsxParseError</MudAlert>
                }
                @if (_xlsxPreview != null)
                {
                    <MudCard Elevation="0" Class="mt-3" Style="border:1px solid var(--mud-palette-success); border-radius:8px;">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">Excel parsed successfully</MudText>
                            </div>
                            <MudText Typo="Typo.body2">
                                <strong>@_xlsxPreview.MatchedGrades</strong> grade(s) matched,
                                <strong>@_xlsxPreview.TotalSubjects</strong> subject group(s),
                                <strong>@_xlsxPreview.TotalStrands</strong> strand(s),
                                <strong>@_xlsxPreview.TotalSubStrands</strong> overall expectation(s)
                            </MudText>
                            @if (_xlsxPreview.SkippedGrades.Count > 0)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                                    Grades skipped (no DB match): @string.Join(", ", _xlsxPreview.SkippedGrades)
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                }
            </MudTabPanel>

            <MudTabPanel Text="Import JSON" Icon="@Icons.Material.Filled.UploadFile">
                <MudText Typo="Typo.body2" Class="mb-3" Style="color:var(--mud-palette-text-secondary);">
                    Upload a JSON file exported from the school board or generated by Claude. Grades are matched by name (e.g. "JK", "Grade 1").
                </MudText>
                <MudExpansionPanels Class="mb-3" Elevation="0">
                    <MudExpansionPanel Text="Expected JSON format" Dense="true">
                        <MudText Typo="Typo.caption" Style="font-family:monospace; white-space:pre-wrap; font-size:0.72rem; color:var(--mud-palette-text-secondary);">@JsonFormatHint</MudText>
                    </MudExpansionPanel>
                </MudExpansionPanels>

                <InputFile id="jsonFileInput" OnChange="HandleJsonFileSelected" accept=".json" style="display:none;" />
                <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.AttachFile"
                           HtmlTag="label" for="jsonFileInput">
                    Choose JSON File
                </MudButton>
                @if (!string.IsNullOrWhiteSpace(_jsonFileName))
                {
                    <MudText Typo="Typo.caption" Class="ml-3" Style="color:var(--mud-palette-text-secondary);">@_jsonFileName</MudText>
                }
                @if (!string.IsNullOrWhiteSpace(_jsonParseError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">@_jsonParseError</MudAlert>
                }
                @if (_jsonPreview != null)
                {
                    <MudCard Elevation="0" Class="mt-3" Style="border:1px solid var(--mud-palette-success); border-radius:8px;">
                        <MudCardContent>
                            <div class="d-flex align-center gap-2 mb-2">
                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                <MudText Typo="Typo.body2" Style="font-weight:600;">JSON parsed successfully</MudText>
                            </div>
                            <MudText Typo="Typo.body2">
                                <strong>@_jsonPreview.MatchedGrades</strong> grade(s) matched,
                                <strong>@_jsonPreview.TotalSubjects</strong> subject(s),
                                <strong>@_jsonPreview.TotalStrands</strong> strand(s),
                                <strong>@_jsonPreview.TotalSubStrands</strong> sub-strand(s)
                            </MudText>
                            @if (_jsonPreview.SkippedGrades.Count > 0)
                            {
                                <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                                    Skipped (no DB match): @string.Join(", ", _jsonPreview.SkippedGrades)
                                </MudAlert>
                            }
                        </MudCardContent>
                    </MudCard>
                }
            </MudTabPanel>

        </MudTabs>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _addTemplateOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!CanCreateTemplate)"
                   OnClick="SaveTemplateAsync">@TemplateCreateButtonLabel</MudButton>
    </DialogActions>
</MudDialog>

<!-- Add Grade Dialog -->
<MudDialog @bind-Visible="_addGradeOpen">
    <TitleContent><MudText Typo="Typo.h6">Add Grade to Template</MudText></TitleContent>
