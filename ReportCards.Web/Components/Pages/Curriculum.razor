    // ── Re-import Excel ────────────────────────────────────────────────
    private void OpenReimportDialog(CurriculumSchema tmpl)
    {
        _reimportTargetId   = tmpl.Id;
        _reimportTargetName = tmpl.Name;
        _reimportFileName   = null;
        _reimportParseError = null;
        _reimportParsing    = false;
        _reimportProgress   = 0;
        _reimportTotal      = 0;
        _reimportPreview    = null;
        _reimportPayload    = null;
        _reimportOpen       = true;
    }

    private async Task HandleReimportFileSelected(InputFileChangeEventArgs e)
    {
        _reimportParseError = null;
        _reimportPreview    = null;
        _reimportPayload    = null;
        _reimportFileName   = e.File.Name;
        _reimportParsing    = true;
        StateHasChanged();
        try
        {
            if (e.File.Size > 20 * 1024 * 1024) { _reimportParseError = "File too large (max 20 MB)."; return; }
            await using var stream = e.File.OpenReadStream(20 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            OfficeOpenXml.ExcelPackage.LicenseContext = OfficeOpenXml.LicenseContext.NonCommercial;
            using var pkg = new OfficeOpenXml.ExcelPackage(ms);
            var ws = pkg.Workbook.Worksheets[0];
            if (ws == null) { _reimportParseError = "No worksheet found."; return; }

            var headers = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            for (int col = 1; col <= ws.Dimension?.Columns; col++)
            {
                var h = ws.Cells[1, col].Text?.Trim();
                if (!string.IsNullOrEmpty(h)) headers[h] = col;
            }
            int ColOf(string n) => headers.TryGetValue(n, out var c) ? c : -1;
            int cSG = ColOf("Subject Group"), cSubj = ColOf("Subject"), cGr = ColOf("Grade");
            int cStC = ColOf("Strand Code"), cOvC = ColOf("Overall Code"), cOvT = ColOf("Overall Expectation");
            if (cSG < 0 || cSubj < 0 || cGr < 0) { _reimportParseError = $"Missing required columns. Found: {string.Join(", ", headers.Keys)}"; return; }
            string Cell(int row, int col) => col > 0 ? ws.Cells[row, col].Text?.Trim() ?? "" : "";

            var gradeMap = new Dictionary<string, JsonGradeImport>();
            int totalRows = ws.Dimension?.Rows ?? 1;
            for (int row = 2; row <= totalRows; row++)
            {
                var gradeName = Cell(row, cGr); var sgName = Cell(row, cSG); var subjName = Cell(row, cSubj);
                var stCode = Cell(row, cStC); var ovCode = Cell(row, cOvC); var ovText = Cell(row, cOvT);
                if (string.IsNullOrWhiteSpace(gradeName) || string.IsNullOrWhiteSpace(sgName)) continue;
                var dbGrades = gradeName.Equals("Kindergarten", StringComparison.OrdinalIgnoreCase) ? new[] { "JK", "SK" } : new[] { gradeName };
                foreach (var dbGrade in dbGrades)
                {
                    if (!gradeMap.TryGetValue(dbGrade, out var jg)) { jg = new JsonGradeImport { Name = dbGrade }; gradeMap[dbGrade] = jg; }
                    var js = jg.Subjects.FirstOrDefault(s => s.Name == sgName);
                    if (js == null) { js = new JsonSubjectImport { Name = sgName, Code = sgName.Length > 8 ? sgName[..8].ToUpper().Replace(" ", "_") : sgName.ToUpper().Replace(" ", "_") }; jg.Subjects.Add(js); }
                    var jr = js.Strands.FirstOrDefault(r => r.Name == subjName);
                    if (jr == null) { jr = new JsonStrandImport { Name = subjName, Code = stCode }; js.Strands.Add(jr); }
                    if (!string.IsNullOrWhiteSpace(ovCode) && !jr.SubStrands.Any(b => b.Name == ovCode))
                        jr.SubStrands.Add(new JsonSubStrandImport { Name = ovCode, Code = ovCode, Description = ovText });
                }
            }
            if (gradeMap.Count == 0) { _reimportParseError = "No data rows found."; return; }

            var gradeNameMap = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g);
            var preview = new JsonPreviewResult();
            foreach (var (gname, jg) in gradeMap)
            {
                if (!gradeNameMap.ContainsKey(gname.ToLowerInvariant())) { preview.SkippedGrades.Add(gname); continue; }
                preview.MatchedGrades++;
                preview.TotalSubjects   += jg.Subjects.Count;
                preview.TotalStrands    += jg.Subjects.Sum(s => s.Strands.Count);
                preview.TotalSubStrands += jg.Subjects.Sum(s => s.Strands.Sum(r => r.SubStrands.Count));
            }
            if (preview.MatchedGrades == 0) { _reimportParseError = "No grades matched DB."; return; }
            _reimportPreview = preview;
            _reimportPayload = new JsonCurriculumImport { Grades = gradeMap.Values.ToList() };
        }
        catch (Exception ex) { _reimportParseError = $"Error: {ex.Message}"; }
        finally { _reimportParsing = false; StateHasChanged(); }
    }

    private async Task ExecuteReimportAsync()
    {
        if (_reimportPayload == null || _reimportSaving) return;
        _reimportSaving = true;
        _reimportParseError = null;
        StateHasChanged();

        // Capture everything we need before going off-thread
        var targetId   = _reimportTargetId;
        var targetName = _reimportTargetName;
        var payload    = _reimportPayload;
        var allGrades  = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g.Id);

        _reimportProgress = 0;
        _reimportTotal = payload.Grades.Sum(g => g.Subjects.Count);

        Exception? bgException = null;
        try
        {
            await Task.Run(async () =>
            {
                await using var db = await DbFactory.CreateDbContextAsync();

                // Step 1: Raw SQL deletes in FK-safe order
                // 1a. StudentLearningItems has FKs to BOTH YearClassOfferings AND YearSubjectOfferings — delete via YearClassOfferings join
                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE sli FROM StudentLearningItems sli
                    INNER JOIN YearClassOfferings yco ON sli.YearClassOfferingId = yco.Id
                    INNER JOIN CurriculumClassTemplates cct ON yco.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                // 1b. YearSubjectOfferings
                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE yso FROM YearSubjectOfferings yso
                    INNER JOIN YearClassOfferings yco ON yso.YearClassOfferingId = yco.Id
                    INNER JOIN CurriculumClassTemplates cct ON yco.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                // 1c. YearClassOfferings
                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE yco FROM YearClassOfferings yco
                    INNER JOIN CurriculumClassTemplates cct ON yco.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                // 1d. ClassGroupSubjectConfigs references CurriculumClassTemplates
                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE cgsc FROM ClassGroupSubjectConfigs cgsc
                    INNER JOIN CurriculumClassTemplates cct ON cgsc.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                // Step 2: Delete curriculum structure explicitly (no cascade assumptions)
                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE css FROM CurriculumSubStrands css
                    INNER JOIN CurriculumSubjectTemplates cst ON css.CurriculumSubjectTemplateId = cst.Id
                    INNER JOIN CurriculumClassTemplates cct ON cst.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE cst FROM CurriculumSubjectTemplates cst
                    INNER JOIN CurriculumClassTemplates cct ON cst.CurriculumClassTemplateId = cct.Id
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                await db.Database.ExecuteSqlRawAsync(@"
                    DELETE cct FROM CurriculumClassTemplates cct
                    INNER JOIN CurriculumGradeTemplates cgt ON cct.CurriculumGradeTemplateId = cgt.Id
                    WHERE cgt.CurriculumSchemaId = {0}", targetId);

                await db.Database.ExecuteSqlRawAsync(
                    "DELETE FROM CurriculumGradeTemplates WHERE CurriculumSchemaId = {0}", targetId);

                // Step 3: Re-build — save per level to get FKs, batch sub-strands
                int gradeSort = 0;
                foreach (var jg in payload.Grades)
                {
                    if (!allGrades.TryGetValue((jg.Name ?? "").Trim().ToLowerInvariant(), out var gradeId)) continue;
                    gradeSort++;

                    var ng = new CurriculumGradeTemplate { CurriculumSchemaId = targetId, GradeId = gradeId, SortOrder = gradeSort };
                    db.CurriculumGradeTemplates.Add(ng);
                    await db.SaveChangesAsync();

                    int ss = 0;
                    foreach (var js in jg.Subjects)
                    {
                        ss++;
                        var ns = new CurriculumClassTemplate { CurriculumGradeTemplateId = ng.Id, Name = js.Name?.Trim() ?? "Unnamed", Code = js.Code?.Trim(), SortOrder = ss, GradedAtStrandLevel = false };
                        db.CurriculumClassTemplates.Add(ns);
                        await db.SaveChangesAsync();
                        _reimportProgress++;
                        await InvokeAsync(StateHasChanged);

                        int st = 0;
                        foreach (var jr in js.Strands)
                        {
                            st++;
                            var nr = new CurriculumSubjectTemplate { CurriculumClassTemplateId = ns.Id, Name = jr.Name?.Trim() ?? "Unnamed", Code = jr.Code?.Trim(), SortOrder = st };
                            db.CurriculumSubjectTemplates.Add(nr);
                            await db.SaveChangesAsync();

                            // Batch all sub-strands for this strand in one save
                            int sb = 0;
                            foreach (var jb in jr.SubStrands)
                            {
                                sb++;
                                db.CurriculumSubStrands.Add(new CurriculumSubStrand { CurriculumSubjectTemplateId = nr.Id, Name = jb.Name?.Trim() ?? "Unnamed", Code = jb.Code?.Trim(), SortOrder = sb, Description = jb.Description?.Trim() });
                            }
                            if (jr.SubStrands.Any()) await db.SaveChangesAsync();
                        }
                    }
                }
            });
        }
        catch (Exception ex)
        {
            bgException = ex;
        }

        // Back on the Blazor thread
        if (bgException != null)
        {
            var msg = $"{bgException.Message} — {bgException.InnerException?.Message}";
            _reimportParseError = $"Save failed: {msg}";
            Snackbar.Add($"Re-import failed: {msg}", Severity.Error);
        }
        else
        {
            _reimportOpen = false;
            _selectedGradeId = null; _selectedSubjectId = null; _selectedStrandId = null;
            Snackbar.Add($"'{targetName}' curriculum replaced successfully.", Severity.Success);
            await LoadAsync();
        }

        _reimportSaving = false;
        StateHasChanged();
    }

    // ── JSON Export ───────────────────────────────────────────────────
    private async Task ExportTemplateAsync(CurriculumSchema tmpl)
    {
        var export = new
        {
            name        = tmpl.Name,
            description = tmpl.Description,
            grades      = tmpl.GradeTemplates.OrderBy(g => g.SortOrder).Select(g => new
            {
                name     = g.Grade?.Name,
                subjects = g.ClassTemplates.OrderBy(s => s.SortOrder).Select(s => new
                {
                    name                = s.Name,
                    code                = s.Code,
                    gradedAtStrandLevel = s.GradedAtStrandLevel,
                    strands             = s.SubjectTemplates.OrderBy(r => r.SortOrder).Select(r => new
                    {
                        name       = r.Name,
                        code       = r.Code,
                        subStrands = r.SubStrands.OrderBy(b => b.SortOrder).Select(b => new
                        {
                            name        = b.Name,
                            code        = b.Code,
                            description = b.Description
                        })
                    })
                })
            })
        };
        var opts     = new System.Text.Json.JsonSerializerOptions { WriteIndented = true };
        var json     = System.Text.Json.JsonSerializer.Serialize(export, opts);
        var fileName = $"{tmpl.Name.Replace(" ", "_")}_curriculum.json";
        await DownloadFileAsync(fileName, json);
        Snackbar.Add($"'{tmpl.Name}' exported as JSON.", Severity.Success);
    }

