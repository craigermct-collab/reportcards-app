    // Sub-Strand
    private void OpenAddSubStrand()
    {
        _editingSubStrand = null;
        _newSubStrandName = "";
        _newSubStrandCode = "";
        _newSubStrandSort = (SelectedStrand?.SubStrands.Count ?? 0) + 1;
        _newSubStrandDesc = "";
        _addSubStrandOpen = true;
    }

    private void OpenEditSubStrand(CurriculumSubStrand ss)
    {
        _editingSubStrand = ss;
        _newSubStrandName = ss.Name;
        _newSubStrandCode = ss.Code ?? "";
        _newSubStrandSort = ss.SortOrder;
        _newSubStrandDesc = ss.Description ?? "";
        _addSubStrandOpen = true;
    }

    private async Task SaveSubStrandAsync()
    {
        if (string.IsNullOrWhiteSpace(_newSubStrandName)) return;

        if (_editingSubStrand != null)
        {
            _editingSubStrand.Name        = _newSubStrandName.Trim();
            _editingSubStrand.Code        = string.IsNullOrWhiteSpace(_newSubStrandCode) ? null : _newSubStrandCode.Trim();
            _editingSubStrand.SortOrder   = _newSubStrandSort;
            _editingSubStrand.Description = string.IsNullOrWhiteSpace(_newSubStrandDesc) ? null : _newSubStrandDesc.Trim();
        }
        else
        {
            if (SelectedStrand == null) return;
            Db.CurriculumSubStrands.Add(new CurriculumSubStrand
            {
                CurriculumSubjectTemplateId = SelectedStrand.Id,
                Name                        = _newSubStrandName.Trim(),
                Code                        = string.IsNullOrWhiteSpace(_newSubStrandCode) ? null : _newSubStrandCode.Trim(),
                SortOrder                   = _newSubStrandSort,
                Description                 = string.IsNullOrWhiteSpace(_newSubStrandDesc) ? null : _newSubStrandDesc.Trim()
            });
        }

        await Db.SaveChangesAsync();
        _addSubStrandOpen = false;
        Snackbar.Add(_editingSubStrand != null ? "Sub-strand updated." : $"Sub-strand '{_newSubStrandName}' added.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteSubStrandAsync(CurriculumSubStrand ss)
    {
        Db.CurriculumSubStrands.Remove(ss);
        await Db.SaveChangesAsync();
        Snackbar.Add($"'{ss.Name}' deleted.", Severity.Info);
        await LoadAsync();
    }

    private async Task ExecuteDeleteAsync()
    {
        _confirmDeleteOpen = false;
        if (_confirmDeleteAction != null)
            await _confirmDeleteAction();
        _confirmDeleteAction = null;
    }

    // ── JSON Export ───────────────────────────────────────────────────
    private async Task ExportTemplateAsync(CurriculumSchema tmpl)
    {
        var export = new
        {
            name        = tmpl.Name,
            description = tmpl.Description,
            grades      = tmpl.GradeTemplates.OrderBy(g => g.SortOrder).Select(g => new
            {
                name     = g.Grade?.Name,
                subjects = g.ClassTemplates.OrderBy(s => s.SortOrder).Select(s => new
                {
                    name                = s.Name,
                    code                = s.Code,
                    gradedAtStrandLevel = s.GradedAtStrandLevel,
                    strands             = s.SubjectTemplates.OrderBy(r => r.SortOrder).Select(r => new
                    {
                        name       = r.Name,
                        code       = r.Code,
                        subStrands = r.SubStrands.OrderBy(b => b.SortOrder).Select(b => new
                        {
                            name        = b.Name,
                            code        = b.Code,
                            description = b.Description
                        })
                    })
                })
            })
        };
        var opts     = new System.Text.Json.JsonSerializerOptions { WriteIndented = true };
        var json     = System.Text.Json.JsonSerializer.Serialize(export, opts);
        var fileName = $"{tmpl.Name.Replace(" ", "_")}_curriculum.json";
        await DownloadFileAsync(fileName, json);
        Snackbar.Add($"'{tmpl.Name}' exported as JSON.", Severity.Success);
    }

