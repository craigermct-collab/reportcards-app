<!-- Re-import Excel Dialog -->
<MudDialog @bind-Visible="_reimportOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.UploadFile" Class="mr-1" Style="color:var(--mud-palette-warning);" />
            Re-import Excel
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Class="mb-3">
            This will <strong>delete all grades, subjects, strands, and sub-strands</strong> for "@_reimportTargetName" and replace them with the new file. Any existing grade entries linked to this curriculum will be orphaned.
        </MudAlert>
        <InputFile id="reimportXlsxInput" OnChange="HandleReimportFileSelected" accept=".xlsx" style="display:none;" />
        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.AttachFile"
                   HtmlTag="label" for="reimportXlsxInput">
            Choose Excel File
        </MudButton>
        @if (!string.IsNullOrWhiteSpace(_reimportFileName))
        {
            <MudText Typo="Typo.caption" Class="ml-3" Style="color:var(--mud-palette-text-secondary);">@_reimportFileName</MudText>
        }
        @if (_reimportParsing)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" />
            <MudText Typo="Typo.caption" Class="mt-1">Reading file...</MudText>
        }
        @if (!string.IsNullOrWhiteSpace(_reimportParseError))
        {
            <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3">@_reimportParseError</MudAlert>
        }
        @if (_reimportPreview != null)
        {
            <MudCard Elevation="0" Class="mt-3" Style="border:1px solid var(--mud-palette-success); border-radius:8px;">
                <MudCardContent>
                    <div class="d-flex align-center gap-2 mb-2">
                        <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                        <MudText Typo="Typo.body2" Style="font-weight:600;">Ready to import</MudText>
                    </div>
                    <MudText Typo="Typo.body2">
                        <strong>@_reimportPreview.MatchedGrades</strong> grade(s),
                        <strong>@_reimportPreview.TotalSubjects</strong> subject(s),
                        <strong>@_reimportPreview.TotalStrands</strong> strand(s),
                        <strong>@_reimportPreview.TotalSubStrands</strong> expectation(s)
                    </MudText>
                    @if (_reimportPreview.SkippedGrades.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" Dense="true" Class="mt-2">
                            Skipped: @string.Join(", ", _reimportPreview.SkippedGrades)
                        </MudAlert>
                    }
                </MudCardContent>
            </MudCard>
        }
    </DialogContent>
    <DialogActions>
        @if (_reimportSaving && _reimportTotal > 0)
        {
            <MudText Typo="Typo.caption" Class="mr-3" Style="color:var(--mud-palette-text-secondary); align-self:center;">
                @_reimportProgress / @_reimportTotal subjects
            </MudText>
        }
        <MudButton OnClick="@(() => _reimportOpen = false)" Disabled="@_reimportSaving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Warning"
                   Disabled="@(_reimportPayload == null || _reimportParsing || _reimportSaving)"
                   OnClick="ExecuteReimportAsync">
            @if (_reimportSaving)
            {
                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                <span>Importing...</span>
            }
            else
            {
                <span>Replace & Re-import</span>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Confirm Delete Dialog -->
<MudDialog @bind-Visible="_confirmDeleteOpen">
    <TitleContent>
        <MudText Typo="Typo.h6" Style="color:var(--mud-palette-error);">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Class="mr-1" />
            Confirm Delete
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudText>@_confirmDeleteMessage</MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _confirmDeleteOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="ExecuteDeleteAsync">Delete</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private List<CurriculumSchema> _templates = new();
    private List<Grade>            _allGrades  = new();

    private int? _selectedTemplateId;
    private int? _selectedGradeId;
    private int? _selectedSubjectId;
    private int? _selectedStrandId;

    private CurriculumSchema?          SelectedTemplate => _templates.FirstOrDefault(t => t.Id == _selectedTemplateId);
    private CurriculumGradeTemplate?   SelectedGrade    => SelectedTemplate?.GradeTemplates.FirstOrDefault(g => g.Id == _selectedGradeId);
    private CurriculumClassTemplate?   SelectedSubject  => SelectedGrade?.ClassTemplates.FirstOrDefault(s => s.Id == _selectedSubjectId);
    private CurriculumSubjectTemplate? SelectedStrand   => SelectedSubject?.SubjectTemplates.FirstOrDefault(s => s.Id == _selectedStrandId);

    private string BreadcrumbText
    {
        get
        {
            var parts = new List<string>();
            if (SelectedTemplate != null) parts.Add(SelectedTemplate.Name);
            if (SelectedGrade    != null) parts.Add(SelectedGrade.Grade?.Name ?? "");
            if (SelectedSubject  != null) parts.Add(SelectedSubject.Name);
            if (SelectedStrand   != null) parts.Add(SelectedStrand.Name);
            return string.Join(" › ", parts);
        }
    }

    private List<Grade> AvailableGrades
    {
        get
        {
            if (SelectedTemplate == null) return _allGrades;
            var usedIds = SelectedTemplate.GradeTemplates.Select(g => g.GradeId).ToHashSet();
            return _allGrades.Where(g => !usedIds.Contains(g.Id)).ToList();
        }
    }

    // ── JSON import DTOs ──────────────────────────────────────────────
    private class JsonCurriculumImport
    {
        [System.Text.Json.Serialization.JsonPropertyName("name")]        public string? Name        { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("description")] public string? Description { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("grades")]      public List<JsonGradeImport> Grades { get; set; } = new();
    }
    private class JsonGradeImport
    {
        [System.Text.Json.Serialization.JsonPropertyName("name")]     public string? Name     { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("subjects")] public List<JsonSubjectImport> Subjects { get; set; } = new();
    }
    private class JsonSubjectImport
    {
        [System.Text.Json.Serialization.JsonPropertyName("name")]               public string? Name               { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("code")]               public string? Code               { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("gradedAtStrandLevel")] public bool   GradedAtStrandLevel { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("strands")]            public List<JsonStrandImport> Strands { get; set; } = new();
    }
    private class JsonStrandImport
    {
        [System.Text.Json.Serialization.JsonPropertyName("name")]       public string? Name       { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("code")]       public string? Code       { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("subStrands")] public List<JsonSubStrandImport> SubStrands { get; set; } = new();
    }
    private class JsonSubStrandImport
    {
        [System.Text.Json.Serialization.JsonPropertyName("name")]        public string? Name        { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("code")]        public string? Code        { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("description")] public string? Description { get; set; }
    }
    private class JsonPreviewResult
    {
        public int          MatchedGrades   { get; set; }
        public int          TotalSubjects   { get; set; }
        public int          TotalStrands    { get; set; }
        public int          TotalSubStrands { get; set; }
        public List<string> SkippedGrades   { get; set; } = new();
    }
    private const string JsonFormatHint = @"{
  ""name"": ""Ontario Curriculum 2026"",
  ""description"": ""Optional description"",
  ""grades"": [
    {
      ""name"": ""Grade 1"",
      ""subjects"": [
        {
          ""name"": ""Mathematics"",
          ""code"": ""MATH"",
          ""gradedAtStrandLevel"": true,
          ""strands"": [
            {
              ""name"": ""Number Sense"",
              ""code"": ""NUM"",
              ""subStrands"": [
                {
                  ""name"": ""Counting and Quantity"",
                  ""code"": ""CQ"",
                  ""description"": ""Teacher guidance text""
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}";
    // ── Dialog state — New Template ───────────────────────────────────
    private bool   _addTemplateOpen;
    private string _newTemplateName    = "";
    private string _newTemplateDesc    = "";
    private int    _templateCreateMode = 0; // 0=blank 1=copy 2=json
    private int?   _copyFromTemplateId;
    private string?            _jsonFileName;
    private string?            _jsonParseError;
    private JsonPreviewResult? _jsonPreview;
    private JsonCurriculumImport? _jsonPayload;

    // Excel import state
    private string?            _xlsxFileName;
    private string?            _xlsxParseError;
    private bool               _xlsxParsing;
    private JsonPreviewResult? _xlsxPreview;
    private JsonCurriculumImport? _xlsxPayload; // reuse same DTO after parsing Excel → same structure

    private bool CanCreateTemplate => !string.IsNullOrWhiteSpace(_newTemplateName) && _templateCreateMode switch
    {
        1 => _copyFromTemplateId != null,
        2 => _xlsxPayload != null,
        3 => _jsonPayload != null,
        _ => true
    };
    private string TemplateCreateButtonLabel => _templateCreateMode switch
    {
        1 => "Copy & Create",
        2 => "Import & Create",
        3 => "Import & Create",
        _ => "Create"
    };

    // Dialog state — Grade
    private bool _addGradeOpen;
    private int? _newGradeId;
    private int  _addGradeForTemplateId;

    // Dialog state — Subject
    private bool   _addSubjectOpen;
    private string _newSubjectName           = "";
    private string _newSubjectCode           = "";
    private int    _newSubjectSort           = 1;
    private bool   _newSubjectGradedAtStrand;

    // Dialog state — Strand
    private bool   _addStrandOpen;
    private string _newStrandName = "";
    private string _newStrandCode = "";
    private int    _newStrandSort = 1;

    // Dialog state — Sub-Strand
    private bool                 _addSubStrandOpen;
    private CurriculumSubStrand? _editingSubStrand;
    private string _newSubStrandName = "";
    private string _newSubStrandCode = "";
    private int    _newSubStrandSort = 1;
    private string _newSubStrandDesc = "";

    // Dialog state — Re-import Excel
    private bool                  _reimportOpen;
    private int                   _reimportTargetId;
    private string                _reimportTargetName = "";
    private string?               _reimportFileName;
    private string?               _reimportParseError;
    private bool                  _reimportParsing;
    private bool                  _reimportSaving;
    private int                   _reimportProgress;
    private int                   _reimportTotal;
    private JsonPreviewResult?    _reimportPreview;
    private JsonCurriculumImport? _reimportPayload;

    // Dialog state — Confirm Delete
    private bool        _confirmDeleteOpen;
    private string      _confirmDeleteMessage = "";
    private Func<Task>? _confirmDeleteAction;

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _templates = await Db.CurriculumSchemas
            .Include(s => s.GradeTemplates)
                .ThenInclude(g => g.Grade)
                    .ThenInclude(g => g.ClassGroupType)
            .Include(s => s.GradeTemplates)
                .ThenInclude(g => g.ClassTemplates)
                    .ThenInclude(c => c.SubjectTemplates)
                        .ThenInclude(st => st.SubStrands)
            .OrderBy(s => s.Name)
            .ToListAsync();

        _allGrades = await Db.Grades
            .Include(g => g.ClassGroupType)
            .OrderBy(g => g.ClassGroupType!.SortOrder)
            .ThenBy(g => g.SortOrder)
            .ToListAsync();
    }

    private void SelectTemplate(CurriculumSchema t)
    {
        _selectedTemplateId = t.Id;
        _selectedGradeId    = null;
        _selectedSubjectId  = null;
        _selectedStrandId   = null;
    }

    private void SelectGrade(CurriculumGradeTemplate g)
    {
        _selectedGradeId   = g.Id;
        _selectedSubjectId = null;
        _selectedStrandId  = null;
    }

    private void SelectSubject(CurriculumClassTemplate s)
    {
        _selectedSubjectId = s.Id;
        _selectedStrandId  = null;
    }

    private void SelectStrand(CurriculumSubjectTemplate s)
    {
        _selectedStrandId = s.Id;
    }

    // Template
    private void OpenAddTemplate()
    {
        _newTemplateName    = "";
        _newTemplateDesc    = "";
        _templateCreateMode = 0;
        _copyFromTemplateId = null;
        _jsonFileName       = null;
        _jsonParseError     = null;
        _jsonPreview        = null;
        _jsonPayload        = null;
        _xlsxFileName       = null;
        _xlsxParseError     = null;
        _xlsxParsing        = false;
        _xlsxPreview        = null;
        _xlsxPayload        = null;
        _addTemplateOpen    = true;
    }

    private async Task HandleJsonFileSelected(InputFileChangeEventArgs e)
    {
        _jsonParseError = null;
        _jsonPreview    = null;
        _jsonPayload    = null;
        _jsonFileName   = e.File.Name;
        try
        {
            if (e.File.Size > 5 * 1024 * 1024) { _jsonParseError = "File too large (max 5 MB)."; return; }
            await using var stream = e.File.OpenReadStream(5 * 1024 * 1024);
            var opts   = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            var parsed = await System.Text.Json.JsonSerializer.DeserializeAsync<JsonCurriculumImport>(stream, opts);
            if (parsed == null || parsed.Grades.Count == 0)
            { _jsonParseError = "Could not parse file or it contains no grades. Check the expected format."; return; }

            var gradeMap = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g);
            var preview  = new JsonPreviewResult();
            foreach (var jg in parsed.Grades)
            {
                if (!gradeMap.ContainsKey((jg.Name ?? "").Trim().ToLowerInvariant()))
                { preview.SkippedGrades.Add(jg.Name ?? "(unnamed)"); continue; }
                preview.MatchedGrades++;
                preview.TotalSubjects   += jg.Subjects.Count;
                preview.TotalStrands    += jg.Subjects.Sum(s => s.Strands.Count);
                preview.TotalSubStrands += jg.Subjects.Sum(s => s.Strands.Sum(r => r.SubStrands.Count));
            }
            if (preview.MatchedGrades == 0)
            {
                _jsonParseError = $"No grades matched. In file: {string.Join(", ", parsed.Grades.Select(g => g.Name))}. In DB: {string.Join(", ", _allGrades.Select(g => g.Name))}."; return;
            }
            _jsonPreview = preview;
            _jsonPayload = parsed;
            if (string.IsNullOrWhiteSpace(_newTemplateName) && !string.IsNullOrWhiteSpace(parsed.Name)) _newTemplateName = parsed.Name;
            if (string.IsNullOrWhiteSpace(_newTemplateDesc)  && !string.IsNullOrWhiteSpace(parsed.Description)) _newTemplateDesc = parsed.Description;
        }
        catch (System.Text.Json.JsonException ex) { _jsonParseError = $"Invalid JSON: {ex.Message}"; }
        catch (Exception ex)                       { _jsonParseError = $"Error reading file: {ex.Message}"; }
    }

    private async Task HandleXlsxFileSelected(InputFileChangeEventArgs e)
    {
        _xlsxParseError = null;
        _xlsxPreview    = null;
        _xlsxPayload    = null;
        _xlsxFileName   = e.File.Name;
        _xlsxParsing    = true;
        StateHasChanged();
        try
        {
            if (e.File.Size > 20 * 1024 * 1024) { _xlsxParseError = "File too large (max 20 MB)."; return; }

            await using var stream = e.File.OpenReadStream(20 * 1024 * 1024);
            using var ms = new System.IO.MemoryStream();
            await stream.CopyToAsync(ms);
            ms.Position = 0;

            OfficeOpenXml.ExcelPackage.LicenseContext = OfficeOpenXml.LicenseContext.NonCommercial;
            using var pkg = new OfficeOpenXml.ExcelPackage(ms);
            var ws = pkg.Workbook.Worksheets[0];
            if (ws == null) { _xlsxParseError = "No worksheet found in file."; return; }

            // Read header row to find column indices
            var headers = new Dictionary<string, int>(StringComparer.OrdinalIgnoreCase);
            for (int col = 1; col <= ws.Dimension?.Columns; col++)
            {
                var h = ws.Cells[1, col].Text?.Trim();
                if (!string.IsNullOrEmpty(h)) headers[h] = col;
            }

            int ColOf(string name) => headers.TryGetValue(name, out var c) ? c : -1;
            int cSG   = ColOf("Subject Group");
            int cSubj = ColOf("Subject");
            int cGr   = ColOf("Grade");
            int cStC  = ColOf("Strand Code");
            int cOvC  = ColOf("Overall Code");
            int cOvT  = ColOf("Overall Expectation");

            if (cSG < 0 || cSubj < 0 || cGr < 0)
            {
                _xlsxParseError = $"Missing required columns. Found: {string.Join(", ", headers.Keys)}";
                return;
            }

            string Cell(int row, int col) => col > 0 ? ws.Cells[row, col].Text?.Trim() ?? "" : "";

            // Build same JsonCurriculumImport DTO from the rows
            // Hierarchy: Grade → SubjectGroup (= ClassTemplate) → Subject (= SubjectTemplate) → Overall (= SubStrand)
            var gradeMap = new Dictionary<string, JsonGradeImport>();

            int totalRows = ws.Dimension?.Rows ?? 1;
            for (int row = 2; row <= totalRows; row++)
            {
                var gradeName = Cell(row, cGr);
                var sgName    = Cell(row, cSG);
                var subjName  = Cell(row, cSubj);
                var stCode    = Cell(row, cStC);
                var ovCode    = Cell(row, cOvC);
                var ovText    = Cell(row, cOvT);

                if (string.IsNullOrWhiteSpace(gradeName) || string.IsNullOrWhiteSpace(sgName)) continue;

                // Map "Kindergarten" grade to both JK and SK
                var dbGrades = gradeName.Equals("Kindergarten", StringComparison.OrdinalIgnoreCase)
                    ? new[] { "JK", "SK" }
                    : new[] { gradeName };

                foreach (var dbGrade in dbGrades)
                {
                    if (!gradeMap.TryGetValue(dbGrade, out var jg))
                    {
                        jg = new JsonGradeImport { Name = dbGrade };
                        gradeMap[dbGrade] = jg;
                    }

                    // Subject Group = ClassTemplate
                    var js = jg.Subjects.FirstOrDefault(s => s.Name == sgName);
                    if (js == null)
                    {
                        js = new JsonSubjectImport { Name = sgName, Code = sgName.Length > 8 ? sgName[..8].ToUpper().Replace(" ", "_") : sgName.ToUpper().Replace(" ", "_") };
                        jg.Subjects.Add(js);
                    }

                    // Subject (strand) = SubjectTemplate — group by Subject column
                    var jr = js.Strands.FirstOrDefault(r => r.Name == subjName);
                    if (jr == null)
                    {
                        jr = new JsonStrandImport { Name = subjName, Code = stCode };
                        js.Strands.Add(jr);
                    }

                    // Overall Expectation = SubStrand
                    if (!string.IsNullOrWhiteSpace(ovCode) && !jr.SubStrands.Any(b => b.Name == ovCode))
                    {
                        jr.SubStrands.Add(new JsonSubStrandImport { Name = ovCode, Code = ovCode, Description = ovText });
                    }
                }
            }

            if (gradeMap.Count == 0) { _xlsxParseError = "No data rows found in file."; return; }

            // Build preview
            var gradeNameMap = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g);
            var preview = new JsonPreviewResult();
            foreach (var (gname, jg) in gradeMap)
            {
                if (!gradeNameMap.ContainsKey(gname.ToLowerInvariant()))
                { preview.SkippedGrades.Add(gname); continue; }
                preview.MatchedGrades++;
                preview.TotalSubjects   += jg.Subjects.Count;
                preview.TotalStrands    += jg.Subjects.Sum(s => s.Strands.Count);
                preview.TotalSubStrands += jg.Subjects.Sum(s => s.Strands.Sum(r => r.SubStrands.Count));
            }

            if (preview.MatchedGrades == 0)
            {
                _xlsxParseError = $"No grades matched DB. In file: {string.Join(", ", gradeMap.Keys)}. In DB: {string.Join(", ", _allGrades.Select(g => g.Name))}";
                return;
            }

            _xlsxPayload = new JsonCurriculumImport
            {
                Name   = _newTemplateName,
                Grades = gradeMap.Values.ToList()
            };
            _xlsxPreview = preview;

            if (string.IsNullOrWhiteSpace(_newTemplateName))
                _newTemplateName = System.IO.Path.GetFileNameWithoutExtension(e.File.Name).Replace("_", " ");
        }
        catch (Exception ex) { _xlsxParseError = $"Error reading file: {ex.Message}"; }
        finally { _xlsxParsing = false; StateHasChanged(); }
    }

    private async Task SaveTemplateAsync()
    {
        var name = _newTemplateName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        try
        {
        var schema = new CurriculumSchema
        {
            Name        = name,
            Description = string.IsNullOrWhiteSpace(_newTemplateDesc) ? null : _newTemplateDesc.Trim(),
            Version     = "1.0",
            UploadedAt  = DateTimeOffset.UtcNow
        };
        Db.CurriculumSchemas.Add(schema);
        await Db.SaveChangesAsync();

        // Copy mode
        if (_templateCreateMode == 1 && _copyFromTemplateId != null)
        {
            var source = await Db.CurriculumSchemas
                .Include(s => s.GradeTemplates).ThenInclude(g => g.ClassTemplates)
                    .ThenInclude(c => c.SubjectTemplates).ThenInclude(st => st.SubStrands)
                .FirstOrDefaultAsync(s => s.Id == _copyFromTemplateId);
            if (source != null) await CopyGradesAsync(schema.Id, source.GradeTemplates);
        }

        // Excel import mode
        else if (_templateCreateMode == 2 && _xlsxPayload != null)
        {
            var gradeMap  = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g.Id);
            int gradeSort = 0;
            foreach (var jg in _xlsxPayload.Grades)
            {
                if (!gradeMap.TryGetValue((jg.Name ?? "").Trim().ToLowerInvariant(), out var gradeId)) continue;
                gradeSort++;
                var ng = new CurriculumGradeTemplate { CurriculumSchemaId = schema.Id, GradeId = gradeId, SortOrder = gradeSort };
                Db.CurriculumGradeTemplates.Add(ng); await Db.SaveChangesAsync();
                int ss = 0;
                foreach (var js in jg.Subjects)
                {
                    ss++;
                    var ns = new CurriculumClassTemplate { CurriculumGradeTemplateId = ng.Id, Name = js.Name?.Trim() ?? "Unnamed", Code = js.Code?.Trim(), SortOrder = ss, GradedAtStrandLevel = false };
                    Db.CurriculumClassTemplates.Add(ns); await Db.SaveChangesAsync();
                    int st = 0;
                    foreach (var jr in js.Strands)
                    {
                        st++;
                        var nr = new CurriculumSubjectTemplate { CurriculumClassTemplateId = ns.Id, Name = jr.Name?.Trim() ?? "Unnamed", Code = jr.Code?.Trim(), SortOrder = st };
                        Db.CurriculumSubjectTemplates.Add(nr); await Db.SaveChangesAsync();
                        int sb = 0;
                        foreach (var jb in jr.SubStrands)
                        {
                            sb++;
                            Db.CurriculumSubStrands.Add(new CurriculumSubStrand { CurriculumSubjectTemplateId = nr.Id, Name = jb.Name?.Trim() ?? "Unnamed", Code = jb.Code?.Trim(), SortOrder = sb, Description = jb.Description?.Trim() });
                        }
                        await Db.SaveChangesAsync();
                    }
                }
            }
        }

        // JSON import mode
        else if (_templateCreateMode == 3 && _jsonPayload != null)
        {
            var gradeMap  = _allGrades.ToDictionary(g => g.Name.ToLowerInvariant(), g => g.Id);
            int gradeSort = 0;
            foreach (var jg in _jsonPayload.Grades)
            {
                if (!gradeMap.TryGetValue((jg.Name ?? "").Trim().ToLowerInvariant(), out var gradeId)) continue;
                gradeSort++;
                var ng = new CurriculumGradeTemplate { CurriculumSchemaId = schema.Id, GradeId = gradeId, SortOrder = gradeSort };
                Db.CurriculumGradeTemplates.Add(ng); await Db.SaveChangesAsync();
                int ss = 0;
                foreach (var js in jg.Subjects)
                {
                    ss++;
                    var ns = new CurriculumClassTemplate { CurriculumGradeTemplateId = ng.Id, Name = js.Name?.Trim() ?? "Unnamed", Code = js.Code?.Trim(), SortOrder = ss, GradedAtStrandLevel = js.GradedAtStrandLevel };
                    Db.CurriculumClassTemplates.Add(ns); await Db.SaveChangesAsync();
                    int st = 0;
                    foreach (var jr in js.Strands)
                    {
                        st++;
                        var nr = new CurriculumSubjectTemplate { CurriculumClassTemplateId = ns.Id, Name = jr.Name?.Trim() ?? "Unnamed", Code = jr.Code?.Trim(), SortOrder = st };
                        Db.CurriculumSubjectTemplates.Add(nr); await Db.SaveChangesAsync();
                        int sb = 0;
                        foreach (var jb in jr.SubStrands)
                        {
                            sb++;
                            Db.CurriculumSubStrands.Add(new CurriculumSubStrand { CurriculumSubjectTemplateId = nr.Id, Name = jb.Name?.Trim() ?? "Unnamed", Code = jb.Code?.Trim(), SortOrder = sb, Description = jb.Description?.Trim() });
                        }
                        await Db.SaveChangesAsync();
                    }
                }
            }
        }

        _addTemplateOpen = false;
        Snackbar.Add(_templateCreateMode switch
        {
            1 => $"Template '{name}' created as a copy. Make your modifications!",
            2 => $"Template '{name}' imported from Excel successfully.",
            3 => $"Template '{name}' imported from JSON successfully.",
            _ => $"Template '{name}' created."
        }, Severity.Success);
        await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error saving template: {ex.Message} — {ex.InnerException?.Message}", Severity.Error);
        }
    }

    private async Task CopyGradesAsync(int newSchemaId, IEnumerable<CurriculumGradeTemplate> sourceGrades)
    {
        foreach (var sg in sourceGrades.OrderBy(g => g.SortOrder))
        {
            var ng = new CurriculumGradeTemplate { CurriculumSchemaId = newSchemaId, GradeId = sg.GradeId, SortOrder = sg.SortOrder };
            Db.CurriculumGradeTemplates.Add(ng); await Db.SaveChangesAsync();
            foreach (var ss in sg.ClassTemplates.OrderBy(s => s.SortOrder))
            {
                var ns = new CurriculumClassTemplate { CurriculumGradeTemplateId = ng.Id, Name = ss.Name, Code = ss.Code, SortOrder = ss.SortOrder, GradedAtStrandLevel = ss.GradedAtStrandLevel };
                Db.CurriculumClassTemplates.Add(ns); await Db.SaveChangesAsync();
                foreach (var sr in ss.SubjectTemplates.OrderBy(s => s.SortOrder))
                {
                    var nr = new CurriculumSubjectTemplate { CurriculumClassTemplateId = ns.Id, Name = sr.Name, Code = sr.Code, SortOrder = sr.SortOrder };
                    Db.CurriculumSubjectTemplates.Add(nr); await Db.SaveChangesAsync();
                    foreach (var sb in sr.SubStrands.OrderBy(s => s.SortOrder))
                        Db.CurriculumSubStrands.Add(new CurriculumSubStrand { CurriculumSubjectTemplateId = nr.Id, Name = sb.Name, Code = sb.Code, SortOrder = sb.SortOrder, Description = sb.Description });
                    await Db.SaveChangesAsync();
                }
            }
        }
    }

