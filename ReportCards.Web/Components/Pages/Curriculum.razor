    private async Task DownloadFileAsync(string fileName, string content)
    {
        var b64 = Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(content));
        var js = $"(function(){{var a=document.createElement('a');a.href='data:application/json;base64,{b64}';a.download='{fileName}';document.body.appendChild(a);a.click();document.body.removeChild(a);}})();";
        await JS.InvokeVoidAsync("eval", js);
    }
