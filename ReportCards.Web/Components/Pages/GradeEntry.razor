@page "/grade-entry"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@using ReportCards.Web.Services
@inject SchoolDbContext Db
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider
@inject CommentTemplateService CommentSvc
@inject IDialogService DialogService
@inject AssistantContextService AssistantCtx

<PageTitle>Grade Entry</PageTitle>

<div class="d-flex align-center gap-3 mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Grading"
             Style="background:#1B4F72; color:white; padding:8px; border-radius:10px; font-size:24px;" />
    <div>
        <MudText Typo="Typo.h5" Style="font-family:'DM Serif Display',serif; line-height:1.1;">Grade Entry</MudText>
        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
            @if (_teacherName != null)
            {
                <span>Showing students for <strong>@_teacherName</strong>.</span>
            }
            else
            {
                <span>Select a term to begin.</span>
            }
        </MudText>
    </div>
</div>

<!-- ── TERM SELECTOR ─────────────────────────────────────────────── -->
<MudCard Elevation="1" Class="mb-5 mt-4">
    <MudCardContent Class="py-3">
        <MudGrid Spacing="3">
            <MudItem xs="12" sm="4">
                <MudSelect T="int?"
                           Label="Term"
                           Value="_selectedTermId"
                           ValueChanged="@(async (int? v) => await TermChanged(v))"
                           Variant="Variant.Outlined"
                           AnchorOrigin="Origin.BottomLeft"
                           Clearable="true"
                           Disabled="@_isLoadingTerms">
                    @foreach (var t in _terms)
                    {
                        <MudSelectItem T="int?" Value="@((int?)t.Id)">
                            @t.SchoolYear?.Name – @t.Name
                        </MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            @if (_selectedTermId != null && !_isLoadingStudents)
            {
                <MudItem xs="12" sm="8">
                    <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
                        @_enrollments.Count student(s) enrolled
                        @if (_expandedStudentId != null)
                        {
                            <span> · <strong>@(_studentStates.GetValueOrDefault(_expandedStudentId.Value)?.StudentName)</strong> selected</span>
                        }
                    </MudText>
                </MudItem>
            }
        </MudGrid>
    </MudCardContent>
</MudCard>

<!-- ── STUDENT LIST ───────────────────────────────────────────────── -->
@if (_isLoadingTerms || _isLoadingStudents)
{
    <div class="d-flex justify-center pa-8">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (_selectedTermId == null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Select a term above to see students.
    </MudAlert>
}
else if (!_enrollments.Any())
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No students enrolled in this term.
    </MudAlert>
}
else
{
    var gradeGroups = GradeGroups;
    @foreach (var gradeGroup in gradeGroups)
    {
        <div class="d-flex align-center gap-2 mb-2 mt-3" style="@(gradeGroup == gradeGroups.First() ? "margin-top:0!important;" : "")">
            <div style="height:1px; flex:1; background:var(--mud-palette-divider);"></div>
            <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary); padding:0 8px; font-size:11px; letter-spacing:0.08em;">
                @gradeGroup.Name
            </MudText>
            <div style="height:1px; flex:1; background:var(--mud-palette-divider);"></div>
        </div>

    @foreach (var enrollment in gradeGroup.Enrollments)
    {
        var state = _studentStates.GetValueOrDefault(enrollment.StudentId);
        var isExpanded = _expandedStudentId == enrollment.StudentId;
        var initials = GetInitials(enrollment.Student?.FirstName, enrollment.Student?.LastName);
        var isLoading = state?.IsLoading ?? false;
        var isSaving  = state?.IsSaving  ?? false;
        var isFullyGraded  = state?.IsFullyGraded ?? false;
        var hasAnyGrades   = state?.HasAnyGrades  ?? false;
        var isPeerReviewed = state?.IsPeerReviewed ?? false;

        <MudCard Elevation="@(isExpanded ? 3 : 1)"
                 Class="mb-3"
                 Style="@(isExpanded ? "border:2px solid var(--mud-palette-primary); border-radius:10px;" : "border-radius:10px; cursor:pointer;")">

            <!-- ── Peer review bar (above the clickable tile) ── -->
            <div class="d-flex align-center gap-2 px-3 pt-2"
                 style="border-bottom:1px solid var(--mud-palette-divider); padding-bottom:8px; margin-bottom:0;">
                @if (state?.IsSavingPeerReview == true)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Secondary" />
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">Saving…</MudText>
                }
                else
                {
                    <MudCheckBox T="bool"
                                 Checked="@isPeerReviewed"
                                 CheckedChanged="@(async (bool v) => await TogglePeerReviewAsync(enrollment.StudentId))"
                                 Size="Size.Small"
                                 Color="Color.Secondary"
                                 @onclick:stopPropagation="true" />
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); font-weight:500;">
                        Peer reviewed
                    </MudText>
                    @if (isPeerReviewed && state?.ReviewerInitials != null)
                    {
                        <MudTooltip Text="@($"Reviewed by {state.ReviewerName}")">
                            <MudAvatar Style="background:#7B4FBF; color:white; font-size:10px; font-weight:700; width:22px; height:22px; margin-left:4px;">
                                @state.ReviewerInitials
                            </MudAvatar>
                        </MudTooltip>
                    }
                }
            </div>

            <!-- ── Student header tile ── -->
            <div @onclick="@(() => ToggleStudentAsync(enrollment.StudentId))"
                 class="d-flex align-center gap-3 pa-3"
                 style="cursor:pointer; user-select:none;">

                <MudAvatar Style="background:#1B4F72; color:white; font-weight:700; font-size:14px; width:40px; height:40px; flex-shrink:0;">
                    @initials
                </MudAvatar>

                <div style="flex:1; min-width:0;">
                    <MudText Typo="Typo.subtitle1" Style="font-weight:600; line-height:1.2;">
                        @enrollment.Student?.LastName, @enrollment.Student?.FirstName
                    </MudText>
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                        @enrollment.Grade?.Name
                        @if (state?.Groups.Any() == true)
                        {
                            <span> · @state.GradedItems / @state.TotalItems graded</span>
                        }
                    </MudText>
                </div>

                <div class="d-flex align-center gap-2">
                    @if (isFullyGraded)
                    {
                        <MudTooltip Text="All fields graded">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Size="Size.Small" Style="color:#2E7D32;" />
                        </MudTooltip>
                    }
                    else if (hasAnyGrades)
                    {
                        <MudTooltip Text="@($"{state!.GradedItems} of {state.TotalItems} graded")">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle"
                                     Size="Size.Small" Style="color:#F9A825;" />
                        </MudTooltip>
                    }
                    @if (isPeerReviewed && state?.ReviewerInitials != null)
                    {
                        <MudTooltip Text="@($"Reviewed by {state.ReviewerName}")">
                            <MudAvatar Style="background:#7B4FBF; color:white; font-size:10px; font-weight:700; width:24px; height:24px;">
                                @state.ReviewerInitials
                            </MudAvatar>
                        </MudTooltip>
                    }
                    @if (isLoading)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" />
                    }
                    else
                    {
                        <MudIcon Icon="@(isExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                 Style="color:var(--mud-palette-text-secondary);" />
                    }
                </div>
            </div>

            <!-- ── Expanded grade entry ── -->
            <MudCollapse Expanded="@isExpanded">
                @if (isLoading)
                {
                    <div class="d-flex justify-center pa-6">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (state?.Groups.Any() == true)
                {
                    <MudDivider />
                    <div class="pa-4">

                        @* ── Learning Skills ──────────────────────────────────────── *@
                        <div class="d-flex align-center gap-2 mb-2">
                            <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Small" Style="color:#B7950B;" />
                            <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#1A2B3C;">Learning Skills and Work Habits</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                     Style="font-size:11px; height:20px;">E / G / S / N</MudChip>
                            @if (state.LearningSkills?.IsSaving == true)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="ml-1" />
                            }
                        </div>

                        <MudPaper Outlined="true" Class="pa-3 mb-4" Style="border-radius:8px;">
                            <div class="d-flex align-center gap-2 mb-2 px-1">
                                <div style="flex:1;"></div>
                                <MudText Typo="Typo.caption" Style="width:90px; text-align:center; font-weight:700; color:#6B7A8D;">TERM 1</MudText>
                                <MudText Typo="Typo.caption" Style="width:90px; text-align:center; font-weight:700; color:#6B7A8D;">TERM 2</MudText>
                            </div>
                            @{
                                var ls = state.LearningSkills!;
                                var skillRows = new[]
                                {
                                    (Label: "Responsibility",   T1: ls.Responsibility_T1,   T1Set: (Action<string?>)(v => ls.Responsibility_T1   = v), T2: ls.Responsibility_T2,   T2Set: (Action<string?>)(v => ls.Responsibility_T2   = v)),
                                    (Label: "Organization",    T1: ls.Organization_T1,    T1Set: (Action<string?>)(v => ls.Organization_T1    = v), T2: ls.Organization_T2,    T2Set: (Action<string?>)(v => ls.Organization_T2    = v)),
                                    (Label: "Independent Work",T1: ls.IndependentWork_T1, T1Set: (Action<string?>)(v => ls.IndependentWork_T1 = v), T2: ls.IndependentWork_T2, T2Set: (Action<string?>)(v => ls.IndependentWork_T2 = v)),
                                    (Label: "Collaboration",   T1: ls.Collaboration_T1,   T1Set: (Action<string?>)(v => ls.Collaboration_T1   = v), T2: ls.Collaboration_T2,   T2Set: (Action<string?>)(v => ls.Collaboration_T2   = v)),
                                    (Label: "Initiative",      T1: ls.Initiative_T1,      T1Set: (Action<string?>)(v => ls.Initiative_T1      = v), T2: ls.Initiative_T2,      T2Set: (Action<string?>)(v => ls.Initiative_T2      = v)),
                                    (Label: "Self-Regulation", T1: ls.SelfRegulation_T1,  T1Set: (Action<string?>)(v => ls.SelfRegulation_T1  = v), T2: ls.SelfRegulation_T2,  T2Set: (Action<string?>)(v => ls.SelfRegulation_T2  = v)),
                                };
                            }
                            @foreach (var skill in skillRows)
                            {
                                <div class="d-flex align-center gap-2 mb-1 px-1">
                                    <MudText Typo="Typo.body2" Style="flex:1; font-weight:500;">@skill.Label</MudText>
                                    <div style="width:90px;">
                                        <MudSelect T="string?" Value="@skill.T1"
                                                   ValueChanged="@((string? v) => { skill.T1Set(v); _ = SaveLearningSkillsAsync(enrollment, state); })"
                                                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                                                   Clearable="true" AnchorOrigin="Origin.BottomLeft"
                                                   @onclick:stopPropagation="true">
                                            @foreach (var opt in _egsnOptions)
                                            {
                                                <MudSelectItem T="string?" Value="@opt">@opt</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                    <div style="width:90px;">
                                        <MudSelect T="string?" Value="@skill.T2"
                                                   ValueChanged="@((string? v) => { skill.T2Set(v); _ = SaveLearningSkillsAsync(enrollment, state); })"
                                                   Variant="Variant.Outlined" Dense="true" Margin="Margin.Dense"
                                                   Clearable="true" AnchorOrigin="Origin.BottomLeft"
                                                   @onclick:stopPropagation="true">
                                            @foreach (var opt in _egsnOptions)
                                            {
                                                <MudSelectItem T="string?" Value="@opt">@opt</MudSelectItem>
                                            }
                                        </MudSelect>
                                    </div>
                                </div>
                            }
                            <MudDivider Class="my-2" />
                            <MudText Typo="Typo.caption" Style="font-weight:700; color:#6B7A8D; text-transform:uppercase; letter-spacing:0.06em;">Strengths / Next Steps</MudText>
                            <MudTextField T="string?" @bind-Value="ls.StrengthsNextSteps"
                                          Variant="Variant.Outlined" Margin="Margin.Dense"
                                          Lines="3" MaxLength="2000"
                                          Placeholder="Strengths and next steps for improvement…"
                                          Style="margin-top:4px;"
                                          @onblur="@(() => _ = SaveLearningSkillsAsync(enrollment, state))"
                                          @onclick:stopPropagation="true" />
                        </MudPaper>

                        @foreach (var subjectGroup in state.Groups)
                        {
                            <div class="d-flex align-center gap-2 mt-4 mb-1"
                                 style="@(state.Groups.First() == subjectGroup ? "margin-top:0!important;" : "")">
                                <MudIcon Icon="@Icons.Material.Filled.MenuBook" Size="Size.Small" Style="color:#1B4F72;" />
                                <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:#1A2B3C;">
                                    @subjectGroup.SubjectName
                                </MudText>
                                @if (!string.IsNullOrWhiteSpace(subjectGroup.SubjectCode))
                                {
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default"
                                             Style="font-size:11px; height:20px;">
                                        @subjectGroup.SubjectCode
                                    </MudChip>
                                }
                            </div>

                            @if (subjectGroup.ModifierOptions.Count > 0)
                            {
                                <div class="d-flex align-center flex-wrap gap-3 mb-2 px-1 py-1"
                                     style="background:rgba(123,79,191,0.05); border-radius:6px; border:1px solid rgba(123,79,191,0.15);">
                                    @if (subjectGroup.IsSavingModifiers)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Secondary" Class="ml-1" />
                                    }
                                    @foreach (var opt in subjectGroup.ModifierOptions)
                                    {
                                        var isChecked = subjectGroup.EnabledModifiers.Contains(opt);
                                        <MudCheckBox T="bool"
                                                     Value="@isChecked"
                                                     ValueChanged="@(async (bool v) => await ToggleModifierAsync(enrollment, subjectGroup, opt))"
                                                     Size="Size.Small"
                                                     Color="Color.Secondary"
                                                     Label="@opt"
                                                     @onclick:stopPropagation="true" />
                                    }
                                </div>
                            }

                            <MudDivider Class="mb-3" />

                            <div class="d-flex align-center gap-3 mb-2 px-2"
                                 style="font-family:'DM Sans',sans-serif; font-size:11px; font-weight:700;
                                        text-transform:uppercase; letter-spacing:0.06em; color:#6B7A8D;">
                                <div style="flex:1; min-width:0;">Strand / Subject</div>
                                <div style="width:160px; flex-shrink:0;">Grade</div>
                                <div style="flex:1.4; min-width:0;">Comment</div>
                                <div style="width:32px; flex-shrink:0;"></div>
                            </div>

                            @foreach (var row in subjectGroup.Rows)
                            {
                                var rowStyle = row.IsStrandActive
                                    ? ""
                                    : "opacity:0.35; pointer-events:none;";
                                <div class="grade-row @(row.IsExpanded ? "grade-row--expanded" : "")" style="@rowStyle">
                                    <div class="d-flex align-center gap-3 px-2 py-2">
                                        <div style="flex:1; min-width:0;">
                                            <MudText Typo="Typo.body2" Style="font-weight:500; color:#1A2B3C;">
                                                @row.DisplayName
                                            </MudText>
                                            @if (row.LearningItem.GradingScale?.Name is not null)
                                            {
                                                <MudText Typo="Typo.caption" Style="color:#6B7A8D;">
                                                    @row.LearningItem.GradingScale.Name
                                                </MudText>
                                            }
                                            @if (row.RowModifierOptions.Count > 0)
                                            {
                                                <div class="d-flex flex-wrap gap-2 mt-1">
                                                    @foreach (var opt in row.RowModifierOptions)
                                                    {
                                                        var isRowChecked = row.RowEnabledModifiers.Contains(opt);
                                                        <MudCheckBox T="bool"
                                                                     Value="@isRowChecked"
                                                                     ValueChanged="@(async (bool v) => await ToggleStrandModifierAsync(enrollment, subjectGroup, row, opt))"
                                                                     Size="Size.Small"
                                                                     Color="Color.Secondary"
                                                                     Label="@opt"
                                                                     Style="margin:0; font-size:11px;"
                                                                     @onclick:stopPropagation="true" />
                                                    }
                                                </div>
                                            }
                                        </div>
                                        <div style="width:160px; flex-shrink:0;">
                                            @if (row.LearningItem.GradingScale?.ValueType == GradingValueType.OptionList)
                                            {
                                                <MudSelect T="string?"
                                                           Value="@row.ValueText"
                                                           ValueChanged="@(v => row.ValueText = v)"
                                                           Variant="Variant.Outlined"
                                                           Dense="true"
                                                           Margin="Margin.Dense"
                                                           Clearable="true"
                                                           AnchorOrigin="Origin.BottomLeft">
                                                    @foreach (var opt in row.LearningItem.GradingScale.Options.OrderBy(o => o.SortOrder))
                                                    {
                                                        <MudSelectItem T="string?" Value="@opt.Label">
                                                            @(opt.Code is not null ? $"{opt.Code} – {opt.Label}" : opt.Label)
                                                        </MudSelectItem>
                                                    }
                                                </MudSelect>
                                            }
                                            else if (row.LearningItem.GradingScale?.ValueType == GradingValueType.Numeric)
                                            {
                                                <MudNumericField T="decimal?"
                                                                 Value="@row.ValueNumber"
                                                                 ValueChanged="@(v => row.ValueNumber = v)"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense"
                                                                 Min="@(row.LearningItem.GradingScale.MinValue ?? 0m)"
                                                                 Max="@(row.LearningItem.GradingScale.MaxValue ?? 100m)"
                                                                 Step="@(row.LearningItem.GradingScale.Step ?? 1m)"
                                                                 Adornment="@(row.LearningItem.GradingScale.DisplaySuffix != null ? Adornment.End : Adornment.None)"
                                                                 AdornmentText="@row.LearningItem.GradingScale.DisplaySuffix" />
                                            }
                                            else
                                            {
                                                <MudTextField T="string?"
                                                              Value="@row.ValueText"
                                                              ValueChanged="@(v => row.ValueText = v)"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Placeholder="Enter grade" />
                                            }
                                        </div>
                                        <div style="flex:1.4; min-width:0;">
                                            <div class="d-flex align-center gap-1">
                                                <MudTextField T="string?"
                                                              @bind-Value="row.Comment"
                                                              Variant="Variant.Outlined"
                                                              Margin="Margin.Dense"
                                                              Lines="2"
                                                              MaxLength="2000"
                                                              Placeholder="Comment… (Ctrl+Shift+A for AI)"
                                                              Style="font-size:13px; flex:1;"
                                                              UserAttributes="@(new Dictionary<string, object> { ["spellcheck"] = "true" })"
                                                              OnKeyDown="@((KeyboardEventArgs e) => HandleCommentKeyDown(e, enrollment, row, subjectGroup.SubjectName))" />
                                                <div @onclick:stopPropagation="true">
                                                    <MudTooltip Text="Insert comment template">
                                                        <MudIconButton Icon="@Icons.Material.Outlined.LibraryBooks"
                                                                       Size="Size.Small"
                                                                       Color="Color.Primary"
                                                                       OnClick="@(() => OpenTemplatePickerAsync(enrollment, row, subjectGroup.SubjectName))" />
                                                    </MudTooltip>
                                                </div>
                                                <div @onclick:stopPropagation="true">
                                                    <MudTooltip Text="AI comment assistant">
                                                        <MudIconButton Icon="@Icons.Material.Filled.AutoAwesome"
                                                                       Size="Size.Small"
                                                                       Color="Color.Secondary"
                                                                       OnClick="@(() => OpenCommentAssistant(enrollment, row, subjectGroup.SubjectName))" />
                                                    </MudTooltip>
                                                </div>
                                            </div>
                                        </div>
                                        <div style="width:32px; flex-shrink:0; text-align:center;">
                                            @if (row.SubStrands.Any())
                                            {
                                                <MudTooltip Text="@(row.IsExpanded ? "Hide curriculum details" : "View curriculum details")">
                                                    <MudIconButton Icon="@(row.IsExpanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Outlined.Info)"
                                                                   Size="Size.Small"
                                                                   Color="@(row.IsExpanded ? Color.Primary : Color.Default)"
                                                                   OnClick="@(() => row.IsExpanded = !row.IsExpanded)" />
                                                </MudTooltip>
                                            }
                                        </div>
                                    </div>

                                    <MudCollapse Expanded="@row.IsExpanded">
                                        <div style="margin: 0 8px 12px 8px; padding:14px 16px;
                                                    background:#F4F6F9; border-radius:8px;
                                                    border-left:3px solid #2E86C1;">
                                            <div class="d-flex align-center gap-2 mb-2">
                                                <MudIcon Icon="@Icons.Material.Filled.AutoStories" Size="Size.Small" Style="color:#2E86C1;" />
                                                <MudText Typo="Typo.caption" Style="font-weight:700; text-transform:uppercase; letter-spacing:0.06em; color:#2E86C1;">
                                                    Curriculum Expectations
                                                </MudText>
                                            </div>
                                            @foreach (var sub in row.SubStrands.OrderBy(s => s.SortOrder))
                                            {
                                                <div class="mb-3">
                                                    <MudText Typo="Typo.body2" Style="font-weight:700; color:#1A2B3C; margin-bottom:2px;">
                                                        @if (!string.IsNullOrWhiteSpace(sub.Code))
                                                        {
                                                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info"
                                                                     Style="font-size:10px; height:18px; margin-right:6px; padding:0 6px;">
                                                                @sub.Code
                                                            </MudChip>
                                                        }
                                                        @sub.Name
                                                    </MudText>
                                                    @if (!string.IsNullOrWhiteSpace(sub.Description))
                                                    {
                                                        <MudText Typo="Typo.body2" Style="color:#455A64; line-height:1.5; padding-left:4px;">
                                                            @sub.Description
                                                        </MudText>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </MudCollapse>
                                </div>
                            }

                            <div class="mb-4"></div>
                        }

                        <MudDivider Class="mt-2 mb-3" />
                        <div class="d-flex justify-end">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Save"
                                       OnClick="@(() => SaveGradesAsync(enrollment.StudentId))"
                                       Disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                    <span>Saving…</span>
                                }
                                else
                                {
                                    <span>Save Grades</span>
                                }
                            </MudButton>
                        </div>
                    </div>
                }
                else
                {
                    <MudDivider />
                    <MudAlert Severity="Severity.Info" Class="ma-3" Variant="Variant.Outlined">
                        No learning items found. Make sure learning items have been seeded for this student.
                    </MudAlert>
                }
            </MudCollapse>
        </MudCard>
    }
    }
}

<!-- ── COMMENT TEMPLATE PICKER DIALOG ──────────────────────────────────── -->
<MudDialog Visible="_templateDialogVisible"
           VisibleChanged="@((bool v) => _templateDialogVisible = v)"
           Options="@(new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseButton = true })">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Outlined.LibraryBooks" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Comment Templates</MudText>
            @if (_templateTargetEnrollment?.Student != null)
            {
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">
                    @_templateTargetEnrollment.Student.FirstName @_templateTargetEnrollment.Student.LastName
                </MudChip>
            }
        </div>
    </TitleContent>
    <DialogContent>
        <!-- Filters -->
        <MudGrid Spacing="2" Class="mb-3">
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_templateSearch"
                              Placeholder="Search by title or keyword…"
                              Adornment="Adornment.Start"
                              AdornmentIcon="@Icons.Material.Filled.Search"
                              Variant="Variant.Outlined"
                              Margin="Margin.Dense"
                              Clearable="true" />
            </MudItem>
            <MudItem xs="12" sm="3">
                <MudSelect T="string?" Value="_templateFilterSubject"
                           ValueChanged="@((string? v) => { _templateFilterSubject = v; _templatePageSize = 50; })"
                           Label="Subject"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomLeft">
                    @foreach (var s in _templateSubjects)
                    {
                        <MudSelectItem T="string?" Value="@s">@s</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="2">
                <MudSelect T="string?" Value="_templateFilterGrade"
                           ValueChanged="@((string? v) => { _templateFilterGrade = v; _templatePageSize = 50; })"
                           Label="Grade"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomLeft">
                    @foreach (var g in _templateGrades)
                    {
                        <MudSelectItem T="string?" Value="@g">@g</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect T="string?" Value="_templateFilterCategory"
                           ValueChanged="@((string? v) => { _templateFilterCategory = v; _templatePageSize = 50; })"
                           Label="Category"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Clearable="true"
                           AnchorOrigin="Origin.BottomLeft">
                    @foreach (var cat in _templateList.Select(t => t.Category).Where(c => c != null).Distinct().OrderBy(c => c))
                    {
                        <MudSelectItem T="string?" Value="@cat">@cat</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
        </MudGrid>

        @if (!_templateList.Any())
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                No templates available. Import templates via the Admin page.
            </MudAlert>
        }
        else
        {
            var filtered = FilteredTemplates.ToList();
            var paged    = filtered.Take(_templatePageSize).ToList();
            @if (!filtered.Any())
            {
                <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary); padding:16px 0;">
                    No templates match your search.
                </MudText>
            }
            else
            {
                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); margin-bottom:8px; display:block;">
                    Showing @paged.Count of @filtered.Count
                </MudText>
                <div style="max-height:420px; overflow-y:auto; display:flex; flex-direction:column; gap:8px;">
                    @foreach (var t in paged)
                    {
                        var preview = t.TemplateText.Length > 200
                            ? t.TemplateText[..200] + "…"
                            : t.TemplateText;

                        <MudPaper Outlined="true"
                                  Class="pa-3"
                                  Style="cursor:pointer; border-radius:8px; transition:box-shadow 0.15s;"
                                  @onclick="@(() => ApplyTemplate(t))">
                            <div class="d-flex align-center justify-space-between mb-1">
                                <div class="d-flex align-center gap-2" style="flex-wrap:wrap;">
                                    @if (t.Title != null)
                                    {
                                        <MudText Typo="Typo.body2" Style="font-weight:600; color:#1A2B3C;">@t.Title</MudText>
                                    }
                                    @if (t.Category != null)
                                    {
                                        var chipColor = t.Category switch
                                        {
                                            "Strength"   => Color.Success,
                                            "Next Steps" => Color.Info,
                                            "Weaknesses" => Color.Warning,
                                            _            => Color.Default,
                                        };
                                        <MudChip T="string" Size="Size.Small" Color="@chipColor" Variant="Variant.Filled"
                                                 Style="font-size:10px; height:20px;">@t.Category</MudChip>
                                    }
                                    @if (t.GradeLabel != null)
                                    {
                                        <MudChip T="string" Size="Size.Small" Color="Color.Default" Variant="Variant.Outlined"
                                                 Style="font-size:10px; height:20px;">Grade @t.GradeLabel</MudChip>
                                    }
                                </div>
                                <MudIconButton Icon="@Icons.Material.Filled.AddCircle"
                                               Size="Size.Small" Color="Color.Primary"
                                               OnClick="@(() => ApplyTemplate(t))" />
                            </div>
                            <MudText Typo="Typo.body2" Style="color:#455A64; line-height:1.5; white-space:pre-wrap;">@preview</MudText>
                        </MudPaper>
                    }
                </div>
                @if (filtered.Count > _templatePageSize)
                {
                    <div class="d-flex justify-center mt-3">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Primary"
                                   OnClick="@(() => _templatePageSize += 50)">
                            Load more (@(filtered.Count - paged.Count) remaining)
                        </MudButton>
                    </div>
                }
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _templateDialogVisible = false)">Cancel</MudButton>
    </DialogActions>
</MudDialog>

<style>
    .grade-row {
        border-radius: 6px;
        transition: background 0.15s;
    }
    .grade-row:hover {
        background: rgba(27, 79, 114, 0.035);
    }
    .grade-row--expanded {
        background: rgba(46, 134, 193, 0.05);
        border: 1px solid rgba(46, 134, 193, 0.2);
        border-radius: 8px;
        margin-bottom: 4px;
    }
</style>

@code {

    // ── VIEW MODELS ───────────────────────────────────────────────

    private class SubjectGroup
    {
        public string SubjectName { get; set; } = "";
        public string? SubjectCode { get; set; }
        public int SortOrder { get; set; }
        public int? CurriculumClassTemplateId { get; set; }
        public List<GradeRow> Rows { get; set; } = new();
        // Modifier options from the assigned template (empty = none configured)
        public List<string> ModifierOptions { get; set; } = new();
        // Which modifier options are currently checked for this student
        public HashSet<string> EnabledModifiers { get; set; } = new();
        public int? ExistingModifierId { get; set; }
        public bool IsSavingModifiers { get; set; }
    }

    private class GradeRow
    {
        public StudentLearningItem LearningItem { get; set; } = null!;
        public string DisplayName { get; set; } = "";
        public int? ExistingAssessmentId { get; set; }
        public string?  ValueText   { get; set; }
        public decimal? ValueNumber { get; set; }
        public string?  Comment     { get; set; }
        public bool IsExpanded { get; set; }
        public List<CurriculumSubStrand> SubStrands { get; set; } = new();
        // The strand this row belongs to (null = class-level item, not strand-level)
        public int? StrandId { get; set; }
        // CurriculumSubjectTemplateId for strand-level modifier keying
        public int? CurriculumSubjectTemplateId { get; set; }
        // Whether this row's strand is active (null = no strand config, show everything)
        public bool IsStrandActive { get; set; } = true;
        // Per-row modifier options (from parent subject group) — empty = no modifiers
        public List<string> RowModifierOptions { get; set; } = new();
        // Which modifier options are currently checked for THIS strand row
        public HashSet<string> RowEnabledModifiers { get; set; } = new();
    }

    private class LearningSkillsState
    {
        public int? ExistingId_T1   { get; set; }   // Term1 LearningSkillsEntry.Id
        public int? ExistingId_T2   { get; set; }   // Term2 LearningSkillsEntry.Id
        public bool IsSaving        { get; set; }

        // Current term values (shown + edited)
        public string? Responsibility_T1   { get; set; }
        public string? Responsibility_T2   { get; set; }
        public string? Organization_T1     { get; set; }
        public string? Organization_T2     { get; set; }
        public string? IndependentWork_T1  { get; set; }
        public string? IndependentWork_T2  { get; set; }
        public string? Collaboration_T1    { get; set; }
        public string? Collaboration_T2    { get; set; }
        public string? Initiative_T1       { get; set; }
        public string? Initiative_T2       { get; set; }
        public string? SelfRegulation_T1   { get; set; }
        public string? SelfRegulation_T2   { get; set; }
        public string? StrengthsNextSteps  { get; set; }
    }

    private class StudentState
    {
        public int StudentId { get; set; }
        public string StudentName { get; set; } = "";
        public bool IsLoading { get; set; }
        public bool IsSaving  { get; set; }
        public bool IsPeerReviewed { get; set; }
        public bool IsSavingPeerReview { get; set; }
        public string? ReviewerInitials { get; set; }
        public string? ReviewerName { get; set; }
        public List<SubjectGroup> Groups { get; set; } = new();
        public LearningSkillsState? LearningSkills { get; set; }

        public int TotalItems  => Groups.Sum(g => g.Rows.Count);
        public int GradedItems => Groups.Sum(g => g.Rows.Count(r => r.ValueText != null || r.ValueNumber != null));
        public bool HasAnyGrades  => GradedItems > 0;
        public bool IsFullyGraded => TotalItems > 0 && GradedItems == TotalItems;
    }

    // ── STATE ─────────────────────────────────────────────────────

    private bool _isLoadingTerms    = true;
    private bool _isLoadingStudents = false;

    private List<TermInstance> _terms       = new();
    private List<Enrollment>   _enrollments = new();

    // Keyed by StudentId
    private Dictionary<int, StudentState> _studentStates = new();

    private int? _selectedTermId;
    private int? _expandedStudentId;
    private int? _teacherId;
    private string? _teacherName;

    private static readonly string[] _egsnOptions = ["E", "G", "S", "N"];

    // ── LIFECYCLE ─────────────────────────────────────────────────

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
        if (email != null)
        {
            var appUser = await Db.AppUsers
                .Include(u => u.Teacher)
                .FirstOrDefaultAsync(u => u.Email == email);

            if (appUser?.TeacherId != null)
            {
                _teacherId   = appUser.TeacherId;
                _teacherName = appUser.Teacher?.DisplayName;
            }
        }

        var termsQuery = Db.TermInstances
            .Include(t => t.SchoolYear)
            .AsQueryable();

        if (_teacherId != null)
        {
            var assignedTermIds = await Db.TeacherAssignments
                .Where(a => a.TeacherId == _teacherId)
                .Select(a => a.ClassGroupInstance.TermInstanceId)
                .Distinct()
                .ToListAsync();

            termsQuery = termsQuery.Where(t => assignedTermIds.Contains(t.Id));
        }

        _terms = await termsQuery
            .OrderByDescending(t => t.SchoolYear!.IsActive)
            .ThenByDescending(t => t.SchoolYearId)
            .ThenBy(t => t.SortOrder)
            .ToListAsync();

        // Auto-select current term
        var today = DateOnly.FromDateTime(DateTime.Today);
        var currentTerm = _terms.FirstOrDefault(t => t.StartDate <= today && t.EndDate >= today);
        if (currentTerm != null)
        {
            _selectedTermId = currentTerm.Id;
            await LoadStudentsAsync();
        }

        _isLoadingTerms = false;
    }

    // ── TERM CHANGE ───────────────────────────────────────────────

    private async Task TermChanged(int? value)
    {
        _selectedTermId    = value;
        _expandedStudentId = null;
        _enrollments       = new();
        _studentStates     = new();

        if (_selectedTermId == null) return;
        await LoadStudentsAsync();
    }

    private async Task LoadStudentsAsync()
    {
        if (_selectedTermId == null) return;

        _isLoadingStudents = true;
        StateHasChanged();

        var enrollmentQuery = Db.Enrollments
            .Include(e => e.Student)
            .Include(e => e.Grade)
            .Where(e => e.TermInstanceId == _selectedTermId && e.Student!.IsActive);

        if (_teacherId != null)
        {
            var assignedCgiIds = await Db.TeacherAssignments
                .Where(a => a.TeacherId == _teacherId &&
                            a.ClassGroupInstance.TermInstanceId == _selectedTermId)
                .Select(a => a.ClassGroupInstanceId)
                .Distinct()
                .ToListAsync();

            enrollmentQuery = enrollmentQuery
                .Where(e => assignedCgiIds.Contains(e.ClassGroupInstanceId));
        }

        _enrollments = await enrollmentQuery
            .OrderBy(e => e.Student!.LastName)
            .ThenBy(e => e.Student!.FirstName)
            .ToListAsync();

        // Pre-populate state shells — grades loaded on expand
        _studentStates = _enrollments.ToDictionary(
            e => e.StudentId,
            e => new StudentState
            {
                StudentId   = e.StudentId,
                StudentName = $"{e.Student?.FirstName} {e.Student?.LastName}"
            });

        // Load peer review status for all enrollments in this term
        try
        {
            var enrollmentIds = _enrollments.Select(e => e.Id).ToList();
            var peerReviews = await Db.EnrollmentPeerReviews
                .Include(r => r.ReviewerTeacher)
                .Where(r => r.TermInstanceId == _selectedTermId && enrollmentIds.Contains(r.EnrollmentId))
                .ToListAsync();
            var reviewMap = peerReviews.ToDictionary(r => r.EnrollmentId);
            foreach (var enrollment in _enrollments)
            {
                if (_studentStates.TryGetValue(enrollment.StudentId, out var st) &&
                    reviewMap.TryGetValue(enrollment.Id, out var review))
                {
                    st.IsPeerReviewed   = true;
                    st.ReviewerName     = review.ReviewerTeacher?.DisplayName;
                    st.ReviewerInitials = GetInitials(
                        review.ReviewerTeacher?.DisplayName?.Split(' ').FirstOrDefault(),
                        review.ReviewerTeacher?.DisplayName?.Split(' ').Skip(1).FirstOrDefault());
                }
            }
        }
        catch
        {
            // EnrollmentPeerReviews table may not exist yet — migration pending
        }

        _isLoadingStudents = false;
    }

    // ── EXPAND / COLLAPSE ─────────────────────────────────────────

    private async Task ToggleStudentAsync(int studentId)
    {
        if (_expandedStudentId == studentId)
        {
            _expandedStudentId = null;
            return;
        }

        _expandedStudentId = studentId;

        var state = _studentStates.GetValueOrDefault(studentId);
        if (state == null) return;

        // Already loaded — don't reload
        if (state.Groups.Any()) return;

        state.IsLoading = true;
        StateHasChanged();

        try
        {
            await BuildGradeGroupsAsync(state, studentId);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load grades: {ex.Message}", Severity.Error);
        }
        finally
        {
            state.IsLoading = false;
            StateHasChanged();
        }
    }

    // ── BUILD GRADE ROWS ──────────────────────────────────────────

    private async Task BuildGradeGroupsAsync(StudentState state, int studentId)
    {
        var enrollment = await Db.Enrollments
            .FirstOrDefaultAsync(e =>
                e.StudentId      == studentId &&
                e.TermInstanceId == _selectedTermId);

        if (enrollment == null) return;

        var items = await Db.StudentLearningItems
            .Include(li => li.GradingScale)
                .ThenInclude(gs => gs!.Options)
            .Include(li => li.YearClassOffering)
                .ThenInclude(o => o!.CurriculumClassTemplate)
            .Include(li => li.YearSubjectOffering)
                .ThenInclude(o => o!.CurriculumSubjectTemplate)
                    .ThenInclude(st => st!.CurriculumClassTemplate)
            .Include(li => li.YearSubjectOffering)
                .ThenInclude(o => o!.CurriculumSubjectTemplate)
                    .ThenInclude(st => st!.SubStrands)
            .Where(li => li.EnrollmentId == enrollment.Id)
            .ToListAsync();

        var itemIds     = items.Select(li => li.Id).ToList();
        var assessments = await Db.Assessments
            .Where(a => a.TermInstanceId == _selectedTermId && itemIds.Contains(a.StudentLearningItemId))
            .ToListAsync();
        var assessmentMap = assessments.ToDictionary(a => a.StudentLearningItemId);

        // Load subject configs for this class group instance
        var subjectConfigs = await Db.ClassGroupSubjectConfigs
            .Include(c => c.SubjectModifierTemplate)
            .Include(c => c.CurriculumClassTemplate)
            .Where(c => c.ClassGroupInstanceId == enrollment.ClassGroupInstanceId)
            .ToListAsync();

        // Index by direct template ID for exact lookups
        var configByTemplateId = subjectConfigs.ToDictionary(c => c.CurriculumClassTemplateId);

        // Also index by subject NAME so we can match any grade's template to the right config
        // (e.g. "Science and Technology" config saved against grade 3 template should also
        // apply when displaying grade 4 items that share the same subject name)
        var configBySubjectName = subjectConfigs
            .Where(c => c.CurriculumClassTemplate?.Name != null)
            .GroupBy(c => c.CurriculumClassTemplate!.Name)
            .ToDictionary(g => g.Key, g => g.First());

        // Build a canonical ID map: for each subject name, lowest CurriculumClassTemplateId wins.
        // This ensures grade-specific templates all resolve to the same config row.
        var canonicalIdByName = items
            .Select(li => li.ItemType == LearningItemType.Class
                ? li.YearClassOffering?.CurriculumClassTemplate
                : li.YearSubjectOffering?.CurriculumSubjectTemplate?.CurriculumClassTemplate)
            .Where(ct => ct != null)
            .GroupBy(ct => ct!.Name)
            .ToDictionary(
                g => g.Key,
                g => g.Min(ct => ct!.Id));

        int CanonicalId(int? id, string? name) =>
            name != null && canonicalIdByName.TryGetValue(name, out var cid) ? cid : (id ?? 0);

        // Load existing student modifier records for this enrollment + term
        // Wrapped in try/catch — StrandModifiersJson column may not exist until migration runs
        List<StudentSubjectModifier> studentModifiers = new();
        try
        {
            studentModifiers = await Db.StudentSubjectModifiers
                .Where(m => m.EnrollmentId == enrollment.Id && m.TermInstanceId == _selectedTermId)
                .ToListAsync();
        }
        catch { /* migration pending — carry on without modifiers */ }
        var modifierByTemplateId = studentModifiers.ToDictionary(m => m.CurriculumClassTemplateId);

        // Filter out items with broken offering references (stale after curriculum re-import)
        items = items.Where(li =>
            li.ItemType == LearningItemType.Class
                ? li.YearClassOffering?.CurriculumClassTemplate != null
                : li.YearSubjectOffering?.CurriculumSubjectTemplate != null
        ).ToList();

        var rows = items.Select(li =>
        {
            assessmentMap.TryGetValue(li.Id, out var existing);
            var subStrands = li.ItemType == LearningItemType.Subject
                ? li.YearSubjectOffering?.CurriculumSubjectTemplate?.SubStrands ?? new()
                : new List<CurriculumSubStrand>();

            // Determine which strand (if any) this row belongs to
            // A subject-level item's strand is its CurriculumSubjectTemplate's parent strand
            // For now we use the CurriculumSubjectTemplateId as a proxy for strand grouping
            var strandId = li.ItemType == LearningItemType.Subject
                ? li.YearSubjectOffering?.CurriculumSubjectTemplate?.Id
                : (int?)null;

            return new GradeRow
            {
                LearningItem                = li,
                DisplayName                 = li.DisplayName,
                ExistingAssessmentId        = existing?.Id,
                ValueText                   = existing?.ValueText,
                ValueNumber                 = existing?.ValueNumber,
                Comment                     = existing?.Comment,
                SubStrands                  = subStrands,
                StrandId                    = strandId,
                CurriculumSubjectTemplateId = li.YearSubjectOffering?.CurriculumSubjectTemplateId,
            };
        }).ToList();

        // ── Learning Skills ────────────────────────────────────────────────
        // Load current term + find the other-term instance to show both columns.
            var currentTermEntry = await Db.LearningSkillsEntries
                .FirstOrDefaultAsync(l => l.EnrollmentId == enrollment.Id
                                       && l.TermInstanceId == _selectedTermId);

            // Find companion term (Term1↔Term2) for the two-column display
            var currentTerm = _terms.FirstOrDefault(t => t.Id == _selectedTermId);
            LearningSkillsEntry? otherTermEntry = null;
            if (currentTerm != null)
            {
                int? otherTermId = null;
                if (currentTerm.ReportCardTermSlot == ReportCardTermSlot.Term2)
                    otherTermId = _terms.FirstOrDefault(t =>
                        t.SchoolYearId == currentTerm.SchoolYearId &&
                        t.ReportCardTermSlot == ReportCardTermSlot.Term1)?.Id;
                else if (currentTerm.ReportCardTermSlot == ReportCardTermSlot.Term1)
                    otherTermId = _terms.FirstOrDefault(t =>
                        t.SchoolYearId == currentTerm.SchoolYearId &&
                        t.ReportCardTermSlot == ReportCardTermSlot.Term2)?.Id;

                if (otherTermId.HasValue)
                    otherTermEntry = await Db.LearningSkillsEntries
                        .FirstOrDefaultAsync(l => l.EnrollmentId == enrollment.Id
                                               && l.TermInstanceId == otherTermId.Value);
            }

            // Determine which column is T1 vs T2 based on current term's slot
            LearningSkillsEntry? t1 = null, t2 = null;
            if (currentTerm?.ReportCardTermSlot == ReportCardTermSlot.Term1)
                { t1 = currentTermEntry; t2 = otherTermEntry; }
            else
                { t1 = otherTermEntry; t2 = currentTermEntry; }

            state.LearningSkills = new LearningSkillsState
            {
                ExistingId_T1      = t1?.Id,
                ExistingId_T2      = t2?.Id,
                Responsibility_T1  = t1?.Responsibility,
                Responsibility_T2  = t2?.Responsibility,
                Organization_T1    = t1?.Organization,
                Organization_T2    = t2?.Organization,
                IndependentWork_T1 = t1?.IndependentWork,
                IndependentWork_T2 = t2?.IndependentWork,
                Collaboration_T1   = t1?.Collaboration,
                Collaboration_T2   = t2?.Collaboration,
                Initiative_T1      = t1?.Initiative,
                Initiative_T2      = t2?.Initiative,
                SelfRegulation_T1  = t1?.SelfRegulation,
                SelfRegulation_T2  = t2?.SelfRegulation,
                StrengthsNextSteps = currentTermEntry?.StrengthsNextSteps ?? otherTermEntry?.StrengthsNextSteps,
            };

            state.Groups = rows
            .GroupBy(r =>
            {
                if (r.LearningItem.ItemType == LearningItemType.Class)
                {
                    var name = r.LearningItem.YearClassOffering?.CurriculumClassTemplate?.Name ?? "General";
                    return (
                        Name:                      name,
                        Code:                      r.LearningItem.YearClassOffering?.CurriculumClassTemplate?.Code,
                        SortOrder:                 r.LearningItem.YearClassOffering?.CurriculumClassTemplate?.SortOrder ?? 999,
                        CurriculumClassTemplateId: (int?)CanonicalId(r.LearningItem.YearClassOffering?.CurriculumClassTemplateId, name)
                    );
                }
                else
                {
                    var name = r.LearningItem.YearSubjectOffering?.CurriculumSubjectTemplate?.CurriculumClassTemplate?.Name ?? "General";
                    return (
                        Name:                      name,
                        Code:                      r.LearningItem.YearSubjectOffering?.CurriculumSubjectTemplate?.CurriculumClassTemplate?.Code,
                        SortOrder:                 r.LearningItem.YearSubjectOffering?.CurriculumSubjectTemplate?.CurriculumClassTemplate?.SortOrder ?? 999,
                        CurriculumClassTemplateId: (int?)CanonicalId(r.LearningItem.YearSubjectOffering?.CurriculumSubjectTemplate?.CurriculumClassTemplateId, name)
                    );
                }
            })
            .OrderBy(g => g.Key.SortOrder)
            .ThenBy(g => g.Key.Name)
            .Select(g =>
            {
                var cctId = g.Key.CurriculumClassTemplateId;

                // Resolve config: try direct ID match first, fall back to name match
                // (config may be stored against a different grade's template ID for the same subject)
                var subjectGroupName = g.Key.Name;
                ClassGroupSubjectConfig? resolvedCfg = null;
                if (cctId.HasValue)
                    configByTemplateId.TryGetValue(cctId.Value, out resolvedCfg);
                if (resolvedCfg == null)
                    configBySubjectName.TryGetValue(subjectGroupName, out resolvedCfg);

                // Get active strand IDs for this subject group
                HashSet<int> activeStrandIds = new();
                bool hasStrandConfig = false;
                if (resolvedCfg != null)
                {
                    var ids = System.Text.Json.JsonSerializer
                        .Deserialize<List<int>>(resolvedCfg.ActiveStrandIdsJson) ?? new();
                    if (ids.Count > 0)
                    {
                        hasStrandConfig = true;
                        activeStrandIds = ids.ToHashSet();
                    }
                }

                // Get modifier options + existing student modifiers
                List<string> modifierOptions = new();
                HashSet<string> enabledModifiers = new();
                int? existingModifierId = null;
                if (resolvedCfg?.SubjectModifierTemplate != null)
                {
                    modifierOptions = System.Text.Json.JsonSerializer
                        .Deserialize<List<string>>(resolvedCfg.SubjectModifierTemplate.OptionsJson) ?? new();
                }

                // For modifier save/load, use the resolved config's actual template ID
                var effectiveCctId = resolvedCfg != null
                    ? (int?)resolvedCfg.CurriculumClassTemplateId
                    : cctId;
                Dictionary<int, HashSet<string>> strandModifiers = new();
                if (effectiveCctId.HasValue && modifierByTemplateId.TryGetValue(effectiveCctId.Value, out var mod))
                {
                    existingModifierId = mod.Id;
                    enabledModifiers = (System.Text.Json.JsonSerializer
                        .Deserialize<List<string>>(mod.EnabledOptionsJson) ?? new()).ToHashSet();

                    // Parse per-strand modifiers dict
                    try
                    {
                        var rawDict = System.Text.Json.JsonSerializer
                            .Deserialize<Dictionary<string, List<string>>>(mod.StrandModifiersJson);
                        if (rawDict != null)
                            strandModifiers = rawDict.ToDictionary(
                                kv => int.Parse(kv.Key),
                                kv => kv.Value.ToHashSet());
                    }
                    catch { }
                }

                var groupRows = g
                    .OrderBy(r => r.LearningItem.ItemType)
                    .ThenBy(r => r.LearningItem.YearSubjectOffering?.CurriculumSubjectTemplate?.SortOrder ?? 999)
                    .ThenBy(r => r.DisplayName)
                    .ToList();

                // Apply strand active state + per-row modifiers
                foreach (var row in groupRows)
                {
                    // Strand active state
                    if (hasStrandConfig && row.SubStrands.Count > 0)
                        row.IsStrandActive = row.SubStrands.Any(s => activeStrandIds.Contains(s.Id));

                    // Per-strand modifier options: only for Subject-type rows
                    if (row.LearningItem.ItemType == LearningItemType.Subject && modifierOptions.Count > 0)
                    {
                        row.RowModifierOptions = modifierOptions;
                        if (row.CurriculumSubjectTemplateId.HasValue &&
                            strandModifiers.TryGetValue(row.CurriculumSubjectTemplateId.Value, out var sm))
                            row.RowEnabledModifiers = sm;
                    }
                }

                return new SubjectGroup
                {
                    SubjectName               = g.Key.Name,
                    SubjectCode               = g.Key.Code,
                    SortOrder                 = g.Key.SortOrder,
                    CurriculumClassTemplateId = effectiveCctId,  // use resolved ID so saves go to correct record
                    ModifierOptions           = modifierOptions,
                    EnabledModifiers          = enabledModifiers,
                    ExistingModifierId        = existingModifierId,
                    Rows                      = groupRows
                };
            })
            .ToList();
    }

    // ── COMMENT TEMPLATE PICKER ──────────────────────────────────────

    private List<CommentTemplate> _templateList = new();
    private List<string> _templateSubjects = new();
    private List<string> _templateGrades   = new();
    private bool _templateDialogVisible;
    private string _templateSearch = "";
    private string? _templateFilterCategory;
    private string? _templateFilterSubject;
    private string? _templateFilterGrade;
    private int _templatePageSize = 50;
    private GradeRow? _templateTargetRow;
    private Enrollment? _templateTargetEnrollment;

    private void HandleCommentKeyDown(KeyboardEventArgs e, Enrollment enrollment, GradeRow row, string subjectName)
    {
        if (e.CtrlKey && e.ShiftKey && e.Key == "A")
            OpenCommentAssistant(enrollment, row, subjectName);
    }

    private void OpenCommentAssistant(Enrollment enrollment, GradeRow row, string subjectName)
    {
        var student    = enrollment.Student;
        var gradeLabel = enrollment.Grade?.Name;
        var term       = _terms.FirstOrDefault(t => t.Id == _selectedTermId);

        AssistantCtx.SetContext(
            new AssistantContext
            {
                Mode             = AssistantMode.CommentWriter,
                Page             = "grade-entry",
                PageLabel        = $"Comment: {subjectName}",
                StudentName      = student != null ? $"{student.FirstName} {student.LastName}" : null,
                StudentFirstName = student?.FirstName,
                GradeLabel       = gradeLabel,
                Subject          = subjectName,
                Term             = term != null ? $"{term.SchoolYear?.Name} – {term.Name}" : null,
                CurrentText      = string.IsNullOrWhiteSpace(row.Comment) ? null : row.Comment,
                SuggestedPrompt  = string.IsNullOrWhiteSpace(row.Comment)
                    ? $"Write a report card comment for {student?.FirstName} in {subjectName}"
                    : "Improve this comment",
            },
            // Callback: teacher clicks “Use this comment” in the drawer
            onCommentAccepted: text =>
            {
                row.Comment = text;
                StateHasChanged();
            });
    }

    private async Task OpenTemplatePickerAsync(Enrollment enrollment, GradeRow row, string subjectName)
    {
        try
        {
            _templateTargetRow        = row;
            _templateTargetEnrollment = enrollment;
            _templateSearch           = "";
            _templateFilterCategory   = null;
            _templateFilterSubject    = null;
            _templateFilterGrade      = null;
            _templatePageSize         = 50;

            // Load all templates — user filters manually until subject/grade names are normalized
            _templateList = await CommentSvc.GetTemplatesAsync();
            _templateSubjects = _templateList.Select(t => t.Subject).Where(s => s != null).Distinct().OrderBy(s => s).ToList()!;
            _templateGrades   = _templateList.Select(t => t.GradeLabel).Where(g => g != null).Distinct().OrderBy(g => g).ToList()!;

            _templateDialogVisible = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to open template picker: {ex.Message} | {ex.InnerException?.Message}", Severity.Error);
        }
    }

    private void ApplyTemplate(CommentTemplate template)
    {
        if (_templateTargetRow == null || _templateTargetEnrollment?.Student == null) return;

        var student = _templateTargetEnrollment.Student;
        var substituted = CommentTemplateService.Substitute(
            template.TemplateText,
            student.FirstName,
            student.Pronouns);

        // Append to existing comment or replace if empty
        _templateTargetRow.Comment = string.IsNullOrWhiteSpace(_templateTargetRow.Comment)
            ? substituted
            : _templateTargetRow.Comment.TrimEnd() + " " + substituted;

        _templateDialogVisible = false;
        StateHasChanged();
    }

    private IEnumerable<CommentTemplate> FilteredTemplates =>
        _templateList.Where(t =>
            (_templateFilterSubject  == null || t.Subject    == _templateFilterSubject) &&
            (_templateFilterGrade    == null || t.GradeLabel == _templateFilterGrade) &&
            (_templateFilterCategory == null || t.Category   == _templateFilterCategory) &&
            (string.IsNullOrWhiteSpace(_templateSearch)
             || t.TemplateText.Contains(_templateSearch, StringComparison.OrdinalIgnoreCase)
             || (t.Title?.Contains(_templateSearch, StringComparison.OrdinalIgnoreCase) ?? false)
             || (t.Category?.Contains(_templateSearch, StringComparison.OrdinalIgnoreCase) ?? false))
        );

    // ── SAVE ──────────────────────────────────────────────────────

    private async Task SaveGradesAsync(int studentId)
    {
        var state = _studentStates.GetValueOrDefault(studentId);
        if (state == null || _selectedTermId == null) return;

        state.IsSaving = true;
        StateHasChanged();

        try
        {
            var now = DateTimeOffset.UtcNow;

            foreach (var group in state.Groups)
            {
                foreach (var row in group.Rows)
                {
                    if (row.ExistingAssessmentId is int existingId)
                    {
                        var existing = await Db.Assessments.FindAsync(existingId);
                        if (existing != null)
                        {
                            existing.ValueText     = row.ValueText;
                            existing.ValueNumber   = row.ValueNumber;
                            existing.Comment       = row.Comment;
                            existing.LastUpdatedAt = now;
                        }
                    }
                    else if (row.ValueText != null || row.ValueNumber != null || row.Comment != null)
                    {
                        var assessment = new Assessment
                        {
                            StudentLearningItemId = row.LearningItem.Id,
                            TermInstanceId        = _selectedTermId.Value,
                            ValueText             = row.ValueText,
                            ValueNumber           = row.ValueNumber,
                            Comment               = row.Comment,
                            LastUpdatedAt         = now,
                        };
                        Db.Assessments.Add(assessment);
                    }
                }
            }

            await Db.SaveChangesAsync();

            // Refresh so new assessment IDs are picked up
            await BuildGradeGroupsAsync(state, studentId);

            Snackbar.Add($"Grades saved for {state.StudentName}!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            state.IsSaving = false;
        }
    }

    // ── SUBJECT MODIFIERS ──────────────────────────────────────

    private async Task ToggleStrandModifierAsync(Enrollment enrollment, SubjectGroup sg, GradeRow row, string option)
    {
        if (row.CurriculumSubjectTemplateId == null || sg.CurriculumClassTemplateId == null || _selectedTermId == null) return;

        // Toggle in the row's in-memory set
        if (row.RowEnabledModifiers.Contains(option))
            row.RowEnabledModifiers.Remove(option);
        else
            row.RowEnabledModifiers.Add(option);

        sg.IsSavingModifiers = true;
        StateHasChanged();

        try
        {
            // Load or create the StudentSubjectModifier for this subject
            StudentSubjectModifier? mod;
            if (sg.ExistingModifierId.HasValue)
            {
                mod = await Db.StudentSubjectModifiers.FindAsync(sg.ExistingModifierId.Value);
            }
            else
            {
                mod = new StudentSubjectModifier
                {
                    EnrollmentId              = enrollment.Id,
                    TermInstanceId            = _selectedTermId.Value,
                    CurriculumClassTemplateId = sg.CurriculumClassTemplateId.Value,
                    EnabledOptionsJson        = System.Text.Json.JsonSerializer.Serialize(sg.EnabledModifiers.ToList()),
                    EnabledStrandIdsJson      = "[]",
                    StrandModifiersJson       = "{}",
                    UpdatedAt                 = DateTimeOffset.UtcNow
                };
                Db.StudentSubjectModifiers.Add(mod);
                await Db.SaveChangesAsync();
                sg.ExistingModifierId = mod.Id;
            }

            if (mod == null) return;

            // Rebuild the strand modifiers dict from ALL rows in this group
            var dict = new Dictionary<string, List<string>>();
            foreach (var r in sg.Rows.Where(r => r.CurriculumSubjectTemplateId.HasValue && r.RowEnabledModifiers.Any()))
                dict[r.CurriculumSubjectTemplateId!.Value.ToString()] = r.RowEnabledModifiers.ToList();

            mod.StrandModifiersJson = System.Text.Json.JsonSerializer.Serialize(dict);
            mod.UpdatedAt = DateTimeOffset.UtcNow;
            await Db.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save strand modifier: {ex.Message}", Severity.Error);
        }
        finally
        {
            sg.IsSavingModifiers = false;
            StateHasChanged();
        }
    }

    private async Task ToggleModifierAsync(Enrollment enrollment, SubjectGroup sg, string option)
    {
        if (sg.EnabledModifiers.Contains(option))
            sg.EnabledModifiers.Remove(option);
        else
            sg.EnabledModifiers.Add(option);

        if (sg.CurriculumClassTemplateId == null || _selectedTermId == null) return;

        sg.IsSavingModifiers = true;
        StateHasChanged();

        try
        {
            var json = System.Text.Json.JsonSerializer.Serialize(sg.EnabledModifiers.ToList());
            if (sg.ExistingModifierId.HasValue)
            {
                var existing = await Db.StudentSubjectModifiers.FindAsync(sg.ExistingModifierId.Value);
                if (existing != null)
                {
                    existing.EnabledOptionsJson = json;
                    existing.UpdatedAt = DateTimeOffset.UtcNow;
                }
            }
            else
            {
                // Check DB first — search by EnrollmentId + TermInstanceId + subject name
                var subjectName = sg.SubjectName;
                var dbExisting = await Db.StudentSubjectModifiers
                    .Include(m => m.CurriculumClassTemplate)
                    .Where(m => m.EnrollmentId   == enrollment.Id &&
                                m.TermInstanceId == _selectedTermId.Value)
                    .FirstOrDefaultAsync(m => m.CurriculumClassTemplate!.Name == subjectName
                                           || m.CurriculumClassTemplateId     == sg.CurriculumClassTemplateId.Value);

                if (dbExisting != null)
                {
                    dbExisting.EnabledOptionsJson = json;
                    dbExisting.UpdatedAt          = DateTimeOffset.UtcNow;
                    sg.ExistingModifierId         = dbExisting.Id;
                }
                else
                {
                    var newMod = new StudentSubjectModifier
                    {
                        EnrollmentId              = enrollment.Id,
                        TermInstanceId            = _selectedTermId.Value,
                        CurriculumClassTemplateId = sg.CurriculumClassTemplateId.Value,
                        EnabledOptionsJson        = json,
                        EnabledStrandIdsJson      = "[]",
                        StrandModifiersJson       = "{}",
                        UpdatedAt                 = DateTimeOffset.UtcNow
                    };
                    Db.StudentSubjectModifiers.Add(newMod);
                    await Db.SaveChangesAsync();
                    sg.ExistingModifierId = newMod.Id;
                    return;
                }
            }

            await Db.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            // Unique constraint violation: another checkbox click already created the record.
            // Reload the existing record and update it.
            if (ex.InnerException?.Message.Contains("duplicate", StringComparison.OrdinalIgnoreCase) == true ||
                ex.InnerException?.Message.Contains("unique",    StringComparison.OrdinalIgnoreCase) == true ||
                ex.Message.Contains("duplicate",                 StringComparison.OrdinalIgnoreCase) == true)
            {
                try
                {
                    Db.ChangeTracker.Clear();
                    var existing2 = await Db.StudentSubjectModifiers
                        .Include(m => m.CurriculumClassTemplate)
                        .Where(m => m.EnrollmentId   == enrollment.Id &&
                                    m.TermInstanceId == _selectedTermId!.Value)
                        .FirstOrDefaultAsync(m => m.CurriculumClassTemplate!.Name == sg.SubjectName
                                               || m.CurriculumClassTemplateId     == sg.CurriculumClassTemplateId!.Value);
                    if (existing2 != null)
                    {
                        existing2.EnabledOptionsJson = System.Text.Json.JsonSerializer.Serialize(sg.EnabledModifiers.ToList());
                        existing2.UpdatedAt          = DateTimeOffset.UtcNow;
                        sg.ExistingModifierId        = existing2.Id;
                        await Db.SaveChangesAsync();
                    }
                }
                catch (Exception ex2)
                {
                    Snackbar.Add($"Failed to save modifier: {ex2.Message}", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add($"Failed to save modifier: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            sg.IsSavingModifiers = false;
            StateHasChanged();
        }
    }

    // ── LEARNING SKILLS ───────────────────────────────────────

    private async Task SaveLearningSkillsAsync(Enrollment enrollment, StudentState state)
    {
        var ls = state.LearningSkills;
        if (ls == null || _selectedTermId == null) return;

        ls.IsSaving = true;
        StateHasChanged();

        try
        {
            var now = DateTimeOffset.UtcNow;
            var currentTerm = _terms.FirstOrDefault(t => t.Id == _selectedTermId);
            bool isCurrentTermT1 = currentTerm?.ReportCardTermSlot == ReportCardTermSlot.Term1;

            var currentEntry = await Db.LearningSkillsEntries
                .FirstOrDefaultAsync(e => e.EnrollmentId == enrollment.Id
                                       && e.TermInstanceId == _selectedTermId.Value);

            if (currentEntry == null)
            {
                currentEntry = new LearningSkillsEntry
                {
                    EnrollmentId   = enrollment.Id,
                    TermInstanceId = _selectedTermId.Value,
                    UpdatedAt      = now,
                };
                Db.LearningSkillsEntries.Add(currentEntry);
            }

            if (isCurrentTermT1)
            {
                currentEntry.Responsibility  = ls.Responsibility_T1;
                currentEntry.Organization    = ls.Organization_T1;
                currentEntry.IndependentWork = ls.IndependentWork_T1;
                currentEntry.Collaboration   = ls.Collaboration_T1;
                currentEntry.Initiative      = ls.Initiative_T1;
                currentEntry.SelfRegulation  = ls.SelfRegulation_T1;
            }
            else
            {
                currentEntry.Responsibility  = ls.Responsibility_T2;
                currentEntry.Organization    = ls.Organization_T2;
                currentEntry.IndependentWork = ls.IndependentWork_T2;
                currentEntry.Collaboration   = ls.Collaboration_T2;
                currentEntry.Initiative      = ls.Initiative_T2;
                currentEntry.SelfRegulation  = ls.SelfRegulation_T2;
            }
            currentEntry.StrengthsNextSteps = ls.StrengthsNextSteps;
            currentEntry.UpdatedAt = now;

            await Db.SaveChangesAsync();

            if (isCurrentTermT1) ls.ExistingId_T1 = currentEntry.Id;
            else                 ls.ExistingId_T2 = currentEntry.Id;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save learning skills: {ex.Message}", Severity.Error);
        }
        finally
        {
            ls.IsSaving = false;
            StateHasChanged();
        }
    }

    // ── PEER REVIEW ───────────────────────────────────────────

    private async Task TogglePeerReviewAsync(int studentId)
    {
        if (_teacherId == null) return; // must be logged in as a teacher
        var state = _studentStates.GetValueOrDefault(studentId);
        if (state == null || _selectedTermId == null) return;

        var enrollment = _enrollments.FirstOrDefault(e => e.StudentId == studentId);
        if (enrollment == null) return;

        state.IsSavingPeerReview = true;
        StateHasChanged();

        try
        {
            var existing = await Db.EnrollmentPeerReviews
                .FirstOrDefaultAsync(r => r.EnrollmentId == enrollment.Id && r.TermInstanceId == _selectedTermId);

            if (existing != null)
            {
                Db.EnrollmentPeerReviews.Remove(existing);
                state.IsPeerReviewed   = false;
                state.ReviewerInitials = null;
                state.ReviewerName     = null;
            }
            else
            {
                Db.EnrollmentPeerReviews.Add(new EnrollmentPeerReview
                {
                    EnrollmentId      = enrollment.Id,
                    TermInstanceId    = _selectedTermId.Value,
                    ReviewerTeacherId = _teacherId.Value
                });
                state.IsPeerReviewed   = true;
                state.ReviewerName     = _teacherName;
                state.ReviewerInitials = GetInitials(
                    _teacherName?.Split(' ').FirstOrDefault(),
                    _teacherName?.Split(' ').Skip(1).FirstOrDefault());
            }

            await Db.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Peer review update failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            state.IsSavingPeerReview = false;
        }
    }

    // ── COMPUTED ──────────────────────────────────────────────────

    private List<(string? Name, int SortOrder, List<Enrollment> Enrollments)> GradeGroups =>
        _enrollments
            .GroupBy(e => new { e.GradeId, e.Grade?.Name, SortOrder = e.Grade?.SortOrder ?? 999 })
            .OrderBy(g => g.Key.SortOrder)
            .Select(g => (g.Key.Name, g.Key.SortOrder, g.ToList()))
            .ToList();

    // ── HELPERS ───────────────────────────────────────────────────

    private static string GetInitials(string? first, string? last)
    {
        var f = string.IsNullOrWhiteSpace(first) ? "?" : first[0].ToString().ToUpper();
        var l = string.IsNullOrWhiteSpace(last)  ? ""  : last[0].ToString().ToUpper();
        return f + l;
    }
