@page "/school-years"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@using ReportCards.Web.Services
@inject SchoolDbContext Db
@inject ISnackbar Snackbar

<div class="d-flex align-center gap-3 mb-1">
    <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif;">School Years</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
               StartIcon="@(_showAddForm ? Icons.Material.Filled.Close : Icons.Material.Filled.Add)"
               OnClick="@(() => _showAddForm = !_showAddForm)">
        @(_showAddForm ? "Cancel" : "New Year")
    </MudButton>
</div>
<MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
    Manage school years, reporting terms, and the school calendar.
</MudText>

<MudCollapse Expanded="_showAddForm">
    <MudCard Class="mb-6" Elevation="1">
        <MudCardHeader>
            <CardHeaderContent><MudText Typo="Typo.h6">Add School Year</MudText></CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudGrid>
                <MudItem xs="12" sm="6" md="4">
                    <MudTextField @bind-Value="_newYearName" Label="School Year Name"
                                  Placeholder="e.g. 2025-2026" Variant="Variant.Outlined" FullWidth="true" />
                </MudItem>
                <MudItem xs="12" sm="6" md="2" Class="d-flex align-end">
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddSchoolYearAsync"
                               Disabled="@(string.IsNullOrWhiteSpace(_newYearName))"
                               FullWidth="true">
                        Add Year
                    </MudButton>
                </MudItem>
            </MudGrid>
        </MudCardContent>
    </MudCard>
</MudCollapse>

@if (_schoolYears.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        No school years yet. Add one above to get started.
    </MudAlert>
}
else
{
    @foreach (var year in _schoolYears)
    {
        <MudCard Class="mb-6" Elevation="1">
            <MudCardHeader>
                <CardHeaderContent>
                    <div class="d-flex align-center gap-3">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Color="Color.Primary" />
                        <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">@year.Name</MudText>
                        @if (year.IsActive)
                        {
                            <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Active</MudChip>
                        }
                        @if (year.IsLocked)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled"
                                     Icon="@Icons.Material.Filled.Lock">Locked</MudChip>
                        }
                    </div>
                </CardHeaderContent>
                <CardHeaderActions>
                    @if (!year.IsActive)
                    {
                        <MudTooltip Text="Set as active year">
                            <MudIconButton Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success"
                                           OnClick="@(() => SetActiveAsync(year))" />
                        </MudTooltip>
                    }
                    <MudTooltip Text="@(year.IsLocked ? "Unlock year" : "Lock year")">
                        <MudIconButton Icon="@(year.IsLocked ? Icons.Material.Filled.LockOpen : Icons.Material.Filled.Lock)"
                                       Color="Color.Warning" OnClick="@(() => ToggleLockAsync(year))" />
                    </MudTooltip>
                </CardHeaderActions>
            </MudCardHeader>

            <MudCardContent>

                <!-- Terms -->
                <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary);" Class="mb-2">Terms</MudText>

                @if (year.TermInstances.Count > 0)
                {
                    <MudTable Items="year.TermInstances.OrderBy(t => t.SortOrder)"
                              Dense="true" Hover="true" Elevation="0" Class="mb-4"
                              Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                        <HeaderContent>
                            <MudTh>Term</MudTh>
                            <MudTh>Start Date</MudTh>
                            <MudTh>End Date</MudTh>
                            <MudTh>
                                <MudTooltip Text="Which column this term fills on the two-term Elementary Report Card">
                                    RC Column Slot
                                </MudTooltip>
                            </MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>@context.Name</MudTd>
                            <MudTd>@context.StartDate.ToString("MMM d, yyyy")</MudTd>
                            <MudTd>@context.EndDate.ToString("MMM d, yyyy")</MudTd>
                            <MudTd>
                                <MudSelect T="ReportCardTermSlot"
                                           Value="context.ReportCardTermSlot"
                                           ValueChanged="@(async v => await SetTermSlotAsync(context, v))"
                                           Variant="Variant.Outlined"
                                           Margin="Margin.Dense"
                                           Style="min-width:160px;">
                                    <MudSelectItem T="ReportCardTermSlot" Value="ReportCardTermSlot.NotApplicable">
                                        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">Not Applicable</MudText>
                                    </MudSelectItem>
                                    <MudSelectItem T="ReportCardTermSlot" Value="ReportCardTermSlot.Term1">
                                        <MudText Typo="Typo.body2" Style="color:#1B8A4B; font-weight:600;">Term 1 (left column)</MudText>
                                    </MudSelectItem>
                                    <MudSelectItem T="ReportCardTermSlot" Value="ReportCardTermSlot.Term2">
                                        <MudText Typo="Typo.body2" Style="color:#1B4F72; font-weight:600;">Term 2 (right column)</MudText>
                                    </MudSelectItem>
                                </MudSelect>
                            </MudTd>
                            <MudTd Style="text-align:right;">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error" OnClick="@(() => DeleteTermAsync(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
                        No terms yet. Add a term below.
                    </MudText>
                }

                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="3">
                        <MudTextField @bind-Value="_newTermNames[year.Id]" Label="Term Name"
                                      Placeholder="e.g. Term 1" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudDatePicker @bind-Date="_newTermStarts[year.Id]" Label="Start Date"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" sm="3">
                        <MudDatePicker @bind-Date="_newTermEnds[year.Id]" Label="End Date"
                                       Variant="Variant.Outlined" Margin="Margin.Dense" DateFormat="yyyy-MM-dd" />
                    </MudItem>
                    <MudItem xs="12" sm="3" Class="d-flex align-end">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="@(() => AddTermAsync(year))"
                                   Disabled="@(!CanAddTerm(year.Id))"
                                   FullWidth="true">
                            Add Term
                        </MudButton>
                    </MudItem>
                </MudGrid>

                <MudDivider Class="mb-4" />

                <!-- Curriculum -->
                <div class="d-flex align-center gap-2 mb-3">
                    <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary);">Curriculum</MudText>
                    @if (_yearCurriculums.TryGetValue(year.Id, out var yc))
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled"
                                 Icon="@Icons.Material.Filled.CheckCircle">
                            @yc.CurriculumSchema?.Name
                        </MudChip>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                            @yc.TotalOfferings offering(s) generated
                        </MudText>
                        <MudTooltip Text="Change curriculum template">
                            <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small"
                                           Color="Color.Primary"
                                           OnClick="@(() => OpenApplyCurriculum(year))" />
                        </MudTooltip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined"
                                 Icon="@Icons.Material.Filled.Warning">
                            No curriculum applied
                        </MudChip>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.LibraryBooks"
                                   OnClick="@(() => OpenApplyCurriculum(year))">
                            Apply Curriculum
                        </MudButton>
                    }
                </div>

                <MudDivider Class="mb-4" />

                <!-- School Calendar -->
                <div class="d-flex align-center flex-wrap gap-2 mb-3">
                    <MudText Typo="Typo.overline" Style="color:var(--mud-palette-text-secondary);">
                        School Calendar — Non-School Days
                    </MudText>
                    <div class="d-flex gap-2" style="margin-left:auto;">
                        <MudButton Variant="Variant.Outlined" Color="Color.Primary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.EventAvailable"
                                   OnClick="@(() => ImportStatHolidaysAsync(year))"
                                   Disabled="@(_importingHolidays.Contains(year.Id))">
                            @(_importingHolidays.Contains(year.Id) ? "Creating..." : "Create Stat Holidays")
                        </MudButton>

                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="@(() => OpenAddException(year.Id))">
                            Add Day Off
                        </MudButton>
                    </div>
                </div>

                <!-- Legend -->
                <div class="d-flex gap-4 mb-3 flex-wrap">
                    <div class="d-flex align-center gap-1">
                        <div style="width:12px;height:12px;border-radius:3px;background:#E74C3C;"></div>
                        <MudText Typo="Typo.caption">Stat Holiday</MudText>
                    </div>
                    <div class="d-flex align-center gap-1">
                        <div style="width:12px;height:12px;border-radius:3px;background:#E67E22;"></div>
                        <MudText Typo="Typo.caption">PD / PA Day</MudText>
                    </div>
                    <div class="d-flex align-center gap-1">
                        <div style="width:12px;height:12px;border-radius:3px;background:#3498DB;"></div>
                        <MudText Typo="Typo.caption">Snow Day</MudText>
                    </div>
                </div>

                @if (year.CalendarExceptions.Count == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                        No non-school days defined. Use "Import Stat Holidays" or "Add Day Off" above.
                    </MudAlert>
                }
                else
                {
                    <MudTable Items="year.CalendarExceptions.OrderBy(e => e.Date)"
                              Dense="true" Hover="true" Elevation="0"
                              Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                        <HeaderContent>
                            <MudTh>Date</MudTh>
                            <MudTh>Label</MudTh>
                            <MudTh>Type</MudTh>
                            <MudTh></MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd>
                                <MudText Typo="Typo.body2">@context.Date.ToString("MMM d, yyyy")</MudText>
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">
                                    @context.Date.DayOfWeek
                                </MudText>
                            </MudTd>
                            <MudTd>@context.Label</MudTd>
                            <MudTd>
                                @{
                                    var (chipColor, chipLabel) = context.ExceptionType switch
                                    {
                                        CalendarExceptionType.StatHoliday => (Color.Error,   "Stat Holiday"),
                                        CalendarExceptionType.PdPaDay     => (Color.Warning, "PD / PA Day"),
                                        CalendarExceptionType.SnowDay     => (Color.Info,    "Snow Day"),
                                        _                                  => (Color.Default, "Other")
                                    };
                                }
                                <MudChip T="string" Color="@chipColor" Size="Size.Small" Variant="Variant.Filled">
                                    @chipLabel
                                </MudChip>
                            </MudTd>
                            <MudTd Style="text-align:right;">
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                               Color="Color.Error"
                                               OnClick="@(() => DeleteExceptionAsync(context))" />
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }

            </MudCardContent>
        </MudCard>
    }
}

<!-- Apply Curriculum Dialog -->
<MudDialog @bind-Visible="_applyCurriculumOpen">
    <TitleContent><MudText Typo="Typo.h6">Apply Curriculum to @_applyCurriculumYear?.Name</MudText></TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body2" Class="mb-4" Style="color:var(--mud-palette-text-secondary);">
            This creates YearClassOffering and YearSubjectOffering records for every grade/subject combination
            in the template. Existing students can then be reseeded from the Enrollments page.
        </MudText>
        <MudSelect T="int?" @bind-Value="_applyCurriculumSchemaId"
                   Label="Curriculum Template" Variant="Variant.Outlined"
                   AnchorOrigin="Origin.BottomCenter">
            @foreach (var s in _curriculumSchemas)
            {
                <MudSelectItem T="int?" Value="@((int?)s.Id)">@s.Name</MudSelectItem>
            }
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _applyCurriculumOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(_applyCurriculumSchemaId == null || _applyingCurriculum)"
                   OnClick="ApplyCurriculumAsync">
            @(_applyingCurriculum ? "Applying..." : "Apply")
        </MudButton>
    </DialogActions>
</MudDialog>

<!-- Add Exception Dialog -->
<MudDialog @bind-Visible="_addExceptionOpen">
    <TitleContent>
        <MudText Typo="Typo.h6">Add Non-School Day</MudText>
    </TitleContent>
    <DialogContent>
        <MudDatePicker @bind-Date="_exceptionDate" Label="Date" Variant="Variant.Outlined"
                       DateFormat="yyyy-MM-dd" Class="mb-3" />
        <MudTextField @bind-Value="_exceptionLabel" Label="Label"
                      Placeholder="e.g. PA Day 1, Board PD Day" Variant="Variant.Outlined" Class="mb-3" />
        <MudSelect @bind-Value="_exceptionType" Label="Type" Variant="Variant.Outlined">
            <MudSelectItem T="CalendarExceptionType" Value="CalendarExceptionType.PdPaDay">PD / PA Day</MudSelectItem>
            <MudSelectItem T="CalendarExceptionType" Value="CalendarExceptionType.SnowDay">Snow Day</MudSelectItem>
            <MudSelectItem T="CalendarExceptionType" Value="CalendarExceptionType.StatHoliday">Stat Holiday</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _addExceptionOpen = false)">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   Disabled="@(!CanAddException)"
                   OnClick="SaveExceptionAsync">Add</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private class YearCurriculumInfo
    {
        public CurriculumSchema? CurriculumSchema { get; set; }
        public int TotalOfferings { get; set; }
    }

    private List<SchoolYear>          _schoolYears       = new();
    private List<CurriculumSchema>    _curriculumSchemas = new();
    private Dictionary<int, YearCurriculumInfo> _yearCurriculums = new();
    private string _newYearName = "";
    private bool   _showAddForm;

    private Dictionary<int, string>    _newTermNames  = new();
    private Dictionary<int, DateTime?> _newTermStarts = new();
    private Dictionary<int, DateTime?> _newTermEnds   = new();

    private bool                  _addExceptionOpen;
    private int                   _addExceptionYearId;
    private DateTime?             _exceptionDate;
    private string                _exceptionLabel = "";
    private CalendarExceptionType _exceptionType  = CalendarExceptionType.PdPaDay;
    private HashSet<int>          _importingHolidays = new();

    // Apply curriculum dialog
    private bool             _applyCurriculumOpen;
    private bool             _applyingCurriculum;
    private SchoolYear?      _applyCurriculumYear;
    private int?             _applyCurriculumSchemaId;


    private bool CanAddException =>
        _exceptionDate.HasValue && !string.IsNullOrWhiteSpace(_exceptionLabel);

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _schoolYears = await Db.SchoolYears
            .Include(y => y.TermInstances)
            .Include(y => y.CalendarExceptions)
            .OrderByDescending(y => y.Name)
            .ToListAsync();

        _curriculumSchemas = await Db.CurriculumSchemas
            .OrderBy(s => s.Name)
            .ToListAsync();

        // Load YearCurriculum per school year
        var yearCurriculums = await Db.YearCurriculums
            .Include(yc => yc.CurriculumSchema)
            .ToListAsync();
        var offeringCounts = await Db.YearClassOfferings
            .GroupBy(o => o.YearCurriculumId)
            .Select(g => new { g.Key, Count = g.Count() })
            .ToListAsync();
        var countMap = offeringCounts.ToDictionary(x => x.Key, x => x.Count);
        _yearCurriculums = yearCurriculums.ToDictionary(
            yc => yc.SchoolYearId,
            yc => new YearCurriculumInfo { CurriculumSchema = yc.CurriculumSchema, TotalOfferings = countMap.GetValueOrDefault(yc.Id) });

        foreach (var y in _schoolYears)
        {
            _newTermNames.TryAdd(y.Id, "");
            _newTermStarts.TryAdd(y.Id, null);
            _newTermEnds.TryAdd(y.Id, null);
        }
    }

    private void OpenApplyCurriculum(SchoolYear year)
    {
        _applyCurriculumYear     = year;
        _applyCurriculumSchemaId = _curriculumSchemas.FirstOrDefault()?.Id;
        _applyCurriculumOpen     = true;
    }

    private async Task ApplyCurriculumAsync()
    {
        if (_applyCurriculumYear == null || _applyCurriculumSchemaId == null) return;
        _applyingCurriculum = true;
        StateHasChanged();
        try
        {
            // Remove existing YearCurriculum for this year if any (clean re-apply)
            var existing = await Db.YearCurriculums
                .Where(yc => yc.SchoolYearId == _applyCurriculumYear.Id)
                .FirstOrDefaultAsync();
            if (existing != null)
            {
                // Remove all offerings under it first
                var existingOfferings = await Db.YearClassOfferings
                    .Where(o => o.YearCurriculumId == existing.Id)
                    .ToListAsync();
                Db.YearClassOfferings.RemoveRange(existingOfferings);
                Db.YearCurriculums.Remove(existing);
                await Db.SaveChangesAsync();
            }

            // Create new YearCurriculum
            var yc = new YearCurriculum
            {
                SchoolYearId       = _applyCurriculumYear.Id,
                CurriculumSchemaId = _applyCurriculumSchemaId.Value,
                AppliedAt          = DateTimeOffset.UtcNow
            };
            Db.YearCurriculums.Add(yc);
            await Db.SaveChangesAsync();

            // Load the full schema with grades/subjects/strands
            var schema = await Db.CurriculumSchemas
                .Include(s => s.GradeTemplates)
                    .ThenInclude(g => g.Grade)
                .Include(s => s.GradeTemplates)
                    .ThenInclude(g => g.ClassTemplates)
                        .ThenInclude(c => c.SubjectTemplates)
                .FirstOrDefaultAsync(s => s.Id == _applyCurriculumSchemaId.Value);

            if (schema == null) return;

            int classCount = 0, subjectCount = 0;
            foreach (var gradeTemplate in schema.GradeTemplates)
            {
                foreach (var classTemplate in gradeTemplate.ClassTemplates)
                {
                    var classOffering = new YearClassOffering
                    {
                        YearCurriculumId          = yc.Id,
                        GradeId                   = gradeTemplate.GradeId,
                        CurriculumClassTemplateId = classTemplate.Id,
                        IsEnabled                 = true
                    };
                    Db.YearClassOfferings.Add(classOffering);
                    await Db.SaveChangesAsync();
                    classCount++;

                    foreach (var subjectTemplate in classTemplate.SubjectTemplates)
                    {
                        Db.YearSubjectOfferings.Add(new YearSubjectOffering
                        {
                            YearClassOfferingId          = classOffering.Id,
                            CurriculumSubjectTemplateId  = subjectTemplate.Id,
                            IsEnabled                    = true
                        });
                        subjectCount++;
                    }
                    await Db.SaveChangesAsync();
                }
            }

            _applyCurriculumOpen = false;
            Snackbar.Add($"Curriculum applied: {classCount} class offering(s), {subjectCount} subject offering(s) created. Now reseed students from the Enrollments page.", Severity.Success);
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _applyingCurriculum = false;
        }
    }

    private async Task AddSchoolYearAsync()
    {
        var name = _newYearName.Trim();
        if (string.IsNullOrWhiteSpace(name)) return;
        if (await Db.SchoolYears.AnyAsync(y => y.Name == name))
        { Snackbar.Add($"School year '{name}' already exists.", Severity.Warning); return; }
        Db.SchoolYears.Add(new SchoolYear { Name = name });
        await Db.SaveChangesAsync();
        _newYearName = ""; _showAddForm = false;
        Snackbar.Add($"'{name}' added.", Severity.Success);
        await LoadAsync();
    }

    private async Task SetActiveAsync(SchoolYear year)
    {
        await Db.SchoolYears.ExecuteUpdateAsync(s => s.SetProperty(y => y.IsActive, false));
        year.IsActive = true;
        await Db.SaveChangesAsync();
        Snackbar.Add($"'{year.Name}' is now the active school year.", Severity.Success);
        await LoadAsync();
    }

    private async Task ToggleLockAsync(SchoolYear year)
    {
        year.IsLocked = !year.IsLocked;
        await Db.SaveChangesAsync();
        Snackbar.Add(year.IsLocked ? $"'{year.Name}' locked." : $"'{year.Name}' unlocked.", Severity.Info);
        await LoadAsync();
    }

    private bool CanAddTerm(int yearId) =>
        _newTermNames.TryGetValue(yearId, out var n) && !string.IsNullOrWhiteSpace(n) &&
        _newTermStarts.TryGetValue(yearId, out var s) && s.HasValue &&
        _newTermEnds.TryGetValue(yearId, out var e) && e.HasValue;

    private async Task AddTermAsync(SchoolYear year)
    {
        if (!CanAddTerm(year.Id)) return;
        var name  = _newTermNames[year.Id].Trim();
        var start = DateOnly.FromDateTime(_newTermStarts[year.Id]!.Value);
        var end   = DateOnly.FromDateTime(_newTermEnds[year.Id]!.Value);
        if (start >= end) { Snackbar.Add("End date must be after start date.", Severity.Warning); return; }
        Db.TermInstances.Add(new TermInstance
        {
            SchoolYearId = year.Id, Name = name,
            SortOrder    = year.TermInstances.Count + 1,
            StartDate    = start, EndDate = end
        });
        await Db.SaveChangesAsync();
        _newTermNames[year.Id] = ""; _newTermStarts[year.Id] = null; _newTermEnds[year.Id] = null;
        Snackbar.Add($"Term '{name}' added.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteTermAsync(TermInstance term)
    {
        Db.TermInstances.Remove(term);
        await Db.SaveChangesAsync();
        Snackbar.Add($"Term '{term.Name}' deleted.", Severity.Info);
        await LoadAsync();
    }

    private async Task SetTermSlotAsync(TermInstance term, ReportCardTermSlot slot)
    {
        term.ReportCardTermSlot = slot;
        await Db.SaveChangesAsync();
        var label = slot switch
        {
            ReportCardTermSlot.Term1         => "Term 1 (left column)",
            ReportCardTermSlot.Term2         => "Term 2 (right column)",
            _                               => "Not Applicable"
        };
        Snackbar.Add($"'{term.Name}' set to {label}.", Severity.Success);
    }

    private void OpenAddException(int yearId)
    {
        _addExceptionYearId = yearId;
        _exceptionDate      = null;
        _exceptionLabel     = "";
        _exceptionType      = CalendarExceptionType.PdPaDay;
        _addExceptionOpen   = true;
    }

    private async Task SaveExceptionAsync()
    {
        if (!CanAddException) return;
        var date = DateOnly.FromDateTime(_exceptionDate!.Value);

        if (await Db.SchoolCalendarExceptions.AnyAsync(
                e => e.SchoolYearId == _addExceptionYearId && e.Date == date))
        {
            Snackbar.Add("A calendar exception already exists for that date.", Severity.Warning);
            return;
        }

        Db.SchoolCalendarExceptions.Add(new SchoolCalendarException
        {
            SchoolYearId  = _addExceptionYearId,
            Date          = date,
            ExceptionType = _exceptionType,
            Label         = _exceptionLabel.Trim()
        });
        await Db.SaveChangesAsync();
        _addExceptionOpen = false;
        Snackbar.Add($"'{_exceptionLabel}' added to calendar.", Severity.Success);
        await LoadAsync();
    }

    private async Task DeleteExceptionAsync(SchoolCalendarException ex)
    {
        Db.SchoolCalendarExceptions.Remove(ex);
        await Db.SaveChangesAsync();
        Snackbar.Add($"'{ex.Label}' removed.", Severity.Info);
        await LoadAsync();
    }

    private async Task ImportStatHolidaysAsync(SchoolYear year)
    {
        var holidays = OntarioStatHolidayService.GetHolidaysForSchoolYear(year.Name);
        if (holidays.Count == 0)
        {
            Snackbar.Add("Could not parse year numbers from school year name. Expected format like '2025-2026'.", Severity.Warning);
            return;
        }

        _importingHolidays.Add(year.Id);
        StateHasChanged();

        int imported = 0;
        int skipped  = 0;

        try
        {
            var existing = year.CalendarExceptions.Select(e => e.Date).ToHashSet();

            // Only import holidays that fall within at least one term's date range
            var termRanges = year.TermInstances.Select(t => (t.StartDate, t.EndDate)).ToList();
            var inScope = holidays.Where(h =>
                termRanges.Any(r => h.Date >= r.StartDate && h.Date <= r.EndDate)).ToList();

            if (inScope.Count == 0)
            {
                Snackbar.Add("No stat holidays fall within any of the defined term date ranges.", Severity.Info);
                return;
            }

            foreach (var h in inScope)
            {
                if (existing.Contains(h.Date)) { skipped++; continue; }

                Db.SchoolCalendarExceptions.Add(new SchoolCalendarException
                {
                    SchoolYearId  = year.Id,
                    Date          = h.Date,
                    ExceptionType = CalendarExceptionType.StatHoliday,
                    Label         = h.Name
                });
                existing.Add(h.Date);
                imported++;
            }

            await Db.SaveChangesAsync();
            var msg = imported > 0
                ? $"Imported {imported} Ontario stat holidays." + (skipped > 0 ? $" ({skipped} already existed)" : "")
                : "No new stat holidays to import — all already existed.";
            Snackbar.Add(msg, imported > 0 ? Severity.Success : Severity.Info);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _importingHolidays.Remove(year.Id);
            await LoadAsync();
        }
    }




