@page "/"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@using Microsoft.EntityFrameworkCore
@using ReportCards.Web.Data
@inject SchoolDbContext Db
@inject ReportCards.Web.Services.AttendanceService AttendanceSvc
@inject IDialogService DialogSvc

<div class="d-flex align-center gap-4 mb-6">
    <img src="https://www.kinderkollege.ca/images/logo_4.png"
         alt="KinderKollege"
         style="height:64px; object-fit:contain;" />
    <div>
        <MudText Typo="Typo.h4" Style="font-family:'DM Serif Display',serif; line-height:1.1;">
            Report Card Builder
        </MudText>
        <MudText Typo="Typo.body2" Style="color:var(--mud-palette-text-secondary);">
            KinderKollege Private Primary School — @DateTime.Now.ToString("MMMM d, yyyy")
        </MudText>
    </div>
</div>

<!-- ── Summary Cards ───────────────────────────────────── -->
<MudGrid Class="mb-6">
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="1" Style="border-top: 4px solid #1B4F72;">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); text-transform:uppercase; letter-spacing:0.06em;">
                            Active Students
                        </MudText>
                        <MudText Typo="Typo.h3" Style="font-weight:700; font-family:'DM Serif Display',serif;">
                            @_activeStudents
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.School"
                             Style="font-size:40px; color:#1B4F72; opacity:0.2;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="1" Style="border-top: 4px solid #E67E22;">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); text-transform:uppercase; letter-spacing:0.06em;">
                            Active Teachers
                        </MudText>
                        <MudText Typo="Typo.h3" Style="font-weight:700; font-family:'DM Serif Display',serif;">
                            @_activeTeachers
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Person"
                             Style="font-size:40px; color:#E67E22; opacity:0.2;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="1" Style="border-top: 4px solid #27AE60;">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); text-transform:uppercase; letter-spacing:0.06em;">
                            Enrollments
                        </MudText>
                        <MudText Typo="Typo.h3" Style="font-weight:700; font-family:'DM Serif Display',serif;">
                            @_totalEnrollments
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.EditNote"
                             Style="font-size:40px; color:#27AE60; opacity:0.2;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <MudCard Elevation="1" Style="border-top: 4px solid #8E44AD;">
            <MudCardContent Class="pa-4">
                <div class="d-flex align-center justify-space-between">
                    <div>
                        <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); text-transform:uppercase; letter-spacing:0.06em;">
                            Class Groups
                        </MudText>
                        <MudText Typo="Typo.h3" Style="font-weight:700; font-family:'DM Serif Display',serif;">
                            @_classGroups
                        </MudText>
                    </div>
                    <MudIcon Icon="@Icons.Material.Filled.Groups"
                             Style="font-size:40px; color:#8E44AD; opacity:0.2;" />
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<!-- ── School Calendar ────────────────────────────────── -->
<MudCard Elevation="1">
    <MudCardHeader>
        <CardHeaderContent>
            <div class="d-flex align-center gap-3">
                <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft" Size="Size.Small"
                               OnClick="PrevMonth" />
                <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif; min-width:180px; text-align:center;">
                    @_calendarMonth.ToString("MMMM yyyy")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.ChevronRight" Size="Size.Small"
                               OnClick="NextMonth" />
                @if (_calendarMonth.Year != DateTime.Today.Year || _calendarMonth.Month != DateTime.Today.Month)
                {
                    <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="GoToToday">Today</MudButton>
                }
                @if (_activeYear != null)
                {
                    <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary); margin-left:8px;">
                        @_activeYear.Name
                        @if (_currentTerm != null)
                        {
                            <span> &mdash; @_currentTerm.Name</span>
                        }
                    </MudText>
                }
            </div>
        </CardHeaderContent>
        <CardHeaderActions>
            <!-- Legend -->
            <div class="d-flex align-center gap-3 pr-2">
                <div class="d-flex align-center gap-1">
                    <div style="width:10px;height:10px;border-radius:2px;background:#E8F4FD;"></div>
                    <MudText Typo="Typo.caption">In Term</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <div style="width:10px;height:10px;border-radius:2px;background:#E74C3C;"></div>
                    <MudText Typo="Typo.caption">Stat Holiday</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <div style="width:10px;height:10px;border-radius:2px;background:#E67E22;"></div>
                    <MudText Typo="Typo.caption">PD / PA Day</MudText>
                </div>
                <div class="d-flex align-center gap-1">
                    <div style="width:10px;height:10px;border-radius:2px;background:#3498DB;"></div>
                    <MudText Typo="Typo.caption">Snow Day</MudText>
                </div>
            </div>
        </CardHeaderActions>
    </MudCardHeader>
    <MudCardContent Style="padding-top:0;">
        @{
            var daysInMonth  = DateTime.DaysInMonth(_calendarMonth.Year, _calendarMonth.Month);
            var firstDayOfMonth = new DateTime(_calendarMonth.Year, _calendarMonth.Month, 1);
            // Week starts Monday: Mon=0 ... Sun=6
            var startOffset = ((int)firstDayOfMonth.DayOfWeek + 6) % 7;
            var totalCells  = startOffset + daysInMonth;
            var totalRows   = (int)Math.Ceiling(totalCells / 7.0);
        }

        <!-- Day headers -->
        <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:2px; margin-bottom:4px;">
            @foreach (var d in new[] { "Mon","Tue","Wed","Thu","Fri","Sat","Sun" })
            {
                <div style="text-align:center; padding:4px 0;">
                    <MudText Typo="Typo.caption" Style="font-weight:600; color:var(--mud-palette-text-secondary); text-transform:uppercase; font-size:0.65rem; letter-spacing:0.05em;">@d</MudText>
                </div>
            }
        </div>

        <!-- Day cells -->
        <div style="display:grid; grid-template-columns:repeat(7,1fr); gap:3px;">
            @for (int cell = 0; cell < totalRows * 7; cell++)
            {
                int dayNum = cell - startOffset + 1;
                if (dayNum < 1 || dayNum > daysInMonth)
                {
                    <div style="min-height:56px;"></div>
                }
                else
                {
                    var date     = new DateOnly(_calendarMonth.Year, _calendarMonth.Month, dayNum);
                    var dateTime = date.ToDateTime(TimeOnly.MinValue);
                    var isToday  = date == DateOnly.FromDateTime(DateTime.Today);
                    var isWeekend = dateTime.DayOfWeek == DayOfWeek.Saturday || dateTime.DayOfWeek == DayOfWeek.Sunday;
                    var inTerm   = _activeYear?.TermInstances.Any(t => date >= t.StartDate && date <= t.EndDate) ?? false;
                    _calendarExceptions.TryGetValue(date, out var exc);

                    var cellBg = exc?.ExceptionType switch
                    {
                        CalendarExceptionType.StatHoliday => "#FDE8E8",
                        CalendarExceptionType.PdPaDay     => "#FEF0E6",
                        CalendarExceptionType.SnowDay     => "#E8F1FD",
                        _                                  => inTerm ? "#E8F4FD" : "transparent"
                    };
                    var borderStyle = isToday
                        ? "2px solid var(--mud-palette-primary)"
                        : "1px solid var(--mud-palette-divider)";
                    var dayColor = isToday
                        ? "var(--mud-palette-primary)"
                        : isWeekend ? "var(--mud-palette-text-disabled)" : "var(--mud-palette-text-primary)";

                    var dayStyle = $"font-weight:{(isToday ? "700" : "400")}; color:{dayColor}; font-size:0.8rem;";
                    _birthdayMap.TryGetValue((_calendarMonth.Month, dayNum), out var birthdays);
                    var isClickable = inTerm && exc == null && !isWeekend;
                    var cellCursor  = isClickable ? "cursor:pointer;" : "";
                    var capturedDate = date;
                    <div style="min-height:140px; border-radius:6px; border:@borderStyle; background:@cellBg; padding:6px 8px; position:relative; @cellCursor"
                         @onclick="@(isClickable ? () => OpenAttendanceAsync(capturedDate) : null)">
                        <MudText Typo="Typo.body2" Style="@dayStyle">@dayNum</MudText>
                        @if (exc != null)
                        {
                            var (badgeBg, badgeFg) = exc.ExceptionType switch
                            {
                                CalendarExceptionType.StatHoliday => ("#E74C3C", "white"),
                                CalendarExceptionType.PdPaDay     => ("#E67E22", "white"),
                                CalendarExceptionType.SnowDay     => ("#3498DB", "white"),
                                _                                  => ("#95A5A6", "white")
                            };
                            var badgeStyle = $"font-size:0.6rem; line-height:1.3; color:{badgeFg}; font-weight:600;";
                            <div style="display:inline-block; margin-top:4px; padding:2px 6px; border-radius:4px; background:@badgeBg;">
                                <MudText Typo="Typo.caption" Style="@badgeStyle">
                                    @exc.Label
                                </MudText>
                            </div>
                        }
                        @if (birthdays != null && birthdays.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @foreach (var bday in birthdays)
                                {
                                    var fullName = $"{bday.FirstName} {bday.LastName}";
                                    var avatarSrc = GetAvatarUrl(bday.AvatarConfigJson, bday.FirstName);
                                    <MudTooltip Text="@($"🎂 {fullName}")">
                                        <div style="width:48px; height:48px; border-radius:50%; overflow:hidden; border:2px solid #ddd; flex-shrink:0;">
                                            <img src="@avatarSrc" style="width:48px; height:48px;" alt="@fullName" />
                                        </div>
                                    </MudTooltip>
                                }
                            </div>
                        }
                        @if (_attendanceMap.TryGetValue(date, out var attendees) && attendees.Count > 0)
                        {
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                @foreach (var (student, attType) in attendees)
                                {
                                    var attName = $"{student.FirstName} {student.LastName}";
                                    var attSrc  = GetAvatarUrl(student.AvatarConfigJson, student.FirstName);
                                    var attLabel = attType == AttendanceType.Absent ? "❌ Absent" : "⏰ Late";
                                    var attBorder = attType == AttendanceType.Absent ? "2px solid #E74C3C" : "2px solid #F39C12";
                                    var attOverlay = attType == AttendanceType.Absent
                                        ? "position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(231,76,60,0.35); border-radius:50%;"
                                        : "position:absolute; top:0; left:0; width:100%; height:100%; background:rgba(243,156,18,0.35); border-radius:50%;";
                                    var attLine = attType == AttendanceType.Absent
                                        ? "position:absolute; top:50%; left:-4px; right:-4px; height:3px; background:#E74C3C; transform:rotate(-35deg); border-radius:2px;"
                                        : "";
                                    <MudTooltip Text="@($"{attLabel}: {attName}")">
                                        <div style="position:relative; width:40px; height:40px; flex-shrink:0;">
                                            <div style="width:40px; height:40px; border-radius:50%; overflow:hidden; border:@attBorder;">
                                                <img src="@attSrc" style="width:40px; height:40px;" alt="@attName" />
                                            </div>
                                            <div style="@attOverlay"></div>
                                            @if (attType == AttendanceType.Absent)
                                            {
                                                <div style="@attLine"></div>
                                            }
                                        </div>
                                    </MudTooltip>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>

        <!-- Term bar -->
        @if (_activeYear?.TermInstances.Count > 0)
        {
            <div class="d-flex flex-wrap gap-3 mt-4">
                @foreach (var term in _activeYear.TermInstances.OrderBy(t => t.SortOrder))
                {
                    var isCurrent = DateOnly.FromDateTime(DateTime.Today) >= term.StartDate &&
                                    DateOnly.FromDateTime(DateTime.Today) <= term.EndDate;
                    <div class="d-flex align-center gap-1">
                        @if (isCurrent)
                        {
                            <MudIcon Icon="@Icons.Material.Filled.Circle" Size="Size.Small"
                                     Style="color:var(--mud-palette-success); font-size:8px;" />
                        }
                        <MudText Typo="Typo.caption" Style="@(isCurrent ? "font-weight:600;" : "color:var(--mud-palette-text-secondary);")">@term.Name: @term.StartDate.ToString("MMM d") – @term.EndDate.ToString("MMM d, yyyy")</MudText>
                    </div>
                }
            </div>
        }
    </MudCardContent>
</MudCard>

<!-- ── Attendance Dialog ──────────────────────────────── -->
<MudDialog @bind-Visible="_attendanceOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true })">
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.HowToReg" Color="Color.Primary" />
            <MudText Typo="Typo.h6" Style="font-family:'DM Serif Display',serif;">
                Attendance — @_attendanceDate.ToString("dddd, MMMM d, yyyy")
            </MudText>
        </div>
    </TitleContent>
    <DialogContent>
        @if (_attendanceEnrollments.Count == 0)
        {
            <MudAlert Severity="Severity.Info">No students enrolled for this term.</MudAlert>
        }
        else
        {
            <MudTable Items="_attendanceEnrollments" Dense="true" Hover="true" Elevation="0"
                      Style="border:1px solid var(--mud-palette-divider); border-radius:8px;">
                <HeaderContent>
                    <MudTh>Student</MudTh>
                    <MudTh Style="text-align:center; width:140px;">Status</MudTh>
                </HeaderContent>
                <RowTemplate>
                    @{
                        var sid  = context.StudentId;
                        var type = _attendanceEdits.GetValueOrDefault(sid);
                        var avatarSrc = GetAvatarUrl(context.Student?.AvatarConfigJson, context.Student?.FirstName);
                    }
                    <MudTd>
                        <div class="d-flex align-center gap-2">
                            <div style="width:36px; height:36px; border-radius:50%; overflow:hidden; flex-shrink:0;">
                                <img src="@avatarSrc" style="width:36px; height:36px;" />
                            </div>
                            <div>
                                <MudText Typo="Typo.body2" Style="font-weight:600;">@context.Student?.FirstName @context.Student?.LastName</MudText>
                                <MudText Typo="Typo.caption" Style="color:var(--mud-palette-text-secondary);">@context.ClassGroupInstance?.DisplayName — @context.Grade?.Name</MudText>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd Style="text-align:center;">
                        <div class="d-flex justify-center gap-1">
                            <MudTooltip Text="Present">
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.CheckCircle"
                                               Color="@(type == null ? Color.Success : Color.Default)"
                                               Style="@(type == null ? "background:rgba(46,204,113,0.15);border-radius:50%;" : "")"
                                               OnClick="@(() => { _attendanceEdits[sid] = null; StateHasChanged(); })" />
                            </MudTooltip>
                            <MudTooltip Text="Late">
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.Schedule"
                                               Color="@(type == AttendanceType.Late ? Color.Warning : Color.Default)"
                                               Style="@(type == AttendanceType.Late ? "background:rgba(230,126,34,0.15);border-radius:50%;" : "")"
                                               OnClick="@(() => { _attendanceEdits[sid] = AttendanceType.Late; StateHasChanged(); })" />
                            </MudTooltip>
                            <MudTooltip Text="Absent">
                                <MudIconButton Size="Size.Small"
                                               Icon="@Icons.Material.Filled.Cancel"
                                               Color="@(type == AttendanceType.Absent ? Color.Error : Color.Default)"
                                               Style="@(type == AttendanceType.Absent ? "background:rgba(231,76,60,0.15);border-radius:50%;" : "")"
                                               OnClick="@(() => { _attendanceEdits[sid] = AttendanceType.Absent; StateHasChanged(); })" />
                            </MudTooltip>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        }
    </DialogContent>
    <DialogActions>
        <MudButton Variant="Variant.Text" OnClick="@(() => _attendanceOpen = false)" Disabled="_attendanceSaving">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Save"
                   OnClick="SaveAttendanceAsync"
                   Disabled="_attendanceSaving">
            @if (_attendanceSaving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private int _activeStudents;
    private int _activeTeachers;
    private int _totalEnrollments;
    private int _classGroups;
    private SchoolYear?   _activeYear;
    private TermInstance? _currentTerm;

    private DateTime _calendarMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
    private Dictionary<DateOnly, SchoolCalendarException> _calendarExceptions = new();
    private Dictionary<(int Month, int Day), List<Student>> _birthdayMap = new();
    // date → list of (student, attendanceType)
    private Dictionary<DateOnly, List<(Student Student, AttendanceType Type)>> _attendanceMap = new();

    protected override async Task OnInitializedAsync()
    {
        _activeStudents   = await Db.Students.CountAsync(s => s.IsActive);
        _activeTeachers   = await Db.Teachers.CountAsync(t => t.IsActive);
        _totalEnrollments = await Db.Enrollments.CountAsync();
        _classGroups      = await Db.ClassGroupInstances.CountAsync();

        _activeYear = await Db.SchoolYears
            .Include(y => y.TermInstances)
            .Include(y => y.CalendarExceptions)
            .FirstOrDefaultAsync(y => y.IsActive);

        if (_activeYear != null)
        {
            var today = DateOnly.FromDateTime(DateTime.Today);
            _currentTerm = _activeYear.TermInstances
                .FirstOrDefault(t => today >= t.StartDate && today <= t.EndDate);
            _calendarExceptions = _activeYear.CalendarExceptions
                .ToDictionary(e => e.Date, e => e);
        }

        // Load active students with birthdays
        var studentsWithDob = await Db.Students
            .Where(s => s.IsActive && s.DateOfBirth != null)
            .Select(s => new { s.FirstName, s.LastName, s.DateOfBirth, s.AvatarConfigJson })
            .ToListAsync();

        _birthdayMap = studentsWithDob
            .GroupBy(s => (s.DateOfBirth!.Value.Month, s.DateOfBirth.Value.Day))
            .ToDictionary(
                g => g.Key,
                g => g.Select(s => new Student { FirstName = s.FirstName, LastName = s.LastName, AvatarConfigJson = s.AvatarConfigJson }).ToList()
            );

        await LoadAttendanceMapAsync();
    }

    private async Task PrevMonth()
    {
        _calendarMonth = _calendarMonth.AddMonths(-1);
        await LoadAttendanceMapAsync();
    }

    private async Task NextMonth()
    {
        _calendarMonth = _calendarMonth.AddMonths(1);
        await LoadAttendanceMapAsync();
    }

    private async Task GoToToday()
    {
        _calendarMonth = new DateTime(DateTime.Today.Year, DateTime.Today.Month, 1);
        await LoadAttendanceMapAsync();
    }

    private async Task LoadAttendanceMapAsync()
    {
        var monthStart = new DateOnly(_calendarMonth.Year, _calendarMonth.Month, 1);
        var monthEnd   = new DateOnly(_calendarMonth.Year, _calendarMonth.Month,
                             DateTime.DaysInMonth(_calendarMonth.Year, _calendarMonth.Month));

        // Load all attendance events for this month with student info
        var events = await Db.AttendanceEvents
            .Where(a => a.Date >= monthStart && a.Date <= monthEnd)
            .Include(a => a.Student)
            .ToListAsync();

        _attendanceMap = events
            .GroupBy(a => a.Date)
            .ToDictionary(
                g => g.Key,
                g => g.Select(a => (a.Student!, a.Type)).ToList()
            );
    }

    // ── Attendance Dialog ─────────────────────────────────────────

    private bool                             _attendanceOpen   = false;
    private DateOnly                         _attendanceDate;
    private bool                             _attendanceSaving = false;
    private List<Enrollment>                 _attendanceEnrollments = new();
    private Dictionary<int, AttendanceType?> _attendanceEdits  = new(); // studentId → type (null = present)

    private async Task OpenAttendanceAsync(DateOnly date)
    {
        if (_activeYear == null) return;
        _attendanceDate  = date;
        _attendanceEdits = new();
        _attendanceSaving = false;

        // Find the term for this date
        var term = _activeYear.TermInstances
            .FirstOrDefault(t => date >= t.StartDate && date <= t.EndDate);
        if (term == null) return;

        // Load enrolled students for this term
        _attendanceEnrollments = await Db.Enrollments
            .Where(e => e.TermInstanceId == term.Id)
            .Include(e => e.Student)
            .Include(e => e.Grade)
            .Include(e => e.ClassGroupInstance)
            .OrderBy(e => e.Student!.LastName).ThenBy(e => e.Student!.FirstName)
            .ToListAsync();

        // Load existing attendance events for this date
        var studentIds = _attendanceEnrollments.Select(e => e.StudentId).ToList();
        var existing   = await Db.AttendanceEvents
            .Where(a => studentIds.Contains(a.StudentId) && a.Date == date)
            .ToListAsync();

        foreach (var e in _attendanceEnrollments)
            _attendanceEdits[e.StudentId] = existing.FirstOrDefault(a => a.StudentId == e.StudentId)?.Type;

        _attendanceOpen = true;
    }

    private async Task SaveAttendanceAsync()
    {
        _attendanceSaving = true;
        StateHasChanged();

        var studentIds = _attendanceEnrollments.Select(e => e.StudentId).ToList();
        var existing   = await Db.AttendanceEvents
            .Where(a => studentIds.Contains(a.StudentId) && a.Date == _attendanceDate)
            .ToListAsync();
        Db.AttendanceEvents.RemoveRange(existing);

        foreach (var (sid, type) in _attendanceEdits)
        {
            if (type.HasValue)
            {
                Db.AttendanceEvents.Add(new AttendanceEvent
                {
                    StudentId = sid,
                    Date      = _attendanceDate,
                    Type      = type.Value
                });
            }
        }

        await Db.SaveChangesAsync();
        _attendanceSaving = false;
        _attendanceOpen   = false;
        await LoadAttendanceMapAsync();
        StateHasChanged();
    }

    private static string GetAvatarUrl(string? json, string? name)
    {
        Dictionary<string, string> props = new();
        if (!string.IsNullOrWhiteSpace(json))
        {
            try { props = System.Text.Json.JsonSerializer.Deserialize<Dictionary<string, string>>(json) ?? new(); }
            catch { }
        }
        var sb = new System.Text.StringBuilder("https://api.dicebear.com/9.x/avataaars/svg?");
        sb.Append("seed=").Append(Uri.EscapeDataString(name ?? "student"));
        if (props.TryGetValue("skinColor",       out var skin))  sb.Append("&skinColor=").Append(skin);
        if (props.TryGetValue("top",             out var top))   sb.Append("&top=").Append(top);
        if (props.TryGetValue("hairColor",       out var hc))    sb.Append("&hairColor=").Append(hc);
        if (props.TryGetValue("eyes",            out var eyes))  sb.Append("&eyes=").Append(eyes);
        if (props.TryGetValue("mouth",           out var mouth)) sb.Append("&mouth=").Append(mouth);
        if (props.TryGetValue("clothing",        out var cloth)) sb.Append("&clothing=").Append(cloth);
        sb.Append("&accessoriesProbability=0&facialHairProbability=0");
        if (props.TryGetValue("backgroundColor", out var bg))   sb.Append("&backgroundColor=").Append(bg);
        sb.Append("&backgroundType=solid&radius=50&scale=90");
        return sb.ToString();
    }
}
