@using ReportCards.Web.Services
@inject AssistantService Assistant
@inject AssistantContextService AssistantCtx
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@implements IDisposable

<!-- ── Floating chat button ─────────────────────────────────────────── -->
@if (!_open)
{
    <div style="position:fixed; bottom:28px; right:28px; z-index:2000;">
        <MudTooltip Text="School Assistant" Placement="Placement.Left">
            <MudFab Color="Color.Primary"
                    StartIcon="@Icons.Material.Filled.AutoAwesome"
                    Size="Size.Large"
                    OnClick="OpenAsync"
                    Style="box-shadow: 0 4px 20px rgba(0,0,0,0.25);" />
        </MudTooltip>
    </div>
}

<!-- ── Chat panel ───────────────────────────────────────────────────── -->
@if (_open)
{
    <div style="position:fixed; bottom:24px; right:24px; z-index:2000;
                width:440px; max-height:660px;
                display:flex; flex-direction:column;
                background:var(--mud-palette-surface);
                border-radius:16px;
                box-shadow: 0 8px 40px rgba(0,0,0,0.22);
                border:1px solid var(--mud-palette-divider);
                overflow:hidden;">

        <!-- Header -->
        <div style="display:flex; align-items:center; gap:10px; padding:12px 16px;
                    background:var(--mud-palette-primary); color:white; flex-shrink:0;">
            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color:white;" />
            <div style="flex:1; min-width:0;">
                <MudText Typo="Typo.subtitle1" Style="font-weight:700; color:white; line-height:1.2;">
                    School Assistant
                </MudText>
                @if (!string.IsNullOrWhiteSpace(AssistantCtx.Current.PageLabel))
                {
                    <div style="display:inline-flex; align-items:center; gap:4px; margin-top:2px;
                                background:rgba(255,255,255,0.2); border-radius:20px;
                                padding:1px 8px; font-size:0.68rem; color:white;">
                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="font-size:10px;" />
                        @AssistantCtx.Current.PageLabel
                        @if (!string.IsNullOrWhiteSpace(AssistantCtx.Current.StudentName))
                        {
                            <span style="opacity:0.75;"> · @AssistantCtx.Current.StudentName</span>
                        }
                    </div>
                }
                else
                {
                    <MudText Typo="Typo.caption" Style="color:rgba(255,255,255,0.7);">
                        Powered by Claude · Ask me anything
                    </MudText>
                }
            </div>
            <!-- TTS toggle -->
            <MudTooltip Text="@(_ttsEnabled ? "Mute voice" : "Enable voice")">
                <MudIconButton Icon="@(_ttsEnabled ? Icons.Material.Filled.VolumeUp : Icons.Material.Filled.VolumeOff)"
                               Size="Size.Small" Style="color:rgba(255,255,255,0.8);"
                               OnClick="ToggleTts" />
            </MudTooltip>
            <!-- Clear -->
            <MudTooltip Text="Clear chat">
                <MudIconButton Icon="@Icons.Material.Filled.DeleteSweep"
                               Size="Size.Small" Style="color:rgba(255,255,255,0.6);"
                               OnClick="ClearChat" />
            </MudTooltip>
            <MudIconButton Icon="@Icons.Material.Filled.Close"
                           Size="Size.Small" Style="color:rgba(255,255,255,0.8);"
                           OnClick="CloseAsync" />
        </div>

        <!-- Messages -->
        <div id="assistant-messages"
             style="flex:1; overflow-y:auto; padding:16px;
                    display:flex; flex-direction:column; gap:10px; min-height:0;">

            @if (_messages.Count == 0)
            {
                <div style="text-align:center; padding:24px 16px; color:var(--mud-palette-text-secondary);">
                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome"
                             Style="font-size:40px; color:var(--mud-palette-primary); opacity:0.6; margin-bottom:8px;" />
                    <MudText Typo="Typo.body2" Style="font-weight:600; margin-bottom:6px;">
                        Hi! I'm your school assistant.
                    </MudText>
                    @if (!string.IsNullOrWhiteSpace(AssistantCtx.Current.PageLabel))
                    {
                        <MudText Typo="Typo.caption">
                            I can see you're on <strong>@AssistantCtx.Current.PageLabel</strong>.
                            @if (!string.IsNullOrWhiteSpace(AssistantCtx.Current.SuggestedPrompt))
                            {
                                <span><br/>Try: "<em>@AssistantCtx.Current.SuggestedPrompt</em>"</span>
                            }
                        </MudText>
                    }
                    else
                    {
                        <MudText Typo="Typo.caption">
                            Try: "Everyone was here except David" or "Who was absent this week?"
                        </MudText>
                    }
                </div>
            }

            @foreach (var msg in _messages)
            {
                var isUser = msg.Role == "user";
                <div style="display:flex; @(isUser ? "justify-content:flex-end;" : "justify-content:flex-start;")">
                    <div style="max-width:88%;
                                @(isUser
                                    ? "background:var(--mud-palette-primary); color:white; border-radius:16px 16px 4px 16px;"
                                    : "background:var(--mud-palette-background-grey); color:var(--mud-palette-text-primary); border-radius:16px 16px 16px 4px;")
                                padding:10px 14px; font-size:0.875rem; line-height:1.5; word-break:break-word;">

                        @((MarkupString)FormatMessage(msg.Content))

                        @if (msg.Action != null && msg == _pendingActionMessage)
                        {
                            <div style="margin-top:10px; padding-top:10px; border-top:1px solid rgba(255,255,255,0.25);">
                                <MudText Typo="Typo.caption" Style="font-weight:700; margin-bottom:6px; display:block;">
                                    Confirm changes:
                                </MudText>
                                @foreach (var change in msg.Action.AttendanceChanges ?? new())
                                {
                                    var icon = change.Status == "absent" ? "❌" : change.Status == "late" ? "⏰" : "✅";
                                    <div style="font-size:0.78rem; margin-bottom:2px;">
                                        @icon @change.StudentName — @change.Status on @change.Date
                                    </div>
                                }
                                <div class="d-flex gap-2 mt-2">
                                    <MudButton Variant="Variant.Filled" Size="Size.Small" Color="Color.Success"
                                               StartIcon="@Icons.Material.Filled.Check"
                                               OnClick="ConfirmActionAsync" Disabled="_executing">
                                        @if (_executing) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-1" /> }
                                        Confirm
                                    </MudButton>
                                    <MudButton Variant="Variant.Text" Size="Size.Small"
                                               Style="color:rgba(255,255,255,0.8);"
                                               OnClick="CancelAction" Disabled="_executing">
                                        Cancel
                                    </MudButton>
                                </div>
                            </div>
                        }
                        @if (msg.Action != null && msg == _executedActionMessage)
                        {
                            <div style="margin-top:6px; font-size:0.78rem; opacity:0.8;">✅ Done — records updated.</div>
                        }
                    </div>
                </div>
            }

            @if (_thinking)
            {
                <div style="display:flex; justify-content:flex-start;">
                    <div style="background:var(--mud-palette-background-grey); border-radius:16px 16px 16px 4px; padding:10px 16px;">
                        <div style="display:flex; gap:4px; align-items:center;">
                            <span class="asst-dot" style="animation-delay:0s;"></span>
                            <span class="asst-dot" style="animation-delay:0.2s;"></span>
                            <span class="asst-dot" style="animation-delay:0.4s;"></span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Input bar -->
        <div style="padding:10px 12px; border-top:1px solid var(--mud-palette-divider); flex-shrink:0;
                    display:flex; align-items:flex-end; gap:6px; background:var(--mud-palette-surface);">

            <MudTextField @ref="_inputField"
                          @bind-Value="_input"
                          Placeholder="@(_listening ? "Listening..." : "Ask me anything...")"
                          Variant="Variant.Outlined"
                          Margin="Margin.Dense"
                          AutoGrow="true"
                          Lines="1"
                          MaxLines="4"
                          Style="flex:1; font-size:0.875rem;"
                          Disabled="@(_thinking || _listening)"
                          OnKeyDown="HandleKeyDown" />

            <MudTooltip Text="@(_listening ? "Stop listening" : "Speak your message")">
                <MudIconButton Icon="@(_listening ? Icons.Material.Filled.MicOff : Icons.Material.Filled.Mic)"
                               Color="@(_listening ? Color.Error : Color.Default)"
                               Variant="@(_listening ? Variant.Filled : Variant.Text)"
                               Size="Size.Medium"
                               Style="margin-bottom:2px; flex-shrink:0;"
                               OnClick="ToggleMicAsync"
                               Disabled="_thinking" />
            </MudTooltip>

            <MudIconButton Icon="@Icons.Material.Filled.Send"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Size="Size.Medium"
                           Style="margin-bottom:2px; flex-shrink:0;"
                           OnClick="SendMessageAsync"
                           Disabled="@(string.IsNullOrWhiteSpace(_input) || _thinking || _listening)" />
        </div>
    </div>
}

<style>
    .asst-dot {
        width:6px; height:6px; border-radius:50%;
        background:var(--mud-palette-text-secondary);
        display:inline-block;
        animation:asstBounce 1s infinite;
    }
    @@keyframes asstBounce {
        0%,80%,100% { transform:translateY(0); }
        40%         { transform:translateY(-6px); }
    }
</style>

@code {
    private bool   _open       = false;
    private bool   _thinking   = false;
    private bool   _executing  = false;
    private bool   _ttsEnabled = false;
    private bool   _listening  = false;
    private string _input      = "";

    private List<ChatMessage> _messages             = new();
    private ChatMessage?      _pendingActionMessage = null;
    private ChatMessage?      _executedActionMessage = null;

    private MudTextField<string>?                        _inputField;
    private DotNetObjectReference<AssistantChatDrawer>?  _dotNetRef;

    protected override void OnInitialized()
    {
        AssistantCtx.OnContextChanged += OnContextChanged;
    }

    // Called when an AssistantButton on any page sets context
    private void OnContextChanged()
    {
        _messages.Clear();
        _pendingActionMessage  = null;
        _executedActionMessage = null;
        _input = AssistantCtx.Current.SuggestedPrompt ?? "";
        _open  = true;
        InvokeAsync(async () =>
        {
            StateHasChanged();
            await ScrollToBottomAsync();
        });
    }

    private async Task OpenAsync()
    {
        _open = true;
        StateHasChanged();
        await ScrollToBottomAsync();
    }

    private async Task CloseAsync()
    {
        _open = false;
        await StopMicAsync();
        try { await JS.InvokeVoidAsync("assistantTts.stop"); } catch { }
        StateHasChanged();
    }

    private void ClearChat()
    {
        _messages.Clear();
        _pendingActionMessage  = null;
        _executedActionMessage = null;
        _input = "";
        StateHasChanged();
    }

    private async Task ToggleTts()
    {
        _ttsEnabled = !_ttsEnabled;
        if (!_ttsEnabled) try { await JS.InvokeVoidAsync("assistantTts.stop"); } catch { }
        StateHasChanged();
    }

    // ── Mic ──────────────────────────────────────────────────────────────────

    private async Task ToggleMicAsync()
    {
        if (_listening) await StopMicAsync();
        else            await StartMicAsync();
    }

    private async Task StartMicAsync()
    {
        _dotNetRef ??= DotNetObjectReference.Create(this);
        try { await JS.InvokeVoidAsync("assistantStt.start", _dotNetRef); }
        catch { Snackbar.Add("Microphone not available.", Severity.Warning); }
    }

    private async Task StopMicAsync()
    {
        try { await JS.InvokeVoidAsync("assistantStt.stop"); } catch { }
    }

    [JSInvokable] public void OnSttStarted()
    {
        _listening = true;
        _input     = "";
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable] public void OnSttResult(string transcript, bool isFinal)
    {
        _input = transcript;
        if (isFinal)
        {
            _listening = false;
            InvokeAsync(async () =>
            {
                StateHasChanged();
                await Task.Delay(250);
                await SendMessageAsync();
            });
        }
        else InvokeAsync(StateHasChanged);
    }

    [JSInvokable] public void OnSttEnded()
    {
        _listening = false;
        InvokeAsync(StateHasChanged);
    }

    [JSInvokable] public void OnSttError(string error)
    {
        _listening = false;
        if (error != "no-speech")
            Snackbar.Add($"Mic error: {error}", Severity.Warning);
        InvokeAsync(StateHasChanged);
    }

    // ── Messaging ────────────────────────────────────────────────────────────

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_thinking && !_listening)
            await SendMessageAsync();
    }

    private async Task SendMessageAsync()
    {
        var text = _input.Trim();
        if (string.IsNullOrWhiteSpace(text) || _thinking) return;

        _input    = "";
        _thinking = true;
        _pendingActionMessage = null;
        _messages.Add(new ChatMessage("user", text));
        StateHasChanged();
        await ScrollToBottomAsync();

        try
        {
            var historyForApi = _messages
                .Take(_messages.Count - 1)
                .Select(m => new ChatMessage(m.Role, m.Content))
                .ToList();

            var reply = await Assistant.SendAsync(historyForApi, text);
            _messages.Add(reply);

            if (reply.Action?.Type == "mark_attendance" && reply.Action.AttendanceChanges?.Count > 0)
                _pendingActionMessage = reply;

            if (_ttsEnabled && !string.IsNullOrWhiteSpace(reply.Content))
                try { await JS.InvokeVoidAsync("assistantTts.speak", reply.Content); } catch { }
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage("assistant", $"⚠️ Something went wrong: {ex.Message}"));
        }
        finally
        {
            _thinking = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private async Task ConfirmActionAsync()
    {
        if (_pendingActionMessage?.Action == null) return;
        _executing = true;
        StateHasChanged();
        try
        {
            await Assistant.ExecuteAttendanceAsync(_pendingActionMessage.Action);
            _executedActionMessage = _pendingActionMessage;
            _pendingActionMessage  = null;
            Snackbar.Add("Attendance updated!", Severity.Success);
            if (_ttsEnabled)
                try { await JS.InvokeVoidAsync("assistantTts.speak", "Done, attendance updated."); } catch { }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _executing = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private void CancelAction()
    {
        _pendingActionMessage = null;
        _messages.Add(new ChatMessage("assistant", "No worries — no changes were made."));
        StateHasChanged();
    }

    private async Task ScrollToBottomAsync()
    {
        await Task.Delay(60);
        try { await JS.InvokeVoidAsync("assistantUi.scrollToBottom", "assistant-messages"); } catch { }
    }

    private static string FormatMessage(string text)
    {
        var html = System.Net.WebUtility.HtmlEncode(text);
        html = System.Text.RegularExpressions.Regex.Replace(html, @"\*\*(.+?)\*\*", "<strong>$1</strong>");
        html = html.Replace("\n", "<br/>");
        return html;
    }

    public void Dispose()
    {
        AssistantCtx.OnContextChanged -= OnContextChanged;
        _dotNetRef?.Dispose();
    }
}
